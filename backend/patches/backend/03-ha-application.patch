+    pub async fn become_leader(
+        &self,
+        rw_persistence: Arc<dyn Persistence>,
+        retention_rate_limiter: Arc<common::runtime::RateLimiter<RT>>,
+        preempt_signal: ShutdownSignal,
+    ) -> anyhow::Result<()> {
+        tracing::info!("[promote] Application::become_leader: promoting Database");
+        let deleted_tablet_receiver = self
+            .database
+            .become_leader(
+                rw_persistence.clone(),
+                retention_rate_limiter,
+                preempt_signal.clone(),
+            )
+            .await?;
+        let log_streaming_allowed = {
+            let mut tx = self.database.begin(Identity::system()).await?;
+            let mut bi = BackendInfoModel::new(&mut tx);
+            bi.is_log_streaming_allowed().await?
+        };
+        let real_log_manager_client = LogManager::start(
+            self.runtime.clone(),
+            self.database.clone(),
+            self.fetch_client.clone(),
+            self.deployment.name.clone(),
+            self.deployment.region.as_ref().map(|r| r.to_string()),
+            log_streaming_allowed,
+            self.usage_counter.clone(),
+        )
+        .await;
+        let prev = self
+            .promotion_log_manager
+            .lock()
+            .replace(real_log_manager_client.clone());
+        if let Some(prev) = prev {
+            let _ = prev.shutdown().await;
+        }
+        tracing::info!("[promote] Application::become_leader: starting leader workers");
+        self.start_leader_workers(
+            rw_persistence,
+            real_log_manager_client,
+            preempt_signal,
+            deleted_tablet_receiver,
+        )
+        .await?;
+        tracing::info!("[promote] Application::become_leader complete");
+        Ok(())
+    }
+
+    pub async fn become_follower(
+        &self,
+        rw_persistence: Arc<dyn Persistence>,
+    ) -> anyhow::Result<()> {
+        tracing::info!("[demote] Application::become_follower: stopping leader workers");
+        let workers = self.workers.lock().take();
+        if let Some(workers) = workers {
+            workers.shutdown().await?;
+        }
+        let promo_log = self.promotion_log_manager.lock().take();
+        if let Some(promo_log) = promo_log {
+            let _ = promo_log.shutdown().await;
+        }
+        tracing::info!("[demote] Application::become_follower: demoting Database");
+        self.database.become_follower(rw_persistence).await?;
+        tracing::info!("[demote] Application::become_follower complete");
+        Ok(())
     }
 
