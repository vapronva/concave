+} from "@common/lib/generatedApiStub";
+import { PlatformDeploymentResponse } from "@convex-dev/platform/managementApi";
+
+export function useCurrentDeployment() {
+  const { useCurrentDeployment: hook } = useContext(DeploymentInfoContext);
+  return hook();
+}
+
+export function useDeploymentByName(_name?: string) {
+  const { useCurrentDeployment: hook } = useContext(DeploymentInfoContext);
+  return hook();
+}
+
+export function useDeploymentRegions(_teamId?: number): {
+  regions: Array<{ name: string; displayName: string }> | undefined;
+} {
+  return { regions: undefined };
+}
+
+export function useCurrentTeam() {
+  const { useCurrentTeam: hook } = useContext(DeploymentInfoContext);
+  return hook();
+}
+
+export function useTeamMembers(
+  teamId?: number,
+): Array<{ id: number; name?: string | null; email: string }> | undefined {
+  const { useTeamMembers: hook } = useContext(DeploymentInfoContext);
+  const members = hook(teamId);
+  return members?.map((m) => ({ ...m, email: m.email ?? "" }));
+}
+
+export function useCurrentProject() {
+  const { useCurrentProject: hook } = useContext(DeploymentInfoContext);
+  return hook();
+}
+
+export function useProjectById(projectId?: number): {
+  project: ProjectDetails | null;
+  isLoading: boolean;
+} {
+  const { useCurrentProject: hook } = useContext(DeploymentInfoContext);
+  const current = hook();
+  if (current && current.id === projectId) {
+    return {
+      project: { ...current, teamId: (current as any).teamId ?? 0 },
+      isLoading: false,
+    };
+  }
+  return { project: null, isLoading: false };
+}
+
+export function useProfile():
+  | { id: number; name?: string | null; email?: string }
+  | undefined {
+  return undefined;
+}
+
+export function useHasProjectAdminPermissions(_projectId?: number): boolean {
+  const { useHasProjectAdminPermissions: hook } = useContext(
+    DeploymentInfoContext,
+  );
+  return hook(_projectId);
+}
+
+export function useHasCustomRolePermission(
+  _teamId: number | undefined,
+  _action: string,
+  _resource: unknown,
+  builtinAllowed: boolean,
+): boolean | undefined {
+  const { useHasProjectAdminPermissions: hook } = useContext(
+    DeploymentInfoContext,
+  );
+  const isAdmin = hook(undefined);
+  return isAdmin || builtinAllowed;
+}
+
+export function useListCloudBackupsIfAvailable(
+  _deployment: PlatformDeploymentResponse | undefined,
+): CloudBackupResponse[] | null | undefined {
+  return null;
+}
+
+export function deploymentResource(
+  _project: unknown,
+  _deployment: unknown,
+): undefined {
+  return undefined;
+}
+
+export function permissionDeniedTip(
+  message: string,
+  _action: string,
+): React.ReactNode {
+  return message;
+}
+
+export function usePostHog(): {
+  capture: (event: string, properties?: Record<string, unknown>) => void;
+} {
+  return { capture: () => {} };
+}
+
+export function getDeploymentLabel({
+  deployment,
+  whoseName,
+}: {
+  deployment: PlatformDeploymentResponse | DeploymentResponse;
+  whoseName: string | null;
+}): string {
+  if (
+    (deployment.deploymentType === "custom" ||
+      ("isDefault" in deployment &&
+        !deployment.isDefault &&
+        deployment.deploymentType !== "preview")) &&
+    "reference" in deployment &&
+    deployment.reference
+  ) {
+    return deployment.reference;
+  }
+  switch (deployment.deploymentType) {
+    case "prod":
+      return "Production";
+    case "preview":
+      return `Preview: ${(deployment as any).previewIdentifier || "Unknown"}`;
+    case "dev": {
+      if (deployment.kind === "local") {
+        return (deployment as any).deviceName ?? "Local";
+      }
+      return whoseName === null ? "Development (Cloud)" : `${whoseName}’s Dev`;
+    }
+    case "custom":
+      return "Custom";
+    default:
+      return "";
+  }
+}
