+export function useGetZipExport(): (
+  snapshotId: Id<"_exports">,
+  filename: string,
+) => Promise<void> {
+  const deploymentUrl = useDeploymentUrl();
+  const adminKey = useAdminKey();
+  const { reportHttpError } = useContext(DeploymentInfoContext);
+  return useCallback(
+    async (snapshotId: Id<"_exports">, filename: string) => {
+      const url = `${deploymentUrl}/api/export/zip/${snapshotId}`;
+      const res = await fetch(url, {
+        headers: { Authorization: `Convex ${adminKey}` },
+      });
+      if (!res.ok) {
+        const err = await deploymentResponseError(res);
+        reportHttpError("GET", res.url, err);
+        toast("error", err.message);
+        return;
+      }
+      const blob = await res.blob();
+      const objectUrl = URL.createObjectURL(blob);
+      const anchor = document.createElement("a");
+      anchor.href = objectUrl;
+      anchor.download = filename;
+      document.body.appendChild(anchor);
+      anchor.click();
+      document.body.removeChild(anchor);
+      URL.revokeObjectURL(objectUrl);
+    },
+    [deploymentUrl, adminKey, reportHttpError],
+  );
+}
+
+async function deploymentResponseError(res: Response) {
+  const text = await res.text();
+  try {
+    return JSON.parse(text);
+  } catch {
+    return { message: text || `${res.status} ${res.statusText}` };
+  }
+}
+
+export function useRequestZipExport(): () => Promise<void> {
+  const deploymentUrl = useDeploymentUrl();
+  const adminKey = useAdminKey();
+  const { reportHttpError } = useContext(DeploymentInfoContext);
+  return useCallback(async () => {
+    const res = await fetch(
+      `${deploymentUrl}/api/export/request/zip?includeStorage=true`,
+      {
+        method: "POST",
+        headers: { Authorization: `Convex ${adminKey}` },
+      },
+    );
+    if (!res.ok) {
+      const err = await deploymentResponseError(res);
+      reportHttpError("POST", res.url, err);
+      toast("error", err.message);
+      return;
+    }
+    toast("success", "Snapshot export requested.");
+  }, [deploymentUrl, adminKey, reportHttpError]);
+}
+
+export function useUploadSnapshotImport(): (file: File) => Promise<void> {
+  const deploymentUrl = useDeploymentUrl();
+  const adminKey = useAdminKey();
+  const { reportHttpError } = useContext(DeploymentInfoContext);
+  return useCallback(
+    async (file: File) => {
+      const headers = { Authorization: `Convex ${adminKey}` };
+      const checkedFetch = async (path: string, init: RequestInit) => {
+        const res = await fetch(`${deploymentUrl}${path}`, {
+          ...init,
+          headers: { ...headers, ...init.headers },
+        });
+        if (!res.ok) {
+          const err = await deploymentResponseError(res);
+          reportHttpError(init.method ?? "GET", res.url, err);
+          throw new Error(err.message);
+        }
+        return res;
+      };
+      try {
+        const start = await checkedFetch("/api/import/start_upload", {
+          method: "POST",
+        });
+        const { uploadToken } = await start.json();
+        const chunkSize = Math.max(
+          5 * 1024 * 1024,
+          Math.ceil(file.size / 9999),
+        );
+        const partTokens: string[] = [];
+        for (
+          let offset = 0, partNumber = 1;
+          offset < file.size;
+          offset += chunkSize, partNumber += 1
+        ) {
+          const part = await checkedFetch(
+            `/api/import/upload_part?uploadToken=${encodeURIComponent(
+              uploadToken,
+            )}&partNumber=${partNumber}`,
+            {
+              method: "POST",
+              headers: { "Content-Type": "application/octet-stream" },
+              body: file.slice(offset, offset + chunkSize),
+            },
+          );
+          partTokens.push(await part.json());
+        }
+        await checkedFetch("/api/import/finish_upload", {
+          method: "POST",
+          headers: { "Content-Type": "application/json" },
+          body: JSON.stringify({
+            import: { mode: "replaceAll", format: "zip" },
+            uploadToken,
+            partTokens,
+          }),
+        });
+        toast("success", "Snapshot uploaded. Review and confirm the import.");
+      } catch (error) {
+        toast(
+          "error",
+          error instanceof Error ? error.message : "Snapshot upload failed.",
+        );
+      }
+    },
+    [deploymentUrl, adminKey, reportHttpError],
+  );
+}
+
+export function useCancelImport(): (
+  id: Id<"_snapshot_imports">,
+) => Promise<void> {
+  const deploymentUrl = useDeploymentUrl();
+  const adminKey = useAdminKey();
+  const { reportHttpError } = useContext(DeploymentInfoContext);
+  return useCallback(
+    async (id: Id<"_snapshot_imports">) => {
+      const res = await fetch(`${deploymentUrl}/api/cancel_import`, {
+        method: "POST",
+        headers: {
+          Authorization: `Convex ${adminKey}`,
+          "Content-Type": "application/json",
+        },
+        body: JSON.stringify({ importId: id }),
+      });
+      if (res.status !== 200) {
+        const err = await deploymentResponseError(res);
+        reportHttpError("POST", res.url, err);
+        toast("error", err.message);
+      }
+    },
+    [deploymentUrl, adminKey, reportHttpError],
+  );
+}
+
+export function useConfirmImport(): (
+  id: Id<"_snapshot_imports">,
+) => Promise<void> {
+  const deploymentUrl = useDeploymentUrl();
+  const adminKey = useAdminKey();
+  const { reportHttpError } = useContext(DeploymentInfoContext);
+  return useCallback(
+    async (importId: Id<"_snapshot_imports">) => {
+      const url = `${deploymentUrl}/api/perform_import`;
+      const res = await fetch(url, {
+        method: "POST",
+        headers: {
+          Authorization: `Convex ${adminKey}`,
+          "Content-Type": "application/json",
+        },
+        body: JSON.stringify({ importId }),
+      });
+      if (res.status !== 200) {
+        const err = await deploymentResponseError(res);
+        reportHttpError("POST", res.url, err);
+        toast("error", err.message);
+      }
+    },
+    [deploymentUrl, adminKey, reportHttpError],
+  );
+}
+
+export function useLogDeploymentEvent() {
+  const { useLogDeploymentEvent: hook } = useContext(DeploymentInfoContext);
+  return hook();
+}
