diff --git a/npm-packages/dashboard-common/src/lib/bigBrainApi.ts b/npm-packages/dashboard-common/src/lib/bigBrainApi.ts
new file mode 100644
index 000000000..2c91afc41
--- /dev/null
+++ b/npm-packages/dashboard-common/src/lib/bigBrainApi.ts
@@ -0,0 +1,227 @@
+import { useCallback, useContext } from "react";
+import useSWR, { SWRConfiguration, SWRResponse, useSWRConfig } from "swr";
+import {
+  ConnectedDeploymentContext,
+  DeploymentInfoContext,
+} from "@common/lib/deploymentContext";
+import { toast } from "@common/lib/utils";
+
+export const OIDC_TOKEN_STORAGE_KEY = "convexOidcAccessToken";
+
+export function useBigBrainUrl(): string | undefined {
+  const ctx = useContext(DeploymentInfoContext);
+  return ctx.bigBrainUrl ?? undefined;
+}
+
+export function useBigBrainToken(): string | undefined {
+  const ctx = useContext(DeploymentInfoContext);
+  return ctx.bigBrainToken ?? undefined;
+}
+
+export function useProjectDeployKey(): (deployment: string) => Promise<string> {
+  const base = useBigBrainUrl();
+  return useCallback(
+    async (deployment: string): Promise<string> => {
+      if (!base) {
+        throw new Error("The control-plane router URL is not configured.");
+      }
+      const oidc =
+        typeof window !== "undefined"
+          ? window.sessionStorage.getItem(OIDC_TOKEN_STORAGE_KEY)
+          : null;
+      if (!oidc) {
+        throw new Error("Sign in with SSO to get a project deploy key.");
+      }
+      const r = await bbFetch(base, oidc, {
+        method: "POST",
+        path: "/project_deploy_key",
+        body: JSON.stringify({ deployment }),
+      });
+      if (!r.ok) {
+        throw new Error(r.error?.message || `Request failed (${r.status})`);
+      }
+      return r.data?.deployKey as string;
+    },
+    [base],
+  );
+}
+
+function useAuthToken(): string | undefined {
+  const bigBrainToken = useBigBrainToken();
+  if (bigBrainToken) return bigBrainToken;
+  const cd = useContext(ConnectedDeploymentContext);
+  const adminKey = cd?.deployment?.adminKey;
+  if (adminKey) return adminKey;
+  if (typeof window !== "undefined") {
+    const oidc = window.sessionStorage.getItem(OIDC_TOKEN_STORAGE_KEY);
+    if (oidc) return oidc;
+  }
+  return undefined;
+}
+
+function substitute(path: string, pathParams?: Record<string, any>): string {
+  if (!pathParams) return path;
+  return path.replace(/\{([^}]+)\}/g, (_m, k) =>
+    encodeURIComponent(String(pathParams[k] ?? "")),
+  );
+}
+
+function queryString(queryParams?: Record<string, any>): string {
+  if (!queryParams) return "";
+  const u = new URLSearchParams();
+  for (const [k, v] of Object.entries(queryParams)) {
+    if (v !== undefined && v !== null && v !== "") u.set(k, String(v));
+  }
+  const s = u.toString();
+  return s ? `?${s}` : "";
+}
+
+function keyFor(
+  path: string,
+  pathParams?: Record<string, any>,
+  queryParams?: Record<string, any>,
+): string {
+  return `bb:${substitute(path, pathParams)}${queryString(queryParams)}`;
+}
+
+async function bbFetch(
+  base: string,
+  token: string | undefined,
+  init: RequestInit & { path: string },
+): Promise<{ ok: boolean; status: number; data: any; error: any }> {
+  const url = `${base.replace(/\/$/, "")}/api/dashboard${init.path}`;
+  const res = await fetch(url, {
+    ...init,
+    headers: {
+      ...(token ? { Authorization: `Bearer ${token}` } : {}),
+      ...(init.body ? { "content-type": "application/json" } : {}),
+      ...(init.headers || {}),
+    },
+  });
+  let body: any;
+  try {
+    body = await res.json();
+  } catch {
+    body = undefined;
+  }
+  return {
+    ok: res.ok,
+    status: res.status,
+    data: res.ok ? body : undefined,
+    error: res.ok
+      ? undefined
+      : (body ?? { code: "Error", message: `HTTP ${res.status}` }),
+  };
+}
+
+export function useBBQuery({
+  path,
+  pathParams,
+  queryParams,
+  swrOptions,
+}: {
+  path: string;
+  pathParams?: Record<string, any>;
+  queryParams?: Record<string, any>;
+  swrOptions?: Omit<SWRConfiguration, "onError">;
+}): SWRResponse<any, any> {
+  const base = useBigBrainUrl();
+  const token = useAuthToken();
+  const paused =
+    !base ||
+    !token ||
+    (!!pathParams && Object.values(pathParams).some((p) => !p));
+  const key = paused ? null : keyFor(path, pathParams, queryParams);
+  return useSWR(
+    key,
+    async () => {
+      const r = await bbFetch(base!, token, {
+        method: "GET",
+        path: `${substitute(path, pathParams)}${queryString(queryParams)}`,
+      });
+      if (!r.ok) {
+        const e: any = new Error(r.error?.message || "request failed");
+        e.code = r.error?.code;
+        throw e;
+      }
+      return r.data;
+    },
+    swrOptions ?? {},
+  );
+}
+
+export function useBBMutation({
+  path,
+  pathParams,
+  method = "post",
+  successToast,
+  toastOnError = true,
+  mutateKey,
+  mutatePathParams,
+}: {
+  path: string;
+  pathParams?: Record<string, any>;
+  method?: "post";
+  successToast?: string;
+  toastOnError?: boolean;
+  mutateKey?: string;
+  mutatePathParams?: Record<string, any>;
+}) {
+  const base = useBigBrainUrl();
+  const token = useAuthToken();
+  const { mutate } = useSWRConfig();
+  const pp = JSON.stringify(pathParams ?? {});
+  const mpp = JSON.stringify(mutatePathParams ?? {});
+  return useCallback(
+    async (body?: any): Promise<any> => {
+      if (!base) {
+        const e = new Error("The control-plane router URL is not configured.");
+        if (toastOnError) toast("error", e.message);
+        throw e;
+      }
+      let r: { ok: boolean; status: number; data: any; error: any };
+      try {
+        r = await bbFetch(base, token, {
+          method: method.toUpperCase(),
+          path: substitute(path, pathParams),
+          body: body !== undefined ? JSON.stringify(body) : undefined,
+        });
+      } catch (e: any) {
+        if (toastOnError) toast("error", e.message || "Network error");
+        throw e;
+      }
+      if (!r.ok) {
+        if (toastOnError)
+          toast("error", r.error?.message || `Request failed (${r.status})`);
+        const e: any = new Error(
+          r.error?.message || `Request failed (${r.status})`,
+        );
+        e.code = r.error?.code;
+        throw e;
+      }
+      if (successToast) toast("success", successToast);
+      if (mutateKey) {
+        const prefix = keyFor(mutateKey, mutatePathParams);
+        await mutate(
+          (k) => typeof k === "string" && k.startsWith(prefix),
+          undefined,
+          { revalidate: true },
+        );
+      }
+      return r.data;
+    },
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+    [
+      base,
+      token,
+      path,
+      pp,
+      method,
+      successToast,
+      toastOnError,
+      mutateKey,
+      mpp,
+      mutate,
+    ],
+  );
+}
