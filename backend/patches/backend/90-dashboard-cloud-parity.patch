+import useSWR, { BareFetcher } from "swr";
+import { deploymentAuthMiddleware } from "@common/lib/deploymentApi";
+import { deploymentFetch } from "@common/lib/fetching";
+
+export type DateRange = { from: string; to: string };
+
+export const USAGE_REFRESH_INTERVAL_MS =
+  getURLConfigInt("usage_refresh_secs", 60 * 10) * 1000;
+export const rootComponentPath = "-root-component-";
+
+export function useUsageQuery({ period }: { period: DateRange | null }) {
+  const queryParams = new URLSearchParams();
+  if (period) {
+    queryParams.set("from", period.from);
+    queryParams.set("to", period.to);
+  }
+  const fetcher = deploymentFetch as BareFetcher<any[][]>;
+  const result = useSWR<any[][]>(
+    `/api/insights/usage/query?${queryParams.toString()}`,
+    fetcher,
+    {
+      use: [deploymentAuthMiddleware],
+      keepPreviousData: false,
+      refreshInterval: USAGE_REFRESH_INTERVAL_MS,
+    },
+  );
+  return {
+    ...result,
+    data: result.data?.map((row: any[]) =>
+      row.map((cell: any) => cell ?? ""),
+    ) as string[][] | undefined,
+  };
+}
+
+function getURLConfigInt(name: string, defaultValue: number) {
+  if (typeof window === "undefined") {
+    return defaultValue;
+  }
+  const value = new URLSearchParams(window.location.search).get(name);
+  if (value === null) {
+    return defaultValue;
+  }
+  const parsed = Number.parseInt(value, 10);
+  return Number.isFinite(parsed) && parsed > 0 ? parsed : defaultValue;
+}
