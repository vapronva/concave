+#[derive(Clone)]
+pub struct InstanceState<RT: Runtime> {
+    pub rt: RT,
+    pub instance_name: String,
+    pub instance_secret: DeploymentSecret,
+    pub key_broker: FunctionRunnerKeyBroker,
+    pub reader: Arc<dyn PersistenceReader>,
+    pub retention_validator: Arc<dyn RetentionValidator>,
+    pub searcher: Arc<dyn search::Searcher>,
+    pub search_storage: Arc<dyn Storage>,
+    pub core: FunctionRunnerCore<RT, DeploymentStorage>,
+    pub database: Database<RT>,
+}
+
+impl<RT: Runtime> InstanceState<RT> {
+    pub async fn load(
+        rt: RT,
+        config: &FunrunInstanceConfig,
+        db: clusters::DbDriverTag,
+        require_ssl: bool,
+        shared_isolate: SharedIsolateResources<RT>,
+    ) -> anyhow::Result<Self> {
+        let reader = db_connection::connect_persistence_reader(
+            db,
+            &config.db_spec,
+            require_ssl,
+            false,
+            &config.instance_name,
+            rt.clone(),
+        )
+        .await?;
+        let retention_validator: Arc<dyn RetentionValidator> =
+            Arc::new(FollowerRetentionManager::new(rt.clone(), reader.clone()).await?);
+        let key_broker =
+            keybroker::KeyBroker::new(&config.instance_name, config.instance_secret.clone())?
+                .function_runner_keybroker();
+        let mut storage_type = Self::read_storage_type(&rt, &reader, &retention_validator).await?;
+        if let Some(prefix) = &config.bucket_prefix {
+            match &mut storage_type {
+                StorageType::S3 { s3_prefix } => {
+                    tracing::info!(
+                        "[convex-funrun] instance {}: overriding S3 prefix {:?} -> {:?}",
+                        config.instance_name,
+                        s3_prefix,
+                        prefix,
+                    );
+                    *s3_prefix = prefix.clone();
+                },
+                StorageType::Local { .. } => {
+                    tracing::warn!(
+                        "[convex-funrun] instance {}: bucket_prefix override ignored for Local \
+                         storage",
+                        config.instance_name,
+                    );
+                },
+            }
+        }
+        let files_storage =
+            create_storage(rt.clone(), &storage_type, storage::StorageUseCase::Files).await?;
+        let modules_storage =
+            create_storage(rt.clone(), &storage_type, storage::StorageUseCase::Modules).await?;
+        let search_storage = create_storage(
+            rt.clone(),
+            &storage_type,
+            storage::StorageUseCase::SearchIndexes,
+        )
+        .await?;
+        let searcher: Arc<dyn search::Searcher> = Arc::new(InProcessSearcher::new(rt.clone())?);
+        let core = FunctionRunnerCore::new_with_isolate_client(
+            rt.clone(),
+            DeploymentStorage {
+                files_storage,
+                modules_storage,
+            },
+            shared_isolate,
+        );
+        let database = Database::load_follower(
+            reader.clone(),
+            rt.clone(),
+            searcher.clone(),
+            virtual_system_mapping().clone(),
+            IndexCache::new(*common::knobs::FUNRUN_INDEX_CACHE_SIZE).new_handle(),
+        )
+        .await?;
+        database.set_search_storage(search_storage.clone());
+        tracing::info!(
+            "[convex-funrun] loaded instance {} ({:?} storage); warm follower snapshot at {}",
+            config.instance_name,
+            storage_type,
+            database.now_ts_for_reads(),
+        );
+        Ok(Self {
+            rt,
+            instance_name: config.instance_name.clone(),
+            instance_secret: config.instance_secret.clone(),
+            key_broker,
+            reader,
+            retention_validator,
+            searcher,
+            search_storage,
+            core,
+            database,
+        })
+    }
+
+    async fn read_storage_type(
+        rt: &RT,
+        reader: &Arc<dyn PersistenceReader>,
+        retention_validator: &Arc<dyn RetentionValidator>,
+    ) -> anyhow::Result<StorageType> {
+        let ts = new_static_repeatable_recent(reader.as_ref()).await?;
+        let snapshot = DatabaseSnapshot::load(
+            rt.clone(),
+            reader.clone(),
+            ts,
+            retention_validator.clone(),
+            virtual_system_mapping().clone(),
+        )
+        .await?;
+        let text_index_snapshot: Arc<dyn TransactionTextSnapshot> =
+            Arc::new(TextIndexManagerSnapshot::new(
+                snapshot.snapshot.index_registry.clone(),
+                snapshot.snapshot.text_indexes.clone(),
+                Arc::new(InProcessSearcher::new(rt.clone())?),
+                Arc::new(OnceLock::new()),
+            ));
+        let mut tx = snapshot.begin_tx(
+            keybroker::Identity::system(),
+            text_index_snapshot,
+            FunctionUsageTracker::new(),
+            virtual_system_mapping().clone(),
+        )?;
+        DatabaseGlobalsModel::new(&mut tx)
+            .database_globals()
+            .await?
+            .into_value()
+            .storage_type
+            .context(
+                "funrun cannot start: database storage tag is not initialized (the leader must \
+                 initialize the database first)",
+            )
+    }
+
+    pub async fn snapshot_inputs(&self, ts: RepeatableTimestamp) -> anyhow::Result<SnapshotInputs> {
+        let repeatable_persistence =
+            RepeatablePersistence::new(self.reader.clone(), ts, self.retention_validator.clone());
+        let index_reader: Arc<dyn IndexReader> =
+            Arc::new(repeatable_persistence.read_snapshot(ts)?);
+        match self.database.snapshot(ts) {
+            Ok(snapshot) => {
+                let bootstrap_metadata = self.database.bootstrap_metadata.clone();
+                let table_count_snapshot: Arc<dyn TableCountSnapshot> =
+                    match snapshot.table_summaries.clone() {
+                        Some(summaries) => Arc::new(Some(summaries)),
+                        None => Arc::new(self.bootstrap_table_summaries(ts).await?),
+                    };
+                let search_storage_cell = Arc::new(OnceLock::new());
+                let _ = search_storage_cell.set(self.search_storage.clone());
+                let text_index_snapshot: Arc<dyn TransactionTextSnapshot> =
+                    Arc::new(TextIndexManagerSnapshot::new(
+                        snapshot.index_registry,
+                        snapshot.text_indexes,
+                        self.searcher.clone(),
+                        search_storage_cell,
+                    ));
+                Ok(SnapshotInputs {
+                    index_reader,
+                    bootstrap_metadata,
+                    table_count_snapshot,
+                    text_index_snapshot,
+                })
+            },
+            Err(warm_err) => {
+                tracing::debug!(
+                    "[convex-funrun] warm snapshot miss at ts {} ({warm_err:#}); cold-loading",
+                    *ts
+                );
+                self.cold_snapshot_inputs(ts, index_reader).await
+            },
+        }
+    }
+
+    async fn bootstrap_table_summaries(
+        &self,
+        ts: RepeatableTimestamp,
+    ) -> anyhow::Result<Option<database::TableSummaries>> {
+        let (table_summary_snapshot, _num_rows) = database::table_summary::bootstrap(
+            self.rt.clone(),
+            self.reader.clone(),
+            self.retention_validator.clone(),
+            ts,
+            database::table_summary::BootstrapKind::FromCheckpoint,
+        )
+        .await?;
+        let snapshot = self.database.snapshot(ts)?;
+        let summaries = database::TableSummaries::new(
+            table_summary_snapshot,
+            snapshot.table_registry.table_mapping(),
+            &snapshot.virtual_system_mapping,
+        )?;
+        Ok(Some(summaries))
+    }
+
+    async fn cold_snapshot_inputs(
+        &self,
+        ts: RepeatableTimestamp,
+        index_reader: Arc<dyn IndexReader>,
+    ) -> anyhow::Result<SnapshotInputs> {
+        let mut snapshot = DatabaseSnapshot::load(
+            self.rt.clone(),
+            self.reader.clone(),
+            ts,
+            self.retention_validator.clone(),
+            virtual_system_mapping().clone(),
+        )
+        .await?;
+        snapshot.load_table_summaries().await?;
+        let bootstrap_metadata = snapshot.bootstrap_metadata.clone();
+        let table_count_snapshot: Arc<dyn TableCountSnapshot> =
+            Arc::new(snapshot.snapshot.table_summaries);
+        let search_storage_cell = Arc::new(OnceLock::new());
+        let _ = search_storage_cell.set(self.search_storage.clone());
+        let text_index_snapshot: Arc<dyn TransactionTextSnapshot> =
+            Arc::new(TextIndexManagerSnapshot::new(
+                snapshot.snapshot.index_registry,
+                snapshot.snapshot.text_indexes,
+                self.searcher.clone(),
+                search_storage_cell,
+            ));
+        Ok(SnapshotInputs {
+            index_reader,
+            bootstrap_metadata,
+            table_count_snapshot,
+            text_index_snapshot,
+        })
+    }
+}
+
+pub struct SnapshotInputs {
+    pub index_reader: Arc<dyn IndexReader>,
+    pub bootstrap_metadata: BootstrapMetadata,
+    pub table_count_snapshot: Arc<dyn TableCountSnapshot>,
+    pub text_index_snapshot: Arc<dyn TransactionTextSnapshot>,
+}
