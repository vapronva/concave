+    #[tokio::test]
+    async fn same_key_returns_cached_arc_and_builds_once() {
+        let cells = Mutex::new(std::collections::HashMap::new());
+        let builds = AtomicUsize::new(0);
+        let first = get_or_init_cell(&cells, "a", || async {
+            builds.fetch_add(1, Ordering::SeqCst);
+            Ok(Arc::new(42u32))
+        })
+        .await
+        .unwrap();
+        let second = get_or_init_cell(&cells, "a", || async {
+            builds.fetch_add(1, Ordering::SeqCst);
+            Ok(Arc::new(42u32))
+        })
+        .await
+        .unwrap();
+        assert!(Arc::ptr_eq(&first, &second));
+        assert_eq!(builds.load(Ordering::SeqCst), 1);
+    }
+
+    #[tokio::test]
+    async fn concurrent_first_requests_build_exactly_once() {
+        let cells = Mutex::new(std::collections::HashMap::new());
+        let builds = AtomicUsize::new(0);
+        let futs = (0..16).map(|_| {
+            let cells = &cells;
+            let builds = &builds;
+            async move {
+                get_or_init_cell(cells, "same", || async {
+                    builds.fetch_add(1, Ordering::SeqCst);
+                    tokio::task::yield_now().await;
+                    Ok(Arc::new("v".to_owned()))
+                })
+                .await
+                .unwrap()
+            }
+        });
+        let results = futures::future::join_all(futs).await;
+        assert_eq!(builds.load(Ordering::SeqCst), 1);
+        for r in &results {
+            assert!(Arc::ptr_eq(r, &results[0]));
