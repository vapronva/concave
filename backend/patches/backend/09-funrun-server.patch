+fn max_percent_per_client(num_tenants: usize, configured: usize) -> usize {
+    if configured > 0 {
+        return configured.clamp(1, 100);
+    }
+    let tenants = num_tenants.max(1);
+    (100 / tenants).max(10)
+}
