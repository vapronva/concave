+    #[tokio::test]
+    async fn build_error_leaves_cell_empty_for_retry() {
+        let cells = Mutex::new(std::collections::HashMap::new());
+        let err = get_or_init_cell::<u32, _>(&cells, "k", || async {
+            anyhow::bail!("transient load failure")
+        })
+        .await
+        .unwrap_err();
+        assert!(err.to_string().contains("transient load failure"), "{err}");
+        let ok = get_or_init_cell(&cells, "k", || async { Ok(Arc::new(7u32)) })
+            .await
+            .unwrap();
+        assert_eq!(*ok, 7);
+    }
+
+    #[test]
+    fn single_tenant_cap_is_full_pool() {
+        assert_eq!(max_percent_per_client(1, 0), 100);
+    }
