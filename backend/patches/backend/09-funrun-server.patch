+    #[test]
+    fn registry_builds_exactly_one_shared_pool() -> anyhow::Result<()> {
+        let tokio = ProdRuntime::init_tokio()?;
+        let rt = ProdRuntime::new(&tokio);
+        rt.block_on("test", async {
+            let reg = InstanceRegistry::new(rt.clone(), &config(&["a", "b", "c"]))?;
+            let pool_id = reg.shared_pool_id();
+            assert_eq!(reg.shared_pool_id(), pool_id);
+            let reg2 = InstanceRegistry::new(rt.clone(), &config(&["solo"]))?;
+            assert_ne!(reg2.shared_pool_id(), pool_id);
+            reg.shared_isolate.shutdown().await?;
+            reg2.shared_isolate.shutdown().await?;
+            anyhow::Ok(())
+        })
+    }
