@@ -0,0 +1,537 @@
+use anyhow::Context;
+use async_trait::async_trait;
+use common::{
+    bootstrap_model::components::handles::FunctionHandle,
+    components::{
+        CanonicalizedComponentFunctionPath,
+        ComponentId,
+        ComponentPath,
+        SerializedComponentFunctionPath,
+    },
+    execution_context::ExecutionContext,
+    http::{
+        CONVEX_ACTIONS_CALLBACK_TOKEN_HEADER,
+        CONVEX_ACTION_FUNCTION_NAME_HEADER,
+        CONVEX_EXECUTION_ID_HEADER,
+        CONVEX_REQUEST_ID_HEADER,
+        CONVEX_ROOT_REQUEST_HEADER,
+    },
+    runtime::UnixTimestamp,
+    types::ConvexOrigin,
+};
+use keybroker::Identity;
+use model::file_storage::{
+    types::FileStorageEntry,
+    FileStorageId,
+};
+use prost::Message;
+use serde::{
+    Deserialize,
+    Serialize,
+};
+use serde_json::{
+    value::RawValue,
+    Value as JsonValue,
+};
+use sync_types::types::SerializedArgs;
+use udf::{
+    ActionCallbacks,
+    FunctionResult,
+};
+use usage_tracking::FunctionUsageStats;
+use value::{
+    ConvexValue,
+    DeveloperDocumentId,
+    JsonPackedValue,
+};
+use vector::PublicVectorSearchQueryResult;
+
+pub struct HttpActionCallbacks {
+    client: reqwest::Client,
+    backend_url: ConvexOrigin,
+    callback_token: String,
+    auth_header: Option<String>,
+    context: ExecutionContext,
+    action_name: Option<String>,
+}
+
+impl HttpActionCallbacks {
+    pub fn new(
+        client: reqwest::Client,
+        backend_url: ConvexOrigin,
+        callback_token: String,
+        auth_header: Option<String>,
+        context: ExecutionContext,
+        action_name: Option<String>,
+    ) -> Self {
+        Self {
+            client,
+            backend_url,
+            callback_token,
+            auth_header,
+            context,
+            action_name,
+        }
+    }
+
+    fn url(&self, path: &str) -> String {
+        format!(
+            "{}{}",
+            self.backend_url.as_str().trim_end_matches('/'),
+            path
+        )
+    }
+
+    fn request(&self, path: &str) -> reqwest::RequestBuilder {
+        let mut req = self
+            .client
+            .post(self.url(path))
+            .header(CONVEX_ACTIONS_CALLBACK_TOKEN_HEADER, &self.callback_token)
+            .header(
+                CONVEX_REQUEST_ID_HEADER,
+                self.context.request_id.to_string(),
+            )
+            .header(
+                CONVEX_EXECUTION_ID_HEADER,
+                self.context.execution_id.to_string(),
+            )
+            .header(
+                CONVEX_ROOT_REQUEST_HEADER,
+                self.context.is_root().to_string(),
+            );
+        if let Some(auth) = &self.auth_header {
+            req = req.header(http::header::AUTHORIZATION, auth);
+        }
+        req
+    }
+
+    async fn run_function(
+        &self,
+        path: &str,
+        function_path: CanonicalizedComponentFunctionPath,
+        args: SerializedArgs,
+    ) -> anyhow::Result<FunctionResult> {
+        let args_raw: Box<RawValue> = RawValue::from_string(args.get().to_owned())?;
+        let body = RunFunctionBody {
+            path: Some(function_path.udf_path.to_string()),
+            reference: None,
+            function_handle: None,
+            args: args_raw,
+        };
+        let response = self
+            .request(path)
+            .json(&body)
+            .send()
+            .await
+            .with_context(|| format!("funrun action callback to {path} failed"))?;
+        let status = response.status();
+        let text = response.text().await?;
+        if !status.is_success() {
+            anyhow::bail!("funrun callback {path} returned {status}: {text}");
+        }
+        let parsed: RunFunctionResponse = serde_json::from_str(&text)
+            .with_context(|| format!("funrun callback {path} returned unparseable body: {text}"))?;
+        let result = match parsed {
+            RunFunctionResponse::Success { value } => {
+                let convex_value = ConvexValue::try_from(value)
+                    .context("funrun callback success value was not a valid Convex value")?;
+                Ok(JsonPackedValue::pack(convex_value))
+            },
+            RunFunctionResponse::Error {
+                error_message,
+                error_data,
+            } => Err(build_js_error(error_message, error_data)),
+        };
+        Ok(FunctionResult { result })
+    }
+}
+
+fn build_js_error(message: String, data: Option<JsonValue>) -> common::errors::JsError {
+    match data.and_then(|d| ConvexValue::try_from(d).ok()) {
+        Some(custom) => common::errors::JsError::convex_error(message, custom),
+        None => common::errors::JsError::from_message(message),
+    }
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct RunFunctionBody {
+    #[serde(skip_serializing_if = "Option::is_none")]
+    path: Option<String>,
+    #[serde(skip_serializing_if = "Option::is_none")]
+    reference: Option<String>,
+    #[serde(skip_serializing_if = "Option::is_none")]
+    function_handle: Option<String>,
+    args: Box<RawValue>,
+}
+
+#[derive(Deserialize)]
+#[serde(tag = "status", rename_all = "camelCase")]
+enum RunFunctionResponse {
+    #[serde(rename_all = "camelCase")]
+    Success { value: JsonValue },
+    #[serde(rename_all = "camelCase")]
+    Error {
+        error_message: String,
+        #[serde(default)]
+        error_data: Option<JsonValue>,
+    },
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct ScheduleJobBody {
+    udf_path: Option<String>,
+    reference: Option<String>,
+    function_handle: Option<String>,
+    udf_args: Box<RawValue>,
+    scheduled_ts: f64,
+}
+
+#[derive(Deserialize)]
+#[serde(rename_all = "camelCase")]
+struct ScheduleJobResponse {
+    job_id: String,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct CancelJobBody {
+    id: String,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct CreateFunctionHandleBody {
+    udf_path: Option<String>,
+    reference: Option<String>,
+}
+
+#[derive(Deserialize)]
+#[serde(rename_all = "camelCase")]
+struct CreateFunctionHandleResponse {
+    handle: String,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct StorageIdBody {
+    storage_id: String,
+}
+
+#[derive(Deserialize)]
+#[serde(rename_all = "camelCase")]
+struct StorageGetUrlResponse {
+    url: Option<String>,
+}
+
+#[derive(Deserialize)]
+#[serde(rename_all = "camelCase")]
+struct StorageGetFileEntryResponse {
+    component_path: String,
+    entry_proto: Vec<u8>,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct StorageStoreFileEntryBody {
+    entry_proto: Vec<u8>,
+}
+
+#[derive(Deserialize)]
+#[serde(rename_all = "camelCase")]
+struct StorageStoreFileEntryResponse {
+    component_path: String,
+    document_id: String,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct VectorSearchBody {
+    query: JsonValue,
+}
+
+#[derive(Deserialize)]
+#[serde(rename_all = "camelCase")]
+struct VectorSearchResponse {
+    results: Vec<VectorSearchResultJson>,
+}
+
+#[derive(Deserialize)]
+#[serde(rename_all = "camelCase")]
+struct VectorSearchResultJson {
+    #[serde(rename = "_id")]
+    id: String,
+    #[serde(rename = "_score")]
+    score: f32,
+}
+
+#[derive(Serialize)]
+#[serde(rename_all = "camelCase")]
+struct LookupFunctionHandleBody {
+    handle: String,
+}
+
+#[async_trait]
+impl ActionCallbacks for HttpActionCallbacks {
+    async fn execute_query(
+        &self,
+        _identity: Identity,
+        path: CanonicalizedComponentFunctionPath,
+        args: SerializedArgs,
+        _context: ExecutionContext,
+    ) -> anyhow::Result<FunctionResult> {
+        self.run_function("/api/actions/query", path, args).await
+    }
+
+    async fn execute_mutation(
+        &self,
+        _identity: Identity,
+        path: CanonicalizedComponentFunctionPath,
+        args: SerializedArgs,
+        _context: ExecutionContext,
+    ) -> anyhow::Result<FunctionResult> {
+        self.run_function("/api/actions/mutation", path, args).await
+    }
+
+    async fn execute_action(
+        &self,
+        _identity: Identity,
+        path: CanonicalizedComponentFunctionPath,
+        args: SerializedArgs,
+        _context: ExecutionContext,
+    ) -> anyhow::Result<FunctionResult> {
+        self.run_function("/api/actions/action", path, args).await
+    }
+
+    async fn schedule_job(
+        &self,
+        _identity: Identity,
+        _scheduling_component: ComponentId,
+        scheduled_path: CanonicalizedComponentFunctionPath,
+        udf_args: SerializedArgs,
+        scheduled_ts: UnixTimestamp,
+        _context: ExecutionContext,
+    ) -> anyhow::Result<DeveloperDocumentId> {
+        let udf_args: Box<RawValue> = RawValue::from_string(udf_args.get().to_owned())?;
+        let body = ScheduleJobBody {
+            udf_path: Some(scheduled_path.udf_path.to_string()),
+            reference: None,
+            function_handle: None,
+            udf_args,
+            scheduled_ts: scheduled_ts.as_secs_f64(),
+        };
+        let response = self
+            .request("/api/actions/schedule_job")
+            .json(&body)
+            .send()
+            .await?
+            .error_for_status()?;
+        let parsed: ScheduleJobResponse = response.json().await?;
+        parsed.job_id.parse().context("invalid scheduled job id")
+    }
+
+    async fn cancel_job(
+        &self,
+        _identity: Identity,
+        virtual_id: DeveloperDocumentId,
+    ) -> anyhow::Result<()> {
+        self.request("/api/actions/cancel_job")
+            .json(&CancelJobBody {
+                id: virtual_id.to_string(),
+            })
+            .send()
+            .await?
+            .error_for_status()?;
+        Ok(())
+    }
+
+    async fn create_function_handle(
+        &self,
+        _identity: Identity,
+        path: CanonicalizedComponentFunctionPath,
+    ) -> anyhow::Result<FunctionHandle> {
+        let body = CreateFunctionHandleBody {
+            udf_path: Some(path.udf_path.to_string()),
+            reference: None,
+        };
+        let response = self
+            .request("/api/actions/create_function_handle")
+            .json(&body)
+            .send()
+            .await?
+            .error_for_status()?;
+        let parsed: CreateFunctionHandleResponse = response.json().await?;
+        parsed.handle.parse().context("invalid function handle")
+    }
+
+    async fn storage_get_url(
+        &self,
+        _identity: Identity,
+        _component: ComponentId,
+        storage_id: FileStorageId,
+    ) -> anyhow::Result<Option<String>> {
+        let response = self
+            .request("/api/actions/storage_get_url")
+            .json(&StorageIdBody {
+                storage_id: storage_id.to_string(),
+            })
+            .send()
+            .await?
+            .error_for_status()?;
+        let parsed: StorageGetUrlResponse = response.json().await?;
+        Ok(parsed.url)
+    }
+
+    async fn storage_delete(
+        &self,
+        _identity: Identity,
+        _component: ComponentId,
+        storage_id: FileStorageId,
+    ) -> anyhow::Result<()> {
+        self.request("/api/actions/storage_delete")
+            .json(&StorageIdBody {
+                storage_id: storage_id.to_string(),
+            })
+            .send()
+            .await?
+            .error_for_status()?;
+        Ok(())
+    }
+
+    async fn storage_get_file_entry(
+        &self,
+        _identity: Identity,
+        _component: ComponentId,
+        storage_id: FileStorageId,
+    ) -> anyhow::Result<Option<(ComponentPath, FileStorageEntry)>> {
+        let response = self
+            .request("/api/actions/storage_get_file_entry")
+            .json(&StorageIdBody {
+                storage_id: storage_id.to_string(),
+            })
+            .send()
+            .await?
+            .error_for_status()?;
+        let parsed: Option<StorageGetFileEntryResponse> = response.json().await?;
+        match parsed {
+            None => Ok(None),
+            Some(StorageGetFileEntryResponse {
+                component_path,
+                entry_proto,
+            }) => {
+                let component_path: ComponentPath = component_path.parse()?;
+                let entry_proto = pb::storage::FileStorageEntry::decode(&entry_proto[..])?;
+                let entry = FileStorageEntry::try_from(entry_proto)?;
+                Ok(Some((component_path, entry)))
+            },
+        }
+    }
+
+    async fn storage_store_file_entry(
+        &self,
+        _identity: Identity,
+        _component: ComponentId,
+        entry: FileStorageEntry,
+    ) -> anyhow::Result<(ComponentPath, DeveloperDocumentId)> {
+        let entry_proto: pb::storage::FileStorageEntry = entry.into();
+        let response = self
+            .request("/api/actions/storage_store_file_entry")
+            .json(&StorageStoreFileEntryBody {
+                entry_proto: entry_proto.encode_to_vec(),
+            })
+            .send()
+            .await?
+            .error_for_status()?;
+        let parsed: StorageStoreFileEntryResponse = response.json().await?;
+        let component_path: ComponentPath = parsed.component_path.parse()?;
+        let document_id: DeveloperDocumentId = parsed.document_id.parse()?;
+        Ok((component_path, document_id))
+    }
+
+    async fn vector_search(
+        &self,
+        _identity: Identity,
+        query: JsonValue,
+    ) -> anyhow::Result<(Vec<PublicVectorSearchQueryResult>, FunctionUsageStats)> {
+        let mut req = self
+            .request("/api/actions/vector_search")
+            .json(&VectorSearchBody { query });
+        if let Some(action_name) = &self.action_name {
+            req = req.header(CONVEX_ACTION_FUNCTION_NAME_HEADER, action_name);
+        }
+        let response = req.send().await?.error_for_status()?;
+        let parsed: VectorSearchResponse = response.json().await?;
+        let results = parsed
+            .results
+            .into_iter()
+            .map(|VectorSearchResultJson { id, score }| {
+                anyhow::Ok(PublicVectorSearchQueryResult {
+                    id: id.parse()?,
+                    score,
+                })
+            })
+            .collect::<anyhow::Result<Vec<_>>>()?;
+        Ok((results, FunctionUsageStats::default()))
+    }
+
+    async fn lookup_function_handle(
+        &self,
+        _identity: Identity,
+        handle: FunctionHandle,
+    ) -> anyhow::Result<CanonicalizedComponentFunctionPath> {
+        let response = self
+            .request("/api/actions/lookup_function_handle")
+            .json(&LookupFunctionHandleBody {
+                handle: String::from(handle),
+            })
+            .send()
+            .await?
+            .error_for_status()?;
+        let parsed: SerializedComponentFunctionPath = response.json().await?;
+        CanonicalizedComponentFunctionPath::try_from(parsed)
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use serde_json::json;
+
+    use super::{
+        build_js_error,
+        RunFunctionResponse,
+    };
+
+    #[test]
+    fn run_function_response_decodes_success_and_error() {
+        let success: RunFunctionResponse =
+            serde_json::from_value(json!({"status": "success", "value": 42})).unwrap();
+        assert!(matches!(
+            success,
+            RunFunctionResponse::Success { value } if value == json!(42)
+        ));
+        let error: RunFunctionResponse = serde_json::from_value(json!({
+            "status": "error",
+            "errorMessage": "nope",
+            "errorData": {"code": "E_NOPE"}
+        }))
+        .unwrap();
+        assert!(matches!(
+            error,
+            RunFunctionResponse::Error {
+                error_message,
+                error_data: Some(data),
+            } if error_message == "nope" && data == json!({"code": "E_NOPE"})
+        ));
+    }
+
+    #[test]
+    fn build_js_error_preserves_valid_custom_data_and_drops_invalid_data() {
+        let custom = build_js_error("custom".to_string(), Some(json!({"code": "E_CUSTOM"})));
+        assert_eq!(custom.message, "custom");
+        assert!(custom.custom_data.is_some());
+        let plain = build_js_error("plain".to_string(), Some(json!({"$invalid": 1})));
+        assert_eq!(plain.message, "plain");
+        assert!(plain.custom_data.is_none());
+    }
+}
