+    }
+
+    pub async fn get_or_create(
+        &self,
+        instance_name: &str,
+    ) -> anyhow::Result<Arc<InstanceState<RT>>> {
+        let config = lookup_instance_config(&self.instances, instance_name)?;
+        let (rt, db, require_ssl) = (self.rt.clone(), self.db, self.require_ssl);
+        let shared_isolate = self.shared_isolate.clone();
+        let state = get_or_init_entry(&self.states, instance_name, || async move {
+            InstanceState::load(rt, &config, db, require_ssl, shared_isolate)
+                .await
+                .map(Arc::new)
+        })
+        .await?;
+        Ok(state)
+    }
+
+    pub async fn prewarm_all(&self) -> anyhow::Result<()> {
+        for instance_name in self.instances.keys() {
+            self.get_or_create(instance_name).await?;
+        }
+        Ok(())
+    }
+
+    pub async fn health_report(&self, max_lag: Duration) -> HealthReport {
+        let states = {
+            let guard = self.states.lock().expect("InstanceRegistry lock poisoned");
+            self.instances
+                .keys()
+                .map(|name| {
+                    (
+                        name.clone(),
+                        guard.get(name).and_then(|entry| entry.cell.get()).cloned(),
+                    )
+                })
+                .collect::<Vec<_>>()
+        };
+        let mut healthy = true;
+        let mut instances = Vec::with_capacity(states.len());
+        for (name, state) in states {
+            let Some(state) = state else {
+                instances.push(InstanceHealth {
+                    name,
+                    healthy: true,
+                    warm_timestamp: None,
+                    persistence_timestamp: None,
+                    lag_seconds: None,
+                    error: None,
+                });
+                continue;
+            };
+            let warm = state.database.now_ts_for_reads();
+            match new_static_repeatable_recent(state.reader.as_ref()).await {
+                Ok(latest) => {
+                    let lag = latest.secs_since_f64(*warm).max(0.0);
+                    let instance_healthy = lag <= max_lag.as_secs_f64();
+                    healthy &= instance_healthy;
+                    instances.push(InstanceHealth {
+                        name,
+                        healthy: instance_healthy,
+                        warm_timestamp: Some(warm.to_string()),
+                        persistence_timestamp: Some(latest.to_string()),
+                        lag_seconds: Some(lag),
+                        error: None,
+                    });
+                },
+                Err(e) => {
+                    healthy = false;
+                    instances.push(InstanceHealth {
+                        name,
+                        healthy: false,
+                        warm_timestamp: Some(warm.to_string()),
+                        persistence_timestamp: None,
+                        lag_seconds: None,
+                        error: Some(format!("{e:#}")),
+                    });
+                },
+            }
+        }
+        HealthReport { healthy, instances }
+    }
+
+    fn spawn_eviction_worker(
+        rt: RT,
+        states: Arc<Mutex<HashMap<String, RegistryEntry<RT>>>>,
+        idle_ttl: Duration,
+    ) {
+        let worker_rt = rt.clone();
+        rt.spawn_background("funrun_instance_eviction", async move {
+            loop {
+                worker_rt.wait(Duration::from_secs(60)).await;
+                evict_states(&states, idle_ttl).await;
+            }
+        });
+    }
+
+    fn spawn_isolate_pool_sampler(rt: RT, shared_isolate: SharedIsolateResources<RT>) {
+        let worker_rt = rt.clone();
+        rt.spawn_background("funrun_isolate_pool_sampler", async move {
+            loop {
+                log_gauge(
+                    &ISOLATE_TOTAL_THREADS,
+                    shared_isolate.max_isolate_workers() as f64,
+                );
+                log_gauge(
+                    &ISOLATE_BUSY_THREADS,
+                    shared_isolate.active_isolate_workers() as f64,
+                );
+                worker_rt.wait(Duration::from_secs(2)).await;
+            }
+        });
+    }
+}
