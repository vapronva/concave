+async fn get_or_init_entry<RT, Fut>(
+    states: &Mutex<HashMap<String, RegistryEntry<RT>>>,
+    key: &str,
+    build: impl FnOnce() -> Fut,
+) -> anyhow::Result<Arc<InstanceState<RT>>>
+where
+    RT: Runtime,
+    Fut: std::future::Future<Output = anyhow::Result<Arc<InstanceState<RT>>>>,
+{
+    let (cell, existing) = {
+        let mut guard = states.lock().expect("InstanceRegistry lock poisoned");
+        let entry = guard
+            .entry(key.to_owned())
+            .or_insert_with(|| RegistryEntry {
+                cell: Arc::new(OnceCell::new()),
+                last_used: Instant::now(),
+            });
+        entry.last_used = Instant::now();
+        (entry.cell.clone(), entry.cell.get().cloned())
+    };
+    if let Some(value) = existing {
+        return Ok(value);
+    }
+    let value = cell.get_or_try_init(build).await?;
+    Ok(value.clone())
+}
+
+async fn evict_states<RT: Runtime>(
+    states: &Mutex<HashMap<String, RegistryEntry<RT>>>,
+    idle_ttl: Duration,
+) {
+    let now = Instant::now();
+    let mut evicted = Vec::new();
+    {
+        let mut guard = states.lock().expect("InstanceRegistry lock poisoned");
+        let stale: Vec<(String, Arc<InstanceState<RT>>)> = guard
+            .iter()
+            .filter_map(|(name, entry)| {
+                let state = entry.cell.get()?;
+                (Arc::strong_count(state) == 1 && now.duration_since(entry.last_used) >= idle_ttl)
+                    .then(|| (name.clone(), state.clone()))
+            })
+            .collect();
+        for (name, state) in stale {
+            guard.remove(&name);
+            evicted.push((name, state));
+        }
+    }
+    for (name, state) in evicted {
+        tracing::info!("[convex-funrun] evicting idle warm instance {name}");
+        if let Err(e) = state.database.shutdown().await {
+            tracing::warn!("[convex-funrun] failed to shut down evicted instance {name}: {e:#}");
+        }
+    }
+}
