+
+pub struct InstanceRegistry<RT: Runtime> {
+    rt: RT,
+    db: clusters::DbDriverTag,
+    require_ssl: bool,
+    instances: HashMap<String, Arc<FunrunInstanceConfig>>,
+    shared_isolate: SharedIsolateResources<RT>,
+    states: Arc<Mutex<HashMap<String, RegistryEntry<RT>>>>,
+}
+
+struct RegistryEntry<RT: Runtime> {
+    cell: Arc<OnceCell<Arc<InstanceState<RT>>>>,
+    last_used: Instant,
+}
+
+impl<RT: Runtime> InstanceRegistry<RT> {
+    pub fn new(rt: RT, config: &FunrunConfig) -> anyhow::Result<Self> {
+        let instances: HashMap<String, Arc<FunrunInstanceConfig>> = config
+            .instances
+            .iter()
+            .map(|i| (i.instance_name.clone(), Arc::new(i.clone())))
+            .collect();
+        let cap = max_percent_per_client(instances.len());
+        let shared_isolate = SharedIsolateResources::new(rt.clone(), cap)?;
+        tracing::info!(
+            "[convex-funrun] shared isolate pool: {} workers, per-tenant cap {}% ({} tenant(s))",
+            shared_isolate.max_isolate_workers(),
+            cap,
+            instances.len(),
+        );
+        let idle_ttl = Duration::from_secs(15 * 60);
+        let states = Arc::new(Mutex::new(HashMap::new()));
+        Self::spawn_eviction_worker(rt.clone(), states.clone(), idle_ttl);
+        Self::spawn_isolate_pool_sampler(rt.clone(), shared_isolate.clone());
+        Ok(Self {
+            rt,
+            db: config.db,
+            require_ssl: config.require_ssl,
+            instances,
+            shared_isolate,
+            states,
+        })
+    }
+
+    pub fn isolate_workers(&self) -> (usize, usize) {
+        (
+            self.shared_isolate.active_isolate_workers(),
+            self.shared_isolate.max_isolate_workers(),
+        )
+    }
+
+    pub fn instance_config(
+        &self,
+        instance_name: &str,
+    ) -> anyhow::Result<Arc<FunrunInstanceConfig>> {
