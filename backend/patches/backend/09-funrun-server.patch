+    #[test]
+    fn explicit_override_is_honored_and_clamped() {
+        assert_eq!(max_percent_per_client(4, 50), 50);
+        assert_eq!(max_percent_per_client(1, 25), 25);
+        assert_eq!(max_percent_per_client(4, 150), 100);
+        assert_eq!(max_percent_per_client(4, 1), 1);
