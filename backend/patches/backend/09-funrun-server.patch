index 000000000..c73fc346c
--- /dev/null
+++ b/crates/funrun_server/src/main.rs
@@ -0,0 +1,271 @@
+use std::sync::{
+    atomic::{
+        AtomicBool,
+        Ordering,
+    },
+    Arc,
+};
+
+use anyhow::Context;
+use axum::{
+    extract::State,
+    http::StatusCode,
+    response::IntoResponse,
+    routing::get,
+    Json,
+    Router,
+};
+use runtime::prod::ProdRuntime;
+use tokio::sync::watch;
+
+mod callbacks;
+mod config;
+mod service;
+mod snapshot;
+
+use config::FunrunConfig;
+use function_runner::remote::MAX_GRPC_MESSAGE_BYTES;
+use service::FunrunService;
+use snapshot::InstanceRegistry;
+
+fn main() -> anyhow::Result<()> {
+    tracing_subscriber::fmt()
+        .with_env_filter(
+            tracing_subscriber::EnvFilter::try_from_default_env()
+                .unwrap_or_else(|_| tracing_subscriber::EnvFilter::new("info")),
+        )
+        .init();
+    let config = FunrunConfig::from_env()?;
+    let tokio = ProdRuntime::init_tokio()?;
+    let runtime = ProdRuntime::new(&tokio);
+    let runtime_ = runtime.clone();
+    runtime.block_on(
+        "convex-funrun",
+        async move { serve(runtime_, config).await },
+    )
+}
+
+async fn serve(runtime: ProdRuntime, config: FunrunConfig) -> anyhow::Result<()> {
+    let instance_names = config
+        .instances
+        .iter()
+        .map(|i| i.instance_name.as_str())
+        .collect::<Vec<_>>()
+        .join(", ");
+    tracing::info!(
+        "[convex-funrun] starting for {} instance(s) [{}] on {}",
+        config.instances.len(),
+        instance_names,
+        config.listen,
+    );
+    let registry = Arc::new(InstanceRegistry::new(runtime.clone(), &config)?);
+    registry
+        .prewarm_all()
+        .await
+        .context("failed to prewarm configured funrun instances")?;
+    spawn_pod_deletion_cost_updater(registry.clone());
+    let service = FunrunService::new(runtime.clone(), registry.clone())?;
+    let server = pb::funrun::funrun_server::FunrunServer::new(service)
+        .max_decoding_message_size(MAX_GRPC_MESSAGE_BYTES)
+        .max_encoding_message_size(MAX_GRPC_MESSAGE_BYTES);
+    let mut builder = tonic::transport::Server::builder();
+    if let Some(tls) = &config.tls {
+        let identity = tonic::transport::Identity::from_pem(&tls.cert_pem, &tls.key_pem);
+        let tls_config = tonic::transport::ServerTlsConfig::new()
+            .identity(identity)
+            .client_ca_root(tonic::transport::Certificate::from_pem(&tls.ca_pem));
+        builder = builder
+            .tls_config(tls_config)
+            .context("invalid funrun TLS configuration")?;
+        tracing::info!("[convex-funrun] mutual TLS enabled (requiring client certs)");
+    } else {
+        tracing::warn!(
+            "[convex-funrun] TLS not configured (CONVEX_FUNRUN_TLS_* unset); serving PLAINTEXT \
+             gRPC -- use only for local/dev"
+        );
+    }
+    let shutting_down = Arc::new(AtomicBool::new(false));
+    let (shutdown_tx, shutdown_rx) = watch::channel(false);
+    {
+        let shutting_down = shutting_down.clone();
+        let drain_delay = config.drain_delay;
+        tokio::spawn(async move {
+            shutdown_signal().await;
+            shutting_down.store(true, Ordering::Release);
+            tokio::time::sleep(drain_delay).await;
+            let _ = shutdown_tx.send(true);
+        });
+    }
+    tracing::info!(
+        "[convex-funrun] listening on {} (health {})",
+        config.listen,
+        config.health_listen
+    );
+    let grpc = builder
+        .add_service(server)
+        .serve_with_shutdown(config.listen, wait_for_shutdown(shutdown_rx.clone()));
+    let health = serve_health(
+        config.health_listen,
+        config.max_snapshot_lag,
+        registry,
+        shutdown_rx,
+        shutting_down,
+    );
+    tokio::try_join!(
+        async { grpc.await.context("convex-funrun gRPC server exited") },
+        health
+    )?;
+    Ok(())
+}
+
+#[derive(Clone)]
+struct HealthState {
+    registry: Arc<InstanceRegistry<ProdRuntime>>,
+    max_snapshot_lag: std::time::Duration,
+    shutting_down: Arc<AtomicBool>,
+}
+
+async fn liveness() -> &'static str {
+    "ok"
+}
+
+async fn readiness(State(state): State<HealthState>) -> impl IntoResponse {
+    let report = state.registry.health_report(state.max_snapshot_lag).await;
+    let draining = state.shutting_down.load(Ordering::Acquire);
+    let status = if draining || !report.healthy {
+        StatusCode::SERVICE_UNAVAILABLE
+    } else {
+        StatusCode::OK
+    };
+    (status, Json(report))
+}
+
+async fn serve_health(
+    listen: std::net::SocketAddr,
+    max_snapshot_lag: std::time::Duration,
+    registry: Arc<InstanceRegistry<ProdRuntime>>,
+    shutdown_rx: watch::Receiver<bool>,
+    shutting_down: Arc<AtomicBool>,
+) -> anyhow::Result<()> {
+    let app = Router::new()
+        .route("/healthz", get(liveness))
+        .route("/readyz", get(readiness))
+        .route("/metrics", get(common::http::metrics))
+        .with_state(HealthState {
+            registry,
+            max_snapshot_lag,
+            shutting_down,
+        });
+    let listener = tokio::net::TcpListener::bind(listen).await?;
+    axum::serve(listener, app)
+        .with_graceful_shutdown(wait_for_shutdown(shutdown_rx))
+        .await
+        .context("convex-funrun health server exited")
+}
+
+fn spawn_pod_deletion_cost_updater(registry: Arc<InstanceRegistry<ProdRuntime>>) {
+    if std::env::var_os("CONVEX_FUNRUN_POD_DELETION_COST").is_none() {
+        return;
+    }
+    let (Ok(pod), Ok(namespace)) = (std::env::var("POD_NAME"), std::env::var("POD_NAMESPACE"))
+    else {
+        tracing::warn!(
+            "[convex-funrun] pod-deletion-cost on but POD_NAME/POD_NAMESPACE unset; disabled"
+        );
+        return;
+    };
+    let client = match std::fs::read("/var/run/secrets/kubernetes.io/serviceaccount/ca.crt")
+        .map_err(|e| anyhow::anyhow!("{e}"))
+        .and_then(|ca| Ok(reqwest::Certificate::from_pem(&ca)?))
+        .and_then(|cert| {
+            Ok(reqwest::Client::builder()
+                .add_root_certificate(cert)
+                .build()?)
+        }) {
+        Ok(client) => client,
+        Err(e) => {
+            tracing::warn!(
+                "[convex-funrun] pod-deletion-cost: no in-cluster API client ({e}); disabled"
+            );
+            return;
+        },
+    };
+    let url = format!("https://kubernetes.default.svc/api/v1/namespaces/{namespace}/pods/{pod}");
+    tracing::info!("[convex-funrun] pod-deletion-cost updater active for {namespace}/{pod}");
+    tokio::spawn(async move {
+        let mut last: Option<i64> = None;
+        loop {
+            tokio::time::sleep(std::time::Duration::from_secs(30)).await;
+            let (busy, total) = registry.isolate_workers();
+            let cost = if total == 0 {
+                0
+            } else {
+                (100i64 * busy as i64) / total as i64
+            };
+            if last == Some(cost) {
+                continue;
+            }
+            let token = match std::fs::read_to_string(
+                "/var/run/secrets/kubernetes.io/serviceaccount/token",
+            ) {
+                Ok(token) => token,
+                Err(e) => {
+                    tracing::debug!("[convex-funrun] pod-deletion-cost: token read failed: {e}");
+                    continue;
+                },
+            };
+            let body = format!(
+                "{{\"metadata\":{{\"annotations\":{{\"controller.kubernetes.io/pod-deletion-cost\"\
+                 :\"{cost}\"}}}}}}"
+            );
+            match client
+                .patch(&url)
+                .bearer_auth(token.trim())
+                .header(
+                    reqwest::header::CONTENT_TYPE,
+                    "application/strategic-merge-patch+json",
+                )
+                .body(body)
+                .send()
+                .await
+            {
+                Ok(resp) if resp.status().is_success() => {
+                    last = Some(cost);
+                    tracing::debug!(
+                        "[convex-funrun] pod-deletion-cost={cost} (isolates {busy}/{total})"
+                    );
+                },
+                Ok(resp) => {
+                    tracing::debug!(
+                        "[convex-funrun] pod-deletion-cost patch: HTTP {}",
+                        resp.status()
+                    )
+                },
+                Err(e) => tracing::debug!("[convex-funrun] pod-deletion-cost patch failed: {e}"),
+            }
+        }
+    });
+}
+
+async fn wait_for_shutdown(mut shutdown_rx: watch::Receiver<bool>) {
+    if !*shutdown_rx.borrow() {
+        let _ = shutdown_rx.changed().await;
+    }
+}
+
+async fn shutdown_signal() {
+    #[cfg(unix)]
+    {
+        let mut term = tokio::signal::unix::signal(tokio::signal::unix::SignalKind::terminate())
+            .expect("install SIGTERM handler");
+        tokio::select! {
+            _ = term.recv() => {},
+            _ = tokio::signal::ctrl_c() => {},
+        }
+    }
+    #[cfg(not(unix))]
+    {
+        let _ = tokio::signal::ctrl_c().await;
+    }
+    tracing::info!("[convex-funrun] shutdown signal; readiness now 503, draining before gRPC stop");
+}
