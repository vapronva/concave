index 000000000..e637eb824
--- /dev/null
+++ b/crates/funrun_server/src/main.rs
@@ -0,0 +1,75 @@
+use std::sync::Arc;
+
+use anyhow::Context;
+use runtime::prod::ProdRuntime;
+
+mod callbacks;
+mod config;
+mod service;
+mod snapshot;
+
+use config::FunrunConfig;
+use service::FunrunService;
+use snapshot::InstanceRegistry;
+
+const MAX_GRPC_MESSAGE_BYTES: usize = udf::HTTP_ACTION_BODY_LIMIT + (1 << 20);
+
+fn main() -> anyhow::Result<()> {
+    tracing_subscriber::fmt()
+        .with_env_filter(
+            tracing_subscriber::EnvFilter::try_from_default_env()
+                .unwrap_or_else(|_| tracing_subscriber::EnvFilter::new("info")),
+        )
+        .init();
+    let config = FunrunConfig::from_env()?;
+    let tokio = ProdRuntime::init_tokio()?;
+    let runtime = ProdRuntime::new(&tokio);
+    let runtime_ = runtime.clone();
+    runtime.block_on(
+        "convex-funrun",
+        async move { serve(runtime_, config).await },
+    )
+}
+
+async fn serve(runtime: ProdRuntime, config: FunrunConfig) -> anyhow::Result<()> {
+    let instance_names = config
+        .instances
+        .iter()
+        .map(|i| i.instance_name.as_str())
+        .collect::<Vec<_>>()
+        .join(", ");
+    tracing::info!(
+        "[convex-funrun] starting for {} instance(s) [{}] on {}",
+        config.instances.len(),
+        instance_names,
+        config.listen,
+    );
+    let registry = Arc::new(InstanceRegistry::new(runtime.clone(), &config)?);
+    let service = FunrunService::new(runtime.clone(), registry)?;
+    let server = pb::funrun::funrun_server::FunrunServer::new(service)
+        .max_decoding_message_size(MAX_GRPC_MESSAGE_BYTES)
+        .max_encoding_message_size(MAX_GRPC_MESSAGE_BYTES);
+    let mut builder = tonic::transport::Server::builder();
+    if let Some(tls) = &config.tls {
+        let identity = tonic::transport::Identity::from_pem(&tls.cert_pem, &tls.key_pem);
+        let tls_config = tonic::transport::ServerTlsConfig::new()
+            .identity(identity)
+            .client_ca_root(tonic::transport::Certificate::from_pem(&tls.ca_pem));
+        builder = builder
+            .tls_config(tls_config)
+            .context("invalid funrun TLS configuration")?;
+        tracing::info!("[convex-funrun] mutual TLS enabled (requiring client certs)");
+    } else {
+        tracing::warn!(
+            "[convex-funrun] TLS not configured (CONVEX_FUNRUN_TLS_* unset); serving PLAINTEXT \
+             gRPC -- use only for local/dev"
+        );
+    }
+    tracing::info!("[convex-funrun] listening on {}", config.listen);
+    builder
+        .add_service(server)
+        .serve(config.listen)
+        .await
+        .context("convex-funrun gRPC server exited")?;
+    Ok(())
+}
