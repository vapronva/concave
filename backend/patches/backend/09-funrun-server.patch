+pub struct InstanceRegistry<RT: Runtime> {
+    rt: RT,
+    db: clusters::DbDriverTag,
+    require_ssl: bool,
+    instances: HashMap<String, Arc<FunrunInstanceConfig>>,
+    shared_isolate: SharedIsolateResources<RT>,
+    states: Mutex<HashMap<String, Arc<OnceCell<Arc<InstanceState<RT>>>>>>,
+}
+
+impl<RT: Runtime> InstanceRegistry<RT> {
+    pub fn new(rt: RT, config: &FunrunConfig) -> anyhow::Result<Self> {
+        let instances: HashMap<String, Arc<FunrunInstanceConfig>> = config
+            .instances
+            .iter()
+            .map(|i| (i.instance_name.clone(), Arc::new(i.clone())))
+            .collect();
+        let cap = max_percent_per_client(
+            instances.len(),
+            *common::knobs::FUNRUN_MAX_PERCENT_PER_CLIENT,
+        );
+        let shared_isolate = SharedIsolateResources::new(rt.clone(), cap)?;
+        tracing::info!(
+            "[convex-funrun] shared isolate pool: {} workers, per-tenant cap {}% ({} tenant(s))",
+            shared_isolate.max_isolate_workers(),
+            cap,
+            instances.len(),
+        );
+        Ok(Self {
+            rt,
+            db: config.db,
+            require_ssl: config.require_ssl,
+            instances,
+            shared_isolate,
+            states: Mutex::new(HashMap::new()),
+        })
+    }
+
+    pub fn instance_config(
+        &self,
+        instance_name: &str,
+    ) -> anyhow::Result<Arc<FunrunInstanceConfig>> {
+        lookup_instance_config(&self.instances, instance_name)
+    }
+
+    pub async fn get_or_create(
+        &self,
+        instance_name: &str,
+    ) -> anyhow::Result<Arc<InstanceState<RT>>> {
+        let config = lookup_instance_config(&self.instances, instance_name)?;
+        let (rt, db, require_ssl) = (self.rt.clone(), self.db, self.require_ssl);
+        let shared_isolate = self.shared_isolate.clone();
+        get_or_init_cell(&self.states, instance_name, || async move {
+            InstanceState::load(rt, &config, db, require_ssl, shared_isolate)
+                .await
+                .map(Arc::new)
+        })
+        .await
+    }
+
+    #[cfg(test)]
+    pub fn shared_pool_id(&self) -> usize {
+        self.shared_isolate.shared_pool_id()
+    }
+}
+
+fn lookup_instance_config(
+    instances: &HashMap<String, Arc<FunrunInstanceConfig>>,
+    instance_name: &str,
+) -> anyhow::Result<Arc<FunrunInstanceConfig>> {
+    instances.get(instance_name).cloned().with_context(|| {
+        format!(
+            "funrun pod is not configured for instance {instance_name:?} (set it in \
+             FUNRUN_INSTANCES)"
+        )
+    })
+}
+
+async fn get_or_init_cell<T, Fut>(
+    cells: &Mutex<HashMap<String, Arc<OnceCell<Arc<T>>>>>,
+    key: &str,
+    build: impl FnOnce() -> Fut,
+) -> anyhow::Result<Arc<T>>
+where
+    Fut: std::future::Future<Output = anyhow::Result<Arc<T>>>,
+{
+    let cell = {
+        let mut guard = cells.lock().expect("InstanceRegistry lock poisoned");
+        guard
+            .entry(key.to_owned())
+            .or_insert_with(|| Arc::new(OnceCell::new()))
+            .clone()
+    };
+    let value = cell.get_or_try_init(build).await?;
+    Ok(value.clone())
+}
