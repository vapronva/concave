+    #[test]
+    fn auto_cap_splits_fleet_evenly_with_floor() {
+        assert_eq!(max_percent_per_client(2, 0), 50);
+        assert_eq!(max_percent_per_client(4, 0), 25);
+        assert_eq!(max_percent_per_client(10, 0), 10);
+        assert_eq!(max_percent_per_client(20, 0), 10);
+        assert_eq!(max_percent_per_client(100, 0), 10);
+        assert_eq!(max_percent_per_client(0, 0), 100);
+    }
