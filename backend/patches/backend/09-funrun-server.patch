@@ -0,0 +1,653 @@
+use std::{
+    collections::BTreeMap,
+    pin::Pin,
+    str::FromStr,
+    sync::Arc,
+    task::{
+        Context,
+        Poll,
+    },
+};
+
+use anyhow::Context as _;
+use common::{
+    execution_context::ExecutionContext,
+    http::RoutedHttpPath,
+    log_lines::LogLine,
+    runtime::{
+        Runtime,
+        SpawnHandle,
+    },
+    types::{
+        ConvexOrigin,
+        DeploymentClass,
+        DeploymentMetadata,
+        IndexId,
+        RepeatableTimestamp,
+        UdfType,
+    },
+};
+use errors::ErrorMetadata;
+use function_runner::{
+    server::{
+        validate_run_function_result,
+        DeploymentStorage,
+        FunctionMetadata,
+        FunctionRunnerCore,
+        HttpActionMetadata,
+        RunRequestArgs,
+    },
+    FunctionWrites,
+};
+use futures::{
+    select_biased,
+    FutureExt,
+    Stream,
+    StreamExt,
+};
+use keybroker::{
+    verify_funrun_auth_header,
+    Identity,
+    FUNRUN_AUTH_METADATA_KEY,
+};
+use model::environment_variables::types::{
+    EnvVarName,
+    EnvVarValue,
+};
+use pb::error_metadata::ErrorMetadataStatusExt;
+use sync_types::Timestamp;
+use tokio::sync::mpsc;
+use tokio_stream::wrappers::{
+    ReceiverStream,
+    UnboundedReceiverStream,
+};
+use tonic::{
+    Request,
+    Response,
+    Status,
+};
+use udf::{
+    validation::{
+        ValidatedHttpPath,
+        ValidatedPathAndArgs,
+    },
+    HttpActionRequest,
+    HttpActionRequestHead,
+    HttpActionResponsePart,
+    HttpActionResponseStreamer,
+};
+
+use crate::{
+    callbacks::HttpActionCallbacks,
+    snapshot::{
+        InstanceRegistry,
+        InstanceState,
+    },
+};
+
+const RESPONSE_STREAM_BUFFER: usize = 256;
+
+struct CommonRunInputs {
+    identity: Identity,
+    ts: RepeatableTimestamp,
+    existing_writes: FunctionWrites,
+    default_system_env_vars: BTreeMap<EnvVarName, EnvVarValue>,
+    in_memory_index_last_modified: BTreeMap<IndexId, Timestamp>,
+    context: ExecutionContext,
+    backend_url: ConvexOrigin,
+    action_callbacks: Arc<HttpActionCallbacks>,
+    deployment: DeploymentMetadata,
+    snapshot: crate::snapshot::SnapshotInputs,
+}
+
+pub struct FunrunService<RT: Runtime> {
+    rt: RT,
+    registry: Arc<InstanceRegistry<RT>>,
+    fetch_client: Arc<dyn common::http::fetch::FetchClient>,
+    callback_client: reqwest::Client,
+}
+
+impl<RT: Runtime> FunrunService<RT> {
+    pub fn new(rt: RT, registry: Arc<InstanceRegistry<RT>>) -> anyhow::Result<Self> {
+        let fetch_client = Arc::new(common::http::fetch::ProxiedFetchClient::new(
+            None,
+            "convex-funrun".to_string(),
+            reqwest::redirect::Policy::none(),
+        ));
+        let callback_client = reqwest::Client::builder()
+            .redirect(reqwest::redirect::Policy::none())
+            .build()
+            .context("failed to build funrun action callback HTTP client")?;
+        Ok(Self {
+            rt,
+            registry,
+            fetch_client,
+            callback_client,
+        })
+    }
+
+    async fn resolve_and_authenticate(
+        &self,
+        instance_name: &str,
+        metadata: &tonic::metadata::MetadataMap,
+    ) -> Result<Arc<InstanceState<RT>>, Status> {
+        let Ok(config) = self.registry.instance_config(instance_name) else {
+            return Err(Status::unauthenticated(
+                "funrun: missing or invalid deployment authorization",
+            ));
+        };
+        let presented = metadata
+            .get(FUNRUN_AUTH_METADATA_KEY)
+            .and_then(|v| v.to_str().ok())
+            .unwrap_or_default();
+        let unix_seconds = self.rt.unix_timestamp().as_secs();
+        if !verify_funrun_auth_header(
+            presented,
+            &config.instance_secret,
+            &config.instance_name,
+            unix_seconds,
+        ) {
+            return Err(Status::unauthenticated(
+                "funrun: missing or invalid deployment authorization",
+            ));
+        }
+        self.registry
+            .get_or_create(instance_name)
+            .await
+            .map_err(|e| Status::not_found(format!("funrun: {e:#}")))
+    }
+
+    #[allow(clippy::too_many_arguments)]
+    async fn decode_common_run_inputs(
+        instance: &Arc<InstanceState<RT>>,
+        callback_client: reqwest::Client,
+        identity: Option<pb::convex_identity::UncheckedIdentity>,
+        ts: Option<pb::common::RepeatableTimestamp>,
+        existing_writes: Vec<pb::common::DocumentUpdateWithPrevTs>,
+        default_system_env_vars: Vec<pb::funrun::EnvVar>,
+        in_memory_index_last_modified: Vec<pb::funrun::IndexLastModified>,
+        context: Option<pb::common::ExecutionContext>,
+        backend_callback_url: Option<String>,
+        callback_token: Option<String>,
+        auth_header: Option<String>,
+        action_name: Option<String>,
+    ) -> anyhow::Result<CommonRunInputs> {
+        let identity = Identity::from_proto_unchecked(identity.context("missing identity")?)?;
+        let ts: RepeatableTimestamp = ts.context("missing ts")?.try_into()?;
+        let context: ExecutionContext = context.context("missing context")?.try_into()?;
+        let existing_writes = FunctionWrites {
+            updates: existing_writes
+                .into_iter()
+                .map(common::document::DocumentUpdateWithPrevTs::try_from)
+                .collect::<anyhow::Result<Vec<_>>>()?,
+        };
+        let default_system_env_vars: BTreeMap<EnvVarName, EnvVarValue> = default_system_env_vars
+            .into_iter()
+            .map(|pb::funrun::EnvVar { name, value }| {
+                anyhow::Ok((EnvVarName::from_str(&name)?, EnvVarValue::from_str(&value)?))
+            })
+            .collect::<anyhow::Result<_>>()?;
+        let in_memory_index_last_modified: BTreeMap<IndexId, Timestamp> =
+            in_memory_index_last_modified
+                .into_iter()
+                .map(
+                    |pb::funrun::IndexLastModified {
+                         index_id,
+                         last_modified_ts,
+                     }| {
+                        anyhow::Ok((
+                            IndexId::from_str(&index_id)?,
+                            Timestamp::try_from(last_modified_ts)?,
+                        ))
+                    },
+                )
+                .collect::<anyhow::Result<_>>()?;
+        let snapshot = instance.snapshot_inputs(ts).await?;
+        let backend_url =
+            ConvexOrigin::from(backend_callback_url.context("missing backend_callback_url")?);
+        let action_callbacks = Arc::new(HttpActionCallbacks::new(
+            callback_client,
+            backend_url.clone(),
+            callback_token.context("missing callback_token")?,
+            auth_header,
+            context.clone(),
+            action_name,
+        ));
+        let deployment = DeploymentMetadata {
+            name: instance.instance_name.clone(),
+            region: None,
+            class: DeploymentClass::S16,
+        };
+        Ok(CommonRunInputs {
+            identity,
+            ts,
+            existing_writes,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            backend_url,
+            action_callbacks,
+            deployment,
+            snapshot,
+        })
+    }
+
+    async fn run(
+        instance: Arc<InstanceState<RT>>,
+        fetch_client: Arc<dyn common::http::fetch::FetchClient>,
+        callback_client: reqwest::Client,
+        req: pb::funrun::RunFunctionRequest,
+        part_tx: &mpsc::Sender<Result<pb::funrun::RunFunctionResponsePart, Status>>,
+    ) -> anyhow::Result<pb::funrun::RunFunctionResult> {
+        let pb::funrun::RunFunctionRequest {
+            instance_name: _,
+            udf_type,
+            identity,
+            ts,
+            existing_writes,
+            path_and_args,
+            journal,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            backend_callback_url,
+            callback_token,
+            auth_header,
+        } = req;
+        let udf_type =
+            UdfType::from(pb::common::UdfType::try_from(udf_type).context("invalid udf_type")?);
+        let function_metadata = match path_and_args {
+            Some(path_and_args) => Some(FunctionMetadata {
+                path_and_args: ValidatedPathAndArgs::from_proto(path_and_args)?,
+                journal: journal
+                    .context("missing journal for query/mutation")?
+                    .try_into()?,
+            }),
+            None => None,
+        };
+        let action_name = function_metadata
+            .as_ref()
+            .map(|m| m.path_and_args.path().udf_path.to_string());
+        let CommonRunInputs {
+            identity,
+            ts,
+            existing_writes,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            backend_url,
+            action_callbacks,
+            deployment,
+            snapshot,
+        } = Self::decode_common_run_inputs(
+            &instance,
+            callback_client,
+            identity,
+            ts,
+            existing_writes,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            backend_callback_url,
+            callback_token,
+            auth_header,
+            action_name,
+        )
+        .await?;
+        let (log_line_sender, log_line_receiver) = mpsc::unbounded_channel::<LogLine>();
+        let run_request_args = RunRequestArgs {
+            key_broker: instance.key_broker.clone(),
+            index_reader: snapshot.index_reader,
+            convex_origin: backend_url,
+            bootstrap_metadata: snapshot.bootstrap_metadata,
+            table_count_snapshot: snapshot.table_count_snapshot,
+            text_index_snapshot: snapshot.text_index_snapshot,
+            action_callbacks,
+            fetch_client,
+            log_line_sender: Some(log_line_sender),
+            function_started_sender: None,
+            udf_type,
+            identity,
+            existing_writes,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            subfunctions_in_same_isolate: *common::knobs::SUBFUNCTIONS_IN_SAME_ISOLATE,
+            deployment,
+        };
+        let result = Self::drive_and_stream_log_lines(
+            &instance.core,
+            run_request_args,
+            function_metadata,
+            log_line_receiver,
+            part_tx,
+        )
+        .await;
+        validate_run_function_result(udf_type, *ts, instance.retention_validator.clone()).await?;
+        let (final_transaction, outcome, usage_stats) = result?;
+        Ok(pb::funrun::RunFunctionResult {
+            outcome: Some(outcome.try_into()?),
+            final_transaction: final_transaction
+                .map(pb::funrun::FunctionFinalTransaction::try_from)
+                .transpose()?,
+            usage_stats: Some(usage_stats.into()),
+        })
+    }
+
+    async fn run_http(
+        instance: Arc<InstanceState<RT>>,
+        fetch_client: Arc<dyn common::http::fetch::FetchClient>,
+        callback_client: reqwest::Client,
+        req: pb::funrun::RunHttpActionRequest,
+        part_tx: &mpsc::Sender<Result<pb::funrun::HttpActionResponsePart, Status>>,
+    ) -> anyhow::Result<pb::funrun::RunFunctionResult> {
+        let pb::funrun::RunHttpActionRequest {
+            instance_name: _,
+            identity,
+            ts,
+            existing_writes,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            backend_callback_url,
+            callback_token,
+            auth_header,
+            http_module_path,
+            routed_path,
+            http_request_head,
+            http_request_body,
+        } = req;
+        let http_module_path =
+            ValidatedHttpPath::from_proto(http_module_path.context("missing http_module_path")?)?;
+        let routed_path = RoutedHttpPath(routed_path);
+        let head = HttpActionRequestHead::try_from(
+            http_request_head.context("missing http_request_head")?,
+        )?;
+        let body: Option<futures::stream::BoxStream<'static, anyhow::Result<bytes::Bytes>>> =
+            http_request_body.map(|bytes| {
+                futures::stream::once(async move { Ok(bytes::Bytes::from(bytes)) }).boxed()
+            });
+        let http_request = HttpActionRequest { head, body };
+        let action_name = Some(http_module_path.path().udf_path.to_string());
+        let CommonRunInputs {
+            identity,
+            ts,
+            existing_writes,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            backend_url,
+            action_callbacks,
+            deployment,
+            snapshot,
+        } = Self::decode_common_run_inputs(
+            &instance,
+            callback_client,
+            identity,
+            ts,
+            existing_writes,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            backend_callback_url,
+            callback_token,
+            auth_header,
+            action_name,
+        )
+        .await?;
+        let (log_line_sender, log_line_receiver) = mpsc::unbounded_channel::<LogLine>();
+        let run_request_args = RunRequestArgs {
+            key_broker: instance.key_broker.clone(),
+            index_reader: snapshot.index_reader,
+            convex_origin: backend_url,
+            bootstrap_metadata: snapshot.bootstrap_metadata,
+            table_count_snapshot: snapshot.table_count_snapshot,
+            text_index_snapshot: snapshot.text_index_snapshot,
+            action_callbacks,
+            fetch_client,
+            log_line_sender: Some(log_line_sender),
+            function_started_sender: None,
+            udf_type: UdfType::HttpAction,
+            identity,
+            existing_writes,
+            default_system_env_vars,
+            in_memory_index_last_modified,
+            context,
+            subfunctions_in_same_isolate: *common::knobs::SUBFUNCTIONS_IN_SAME_ISOLATE,
+            deployment,
+        };
+        let (inner_response_sender, inner_response_receiver) = mpsc::unbounded_channel();
+        let http_action_metadata = HttpActionMetadata {
+            http_response_streamer: HttpActionResponseStreamer::new(inner_response_sender),
+            http_module_path,
+            routed_path,
+            http_request,
+        };
+        let mut inner_response_stream =
+            UnboundedReceiverStream::new(inner_response_receiver).fuse();
+        let mut log_lines = UnboundedReceiverStream::new(log_line_receiver).fuse();
+        let mut run_fut = Box::pin(instance.core.run_function_no_retention_check(
+            run_request_args,
+            None,
+            Some(http_action_metadata),
+        ))
+        .fuse();
+        let result = loop {
+            select_biased! {
+                result = &mut run_fut => {
+                    while let Some(log_line) = log_lines.next().await {
+                        forward_http_log_line(part_tx, log_line).await;
+                    }
+                    while let Some(part) = inner_response_stream.next().await {
+                        if forward_http_part(part_tx, part).await.is_err() {
+                            anyhow::bail!(ErrorMetadata::client_disconnect());
+                        }
+                    }
+                    break result;
+                },
+                _ = part_tx.closed().fuse() => {
+                    drop(run_fut);
+                    anyhow::bail!(ErrorMetadata::client_disconnect());
+                },
+                part = inner_response_stream.select_next_some() => {
+                    if forward_http_part(part_tx, part).await.is_err() {
+                        anyhow::bail!(ErrorMetadata::client_disconnect());
+                    }
+                },
+                log_line = log_lines.select_next_some() => {
+                    forward_http_log_line(part_tx, log_line).await;
+                },
+            }
+        };
+        validate_run_function_result(
+            UdfType::HttpAction,
+            *ts,
+            instance.retention_validator.clone(),
+        )
+        .await?;
+        let (_final_transaction, outcome, usage_stats) = result?;
+        Ok(pb::funrun::RunFunctionResult {
+            outcome: Some(outcome.try_into()?),
+            final_transaction: None,
+            usage_stats: Some(usage_stats.into()),
+        })
+    }
+
+    async fn drive_and_stream_log_lines(
+        core: &FunctionRunnerCore<RT, DeploymentStorage>,
+        run_request_args: RunRequestArgs,
+        function_metadata: Option<FunctionMetadata>,
+        log_line_receiver: mpsc::UnboundedReceiver<LogLine>,
+        part_tx: &mpsc::Sender<Result<pb::funrun::RunFunctionResponsePart, Status>>,
+    ) -> anyhow::Result<(
+        Option<function_runner::FunctionFinalTransaction>,
+        udf::FunctionOutcome,
+        usage_tracking::FunctionUsageStats,
+    )> {
+        let mut run_fut = Box::pin(core.run_function_no_retention_check(
+            run_request_args,
+            function_metadata,
+            None,
+        ))
+        .fuse();
+        let mut log_lines =
+            tokio_stream::wrappers::UnboundedReceiverStream::new(log_line_receiver).fuse();
+        loop {
+            select_biased! {
+                result = &mut run_fut => {
+                    while let Some(log_line) = log_lines.next().await {
+                        forward_log_line(part_tx, log_line).await;
+                    }
+                    return result;
+                },
+                _ = part_tx.closed().fuse() => {
+                    drop(run_fut);
+                    anyhow::bail!(ErrorMetadata::client_disconnect());
+                },
+                maybe_line = log_lines.select_next_some() => {
+                    forward_log_line(part_tx, maybe_line).await;
+                },
+            }
+        }
+    }
+}
+
+async fn forward_log_line(
+    part_tx: &mpsc::Sender<Result<pb::funrun::RunFunctionResponsePart, Status>>,
+    log_line: LogLine,
+) {
+    let part = pb::funrun::RunFunctionResponsePart {
+        part: Some(pb::funrun::run_function_response_part::Part::LogLine(
+            log_line.into(),
+        )),
+    };
+    let _ = part_tx.send(Ok(part)).await;
+}
+
+async fn forward_http_log_line(
+    part_tx: &mpsc::Sender<Result<pb::funrun::HttpActionResponsePart, Status>>,
+    log_line: LogLine,
+) {
+    let part = pb::funrun::HttpActionResponsePart {
+        part: Some(pb::funrun::http_action_response_part::Part::LogLine(
+            log_line.into(),
+        )),
+    };
+    let _ = part_tx.send(Ok(part)).await;
+}
+
+async fn forward_http_part(
+    part_tx: &mpsc::Sender<Result<pb::funrun::HttpActionResponsePart, Status>>,
+    part: HttpActionResponsePart,
+) -> Result<(), ()> {
+    let message_type = match part {
+        HttpActionResponsePart::Head(head) => {
+            pb::common::http_action_response::MessageType::Head(head.into())
+        },
+        HttpActionResponsePart::BodyChunk(bytes) => {
+            pb::common::http_action_response::MessageType::Body(bytes.to_vec())
+        },
+    };
+    let wire = pb::funrun::HttpActionResponsePart {
+        part: Some(pb::funrun::http_action_response_part::Part::Response(
+            pb::common::HttpActionResponse {
+                message_type: Some(message_type),
+            },
+        )),
+    };
+    part_tx.send(Ok(wire)).await.map_err(|_| ())
+}
+
+pub struct RunFunctionStream {
+    inner: ReceiverStream<Result<pb::funrun::RunFunctionResponsePart, Status>>,
+    _handle: Box<dyn SpawnHandle>,
+}
+
+impl Stream for RunFunctionStream {
+    type Item = Result<pb::funrun::RunFunctionResponsePart, Status>;
+
+    fn poll_next(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Option<Self::Item>> {
+        Pin::new(&mut self.inner).poll_next(cx)
+    }
+}
+
+pub struct HttpActionResponseStream {
+    inner: ReceiverStream<Result<pb::funrun::HttpActionResponsePart, Status>>,
+    _handle: Box<dyn SpawnHandle>,
+}
+
+impl Stream for HttpActionResponseStream {
+    type Item = Result<pb::funrun::HttpActionResponsePart, Status>;
+
+    fn poll_next(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Option<Self::Item>> {
+        Pin::new(&mut self.inner).poll_next(cx)
+    }
+}
+
+#[tonic::async_trait]
+impl<RT: Runtime> pb::funrun::funrun_server::Funrun for FunrunService<RT> {
+    type RunFunctionStream = RunFunctionStream;
+    type RunHttpActionStream = HttpActionResponseStream;
+
+    async fn run_function(
+        &self,
+        request: Request<pb::funrun::RunFunctionRequest>,
+    ) -> Result<Response<Self::RunFunctionStream>, Status> {
+        let metadata = request.metadata().clone();
+        let req = request.into_inner();
+        let instance = self
+            .resolve_and_authenticate(&req.instance_name, &metadata)
+            .await?;
+        let (part_tx, part_rx) = mpsc::channel(RESPONSE_STREAM_BUFFER);
+        let fetch_client = self.fetch_client.clone();
+        let callback_client = self.callback_client.clone();
+        let handle = self.rt.spawn("funrun_run_function", async move {
+            match Self::run(instance, fetch_client, callback_client, req, &part_tx).await {
+                Ok(result) => {
+                    let part = pb::funrun::RunFunctionResponsePart {
+                        part: Some(pb::funrun::run_function_response_part::Part::Result(result)),
+                    };
+                    let _ = part_tx.send(Ok(part)).await;
+                },
+                Err(e) => {
+                    let _ = part_tx.send(Err(Status::from_anyhow(e))).await;
+                },
+            }
+        });
+        Ok(Response::new(RunFunctionStream {
+            inner: ReceiverStream::new(part_rx),
+            _handle: handle,
+        }))
+    }
+
+    async fn run_http_action(
+        &self,
+        request: Request<pb::funrun::RunHttpActionRequest>,
+    ) -> Result<Response<Self::RunHttpActionStream>, Status> {
+        let metadata = request.metadata().clone();
+        let req = request.into_inner();
+        let instance = self
+            .resolve_and_authenticate(&req.instance_name, &metadata)
+            .await?;
+        let (part_tx, part_rx) = mpsc::channel(RESPONSE_STREAM_BUFFER);
+        let fetch_client = self.fetch_client.clone();
+        let callback_client = self.callback_client.clone();
+        let handle = self.rt.spawn("funrun_run_http_action", async move {
+            match Self::run_http(instance, fetch_client, callback_client, req, &part_tx).await {
+                Ok(result) => {
+                    let part = pb::funrun::HttpActionResponsePart {
+                        part: Some(pb::funrun::http_action_response_part::Part::Result(result)),
+                    };
+                    let _ = part_tx.send(Ok(part)).await;
+                },
+                Err(e) => {
+                    let _ = part_tx.send(Err(Status::from_anyhow(e))).await;
+                },
+            }
+        });
+        Ok(Response::new(HttpActionResponseStream {
+            inner: ReceiverStream::new(part_rx),
+            _handle: handle,
+        }))
+    }
+}
