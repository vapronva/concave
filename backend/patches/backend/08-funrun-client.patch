@@ -0,0 +1,154 @@
+use aws_lc_rs::hmac;
+
+use crate::DeploymentSecret;
+
+const DOMAIN: &[u8] = b"convex-funrun-auth-v2";
+
+pub const WINDOW_SECONDS: u64 = 30;
+
+pub const FUNRUN_AUTH_METADATA_KEY: &str = "authorization";
+
+fn window_for(unix_seconds: u64) -> u64 {
+    unix_seconds / WINDOW_SECONDS
+}
+
+fn funrun_auth_token_for_window(
+    secret: &DeploymentSecret,
+    instance_name: &str,
+    window: u64,
+) -> String {
+    let key = hmac::Key::new(hmac::HMAC_SHA256, secret.as_bytes());
+    let mut msg = Vec::with_capacity(DOMAIN.len() + 1 + instance_name.len() + 1 + 8);
+    msg.extend_from_slice(DOMAIN);
+    msg.push(0u8);
+    msg.extend_from_slice(instance_name.as_bytes());
+    msg.push(0u8);
+    msg.extend_from_slice(&window.to_be_bytes());
+    let tag = hmac::sign(&key, &msg);
+    hex::encode(tag.as_ref())
+}
+
+pub fn funrun_auth_token(
+    secret: &DeploymentSecret,
+    instance_name: &str,
+    unix_seconds: u64,
+) -> String {
+    funrun_auth_token_for_window(secret, instance_name, window_for(unix_seconds))
+}
+
+pub fn funrun_auth_header(
+    secret: &DeploymentSecret,
+    instance_name: &str,
+    unix_seconds: u64,
+) -> String {
+    format!(
+        "Bearer {}",
+        funrun_auth_token(secret, instance_name, unix_seconds)
+    )
+}
+
+pub fn verify_funrun_auth_header(
+    presented: &str,
+    secret: &DeploymentSecret,
+    instance_name: &str,
+    unix_seconds: u64,
+) -> bool {
+    let Some(token) = presented.strip_prefix("Bearer ") else {
+        return false;
+    };
+    let current = window_for(unix_seconds);
+    let expected_current = funrun_auth_token_for_window(secret, instance_name, current);
+    let expected_prev =
+        funrun_auth_token_for_window(secret, instance_name, current.wrapping_sub(1));
+    let m_current = constant_time_eq(token.as_bytes(), expected_current.as_bytes());
+    let m_prev = constant_time_eq(token.as_bytes(), expected_prev.as_bytes());
+    m_current | m_prev
+}
+
+fn constant_time_eq(a: &[u8], b: &[u8]) -> bool {
+    if a.len() != b.len() {
+        return false;
+    }
+    let mut diff: u8 = 0;
+    for (x, y) in a.iter().zip(b.iter()) {
+        diff |= x ^ y;
+    }
+    diff == 0
+}
+
+#[cfg(test)]
+mod tests {
+    use super::{
+        funrun_auth_header,
+        funrun_auth_token,
+        verify_funrun_auth_header,
+        WINDOW_SECONDS,
+    };
+    use crate::DeploymentSecret;
+
+    #[test]
+    fn token_roundtrips_and_is_deployment_scoped() {
+        let secret = DeploymentSecret::random();
+        let other_secret = DeploymentSecret::random();
+        let now = 1_700_000_000u64;
+        let header = funrun_auth_header(&secret, "carnitas", now);
+        assert!(verify_funrun_auth_header(&header, &secret, "carnitas", now));
+        assert!(!verify_funrun_auth_header(
+            &header,
+            &other_secret,
+            "carnitas",
+            now
+        ));
+        assert!(!verify_funrun_auth_header(
+            &header, &secret, "barbacoa", now
+        ));
+        assert!(!verify_funrun_auth_header("", &secret, "carnitas", now));
+        assert!(!verify_funrun_auth_header(
+            "Bearer", &secret, "carnitas", now
+        ));
+        assert!(!verify_funrun_auth_header(
+            &funrun_auth_token(&secret, "carnitas", now),
+            &secret,
+            "carnitas",
+            now
+        ));
+    }
+
+    #[test]
+    fn token_is_time_windowed_with_bounded_replay() {
+        let secret = DeploymentSecret::random();
+        let base = 100 * WINDOW_SECONDS;
+        let header = funrun_auth_header(&secret, "carnitas", base);
+        assert!(verify_funrun_auth_header(
+            &header,
+            &secret,
+            "carnitas",
+            base + WINDOW_SECONDS - 1
+        ));
+        assert!(verify_funrun_auth_header(
+            &header,
+            &secret,
+            "carnitas",
+            base + WINDOW_SECONDS
+        ));
+        assert!(verify_funrun_auth_header(
+            &header,
+            &secret,
+            "carnitas",
+            base + 2 * WINDOW_SECONDS - 1
+        ));
+        assert!(!verify_funrun_auth_header(
+            &header,
+            &secret,
+            "carnitas",
+            base + 2 * WINDOW_SECONDS
+        ));
+        let future_header = funrun_auth_header(&secret, "carnitas", base + 2 * WINDOW_SECONDS);
+        assert!(!verify_funrun_auth_header(
+            &future_header,
+            &secret,
+            "carnitas",
+            base
+        ));
+    }
+}
