+    fn from(term: TextQueryTerm) -> Self {
+        let term = match term {
+            TextQueryTerm::Exact(token) => pb::funrun::text_query_term::Term::Exact(token),
+            TextQueryTerm::Prefix(token) => pb::funrun::text_query_term::Term::Prefix(token),
+        };
+        pb::funrun::TextQueryTerm { term: Some(term) }
+    }
+}
+
+impl TryFrom<pb::funrun::TextQueryTerm> for TextQueryTerm {
+    type Error = anyhow::Error;
+
+    fn try_from(value: pb::funrun::TextQueryTerm) -> anyhow::Result<Self> {
+        Ok(
+            match value.term.context("Missing `term` in TextQueryTerm")? {
+                pb::funrun::text_query_term::Term::Exact(token) => TextQueryTerm::Exact(token),
+                pb::funrun::text_query_term::Term::Prefix(token) => TextQueryTerm::Prefix(token),
+            },
+        )
+    }
+}
+
+impl From<TextQueryTermRead> for pb::funrun::TextQueryTermRead {
