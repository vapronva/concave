+
+impl QueryReads {
+    pub fn to_proto(
+        self,
+    ) -> (
+        Vec<pb::funrun::TextQueryTermRead>,
+        Vec<pb::funrun::FilterConditionRead>,
+    ) {
+        let text_queries = Vec::from(self.text_queries)
+            .into_iter()
+            .map(pb::funrun::TextQueryTermRead::from)
+            .collect();
+        let filter_conditions = Vec::from(self.filter_conditions)
+            .into_iter()
+            .map(pb::funrun::FilterConditionRead::from)
+            .collect();
+        (text_queries, filter_conditions)
+    }
+
+    pub fn from_proto(
+        text_queries: Vec<pb::funrun::TextQueryTermRead>,
+        filter_conditions: Vec<pb::funrun::FilterConditionRead>,
+    ) -> anyhow::Result<Self> {
+        let text_queries: Vec<TextQueryTermRead> = text_queries
+            .into_iter()
+            .map(TextQueryTermRead::try_from)
+            .collect::<anyhow::Result<_>>()?;
+        let filter_conditions: Vec<FilterConditionRead> = filter_conditions
+            .into_iter()
+            .map(FilterConditionRead::try_from)
+            .collect::<anyhow::Result<_>>()?;
+        Ok(QueryReads::new(
+            text_queries.into(),
+            filter_conditions.into(),
+        ))
+    }
+}
