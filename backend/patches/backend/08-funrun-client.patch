+impl From<FilterConditionRead> for pb::funrun::FilterConditionRead {
+    fn from(read: FilterConditionRead) -> Self {
+        let FilterConditionRead::Must(field_path, value) = read;
+        pb::funrun::FilterConditionRead {
+            field_path: Some(field_path.into()),
+            value: Vec::<u8>::from(value),
+        }
+    }
+}
