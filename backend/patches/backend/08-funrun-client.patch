+mod funrun_proto_tests {
+    use std::str::FromStr;
+
+    use common::query::FilterValue;
+    use value::{
+        ConvexValue,
+        FieldPath,
+    };
+
+    use super::{
+        FilterConditionRead,
+        QueryReads,
+        TextQueryTerm,
+        TextQueryTermRead,
+    };
+
+    #[test]
+    fn query_reads_proto_roundtrip() {
+        let field = FieldPath::from_str("body").unwrap();
+        let filter_field = FieldPath::from_str("channel").unwrap();
+        let reads = QueryReads::new(
+            vec![
+                TextQueryTermRead::new(field.clone(), TextQueryTerm::Exact("hello".to_string())),
+                TextQueryTermRead::new(field.clone(), TextQueryTerm::Prefix("wor".to_string())),
+            ]
+            .into(),
+            vec![FilterConditionRead::Must(
+                filter_field,
+                FilterValue::from_search_value(Some(&ConvexValue::from(7.0))),
+            )]
+            .into(),
+        );
+        let (text_queries, filter_conditions) = reads.clone().to_proto();
+        assert_eq!(text_queries.len(), 2);
+        assert_eq!(filter_conditions.len(), 1);
+        let decoded = QueryReads::from_proto(text_queries, filter_conditions).unwrap();
+        assert_eq!(reads, decoded);
+    }
+}
