+
+impl TryFrom<pb::funrun::TextQueryTermRead> for TextQueryTermRead {
+    type Error = anyhow::Error;
+
+    fn try_from(value: pb::funrun::TextQueryTermRead) -> anyhow::Result<Self> {
+        Ok(TextQueryTermRead {
