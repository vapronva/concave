+impl TryFrom<pb::funrun::FilterConditionRead> for FilterConditionRead {
+    type Error = anyhow::Error;
+
+    fn try_from(value: pb::funrun::FilterConditionRead) -> anyhow::Result<Self> {
+        Ok(FilterConditionRead::Must(
