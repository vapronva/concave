@@ -0,0 +1,213 @@
+use std::{
+    collections::BTreeMap,
+    str::FromStr,
+};
+
+use anyhow::Context;
+use common::{
+    bootstrap_model::index::database_index::IndexedFields,
+    interval::IntervalSet,
+    types::TabletIndexName,
+};
+use database::{
+    reads::{
+        IndexReads,
+        TransactionReadSize,
+    },
+    ReadSet,
+};
+use search::QueryReads as SearchQueryReads;
+use sync_types::Timestamp;
+use value::{
+    FieldPath,
+    TabletId,
+};
+
+use crate::{
+    FunctionFinalTransaction,
+    FunctionReads,
+    FunctionWrites,
+};
+
+impl TryFrom<FunctionReads> for pb::funrun::FunctionReads {
+    type Error = anyhow::Error;
+
+    fn try_from(
+        FunctionReads {
+            reads,
+            num_intervals,
+            user_tx_size,
+            system_tx_size,
+        }: FunctionReads,
+    ) -> anyhow::Result<Self> {
+        let (index_reads, search_reads) = reads.consume();
+        let indexed = index_reads
+            .map(|(index_name, index_reads)| {
+                let IndexReads {
+                    fields, intervals, ..
+                } = index_reads;
+                pb::funrun::IndexedReads {
+                    index_name: index_name.to_string(),
+                    fields: Vec::<pb::common::FieldPath>::from(fields),
+                    intervals: Vec::<pb::common::Interval>::from(intervals),
+                }
+            })
+            .collect();
+        let search = search_reads
+            .map(|(index_name, query_reads)| {
+                let (text_queries, filter_conditions) = query_reads.to_proto();
+                pb::funrun::SearchReads {
+                    index_name: index_name.to_string(),
+                    text_queries,
+                    filter_conditions,
+                }
+            })
+            .collect();
+        Ok(pb::funrun::FunctionReads {
+            indexed,
+            num_intervals: num_intervals as u64,
+            user_tx_size: Some(read_size_to_proto(user_tx_size)),
+            system_tx_size: Some(read_size_to_proto(system_tx_size)),
+            search,
+        })
+    }
+}
+
+impl TryFrom<pb::funrun::FunctionReads> for FunctionReads {
+    type Error = anyhow::Error;
+
+    fn try_from(
+        pb::funrun::FunctionReads {
+            indexed,
+            num_intervals,
+            user_tx_size,
+            system_tx_size,
+            search,
+        }: pb::funrun::FunctionReads,
+    ) -> anyhow::Result<Self> {
+        let mut indexed_map = BTreeMap::new();
+        for pb::funrun::IndexedReads {
+            index_name,
+            fields,
+            intervals,
+        } in indexed
+        {
+            let index_name = TabletIndexName::from_str(&index_name)
+                .with_context(|| format!("Invalid index name {index_name}"))?;
+            let fields: IndexedFields = fields
+                .into_iter()
+                .map(FieldPath::try_from)
+                .collect::<anyhow::Result<Vec<_>>>()?
+                .try_into()?;
+            let intervals = IntervalSet::try_from(intervals)?;
+            indexed_map.insert(
+                index_name,
+                IndexReads {
+                    fields,
+                    intervals,
+                    stack_traces: None,
+                },
+            );
+        }
+        let mut search_map = BTreeMap::new();
+        for pb::funrun::SearchReads {
+            index_name,
+            text_queries,
+            filter_conditions,
+        } in search
+        {
+            let index_name = TabletIndexName::from_str(&index_name)
+                .with_context(|| format!("Invalid search index name {index_name}"))?;
+            let query_reads = SearchQueryReads::from_proto(text_queries, filter_conditions)?;
+            search_map.insert(index_name, query_reads);
+        }
+        let reads = ReadSet::new(indexed_map, search_map);
+        Ok(FunctionReads {
+            reads,
+            num_intervals: num_intervals as usize,
+            user_tx_size: read_size_from_proto(user_tx_size.unwrap_or_default()),
+            system_tx_size: read_size_from_proto(system_tx_size.unwrap_or_default()),
+        })
+    }
+}
+
+fn read_size_to_proto(size: TransactionReadSize) -> pb::funrun::ReadSize {
+    pb::funrun::ReadSize {
+        total_document_size: size.total_document_size as u64,
+        total_document_count: size.total_document_count as u64,
+    }
+}
+
+fn read_size_from_proto(size: pb::funrun::ReadSize) -> TransactionReadSize {
+    TransactionReadSize {
+        total_document_size: size.total_document_size as usize,
+        total_document_count: size.total_document_count as usize,
+    }
+}
+
+impl TryFrom<FunctionFinalTransaction> for pb::funrun::FunctionFinalTransaction {
+    type Error = anyhow::Error;
+
+    fn try_from(
+        FunctionFinalTransaction {
+            begin_timestamp,
+            reads,
+            writes,
+            rows_read_by_tablet,
+        }: FunctionFinalTransaction,
+    ) -> anyhow::Result<Self> {
+        let writes = writes
+            .updates
+            .into_iter()
+            .map(pb::common::DocumentUpdateWithPrevTs::try_from)
+            .collect::<anyhow::Result<Vec<_>>>()?;
+        let rows_read_by_tablet = rows_read_by_tablet
+            .into_iter()
+            .map(|(tablet_id, rows_read)| pb::funrun::RowsReadByTablet {
+                tablet_id: tablet_id.to_string(),
+                rows_read,
+            })
+            .collect();
+        Ok(pb::funrun::FunctionFinalTransaction {
+            begin_timestamp: begin_timestamp.into(),
+            reads: Some(reads.try_into()?),
+            writes,
+            rows_read_by_tablet,
+        })
+    }
+}
+
+impl TryFrom<pb::funrun::FunctionFinalTransaction> for FunctionFinalTransaction {
+    type Error = anyhow::Error;
+
+    fn try_from(
+        pb::funrun::FunctionFinalTransaction {
+            begin_timestamp,
+            reads,
+            writes,
+            rows_read_by_tablet,
+        }: pb::funrun::FunctionFinalTransaction,
+    ) -> anyhow::Result<Self> {
+        let writes = writes
+            .into_iter()
+            .map(common::document::DocumentUpdateWithPrevTs::try_from)
+            .collect::<anyhow::Result<Vec<_>>>()?;
+        let rows_read_by_tablet = rows_read_by_tablet
+            .into_iter()
+            .map(
+                |pb::funrun::RowsReadByTablet {
+                     tablet_id,
+                     rows_read,
+                 }| { anyhow::Ok((TabletId::from_str(&tablet_id)?, rows_read)) },
+            )
+            .collect::<anyhow::Result<BTreeMap<_, _>>>()?;
+        Ok(FunctionFinalTransaction {
+            begin_timestamp: Timestamp::try_from(begin_timestamp)?,
+            reads: reads
+                .context("Missing reads in FunctionFinalTransaction")?
+                .try_into()?,
+            writes: FunctionWrites { updates: writes },
+            rows_read_by_tablet,
+        })
+    }
+}
