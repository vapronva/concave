+pub const MAX_GRPC_MESSAGE_BYTES: usize = udf::HTTP_ACTION_BODY_LIMIT + (1 << 20);
+
+pub fn funrun_tls_pem_from_env() -> anyhow::Result<Option<(Vec<u8>, Vec<u8>, Vec<u8>)>> {
+    let cert = std::env::var_os("CONVEX_FUNRUN_TLS_CERT");
+    let key = std::env::var_os("CONVEX_FUNRUN_TLS_KEY");
+    let ca = std::env::var_os("CONVEX_FUNRUN_TLS_CA");
+    match (cert, key, ca) {
+        (None, None, None) => Ok(None),
+        (Some(cert), Some(key), Some(ca)) => {
+            let cert_pem = std::fs::read(&cert)
+                .map_err(|e| anyhow::anyhow!("reading CONVEX_FUNRUN_TLS_CERT {cert:?}: {e}"))?;
+            let key_pem = std::fs::read(&key)
+                .map_err(|e| anyhow::anyhow!("reading CONVEX_FUNRUN_TLS_KEY {key:?}: {e}"))?;
+            let ca_pem = std::fs::read(&ca)
+                .map_err(|e| anyhow::anyhow!("reading CONVEX_FUNRUN_TLS_CA {ca:?}: {e}"))?;
+            Ok(Some((cert_pem, key_pem, ca_pem)))
+        },
+        _ => anyhow::bail!(
+            "funrun mTLS misconfigured: set ALL of CONVEX_FUNRUN_TLS_CERT, CONVEX_FUNRUN_TLS_KEY, \
+             CONVEX_FUNRUN_TLS_CA (file paths) to enable mutual TLS, or NONE of them for plaintext"
+        ),
+    }
+}
+
+fn funrun_client_tls_config() -> anyhow::Result<Option<ClientTlsConfig>> {
+    let Some((cert_pem, key_pem, ca_pem)) = funrun_tls_pem_from_env()? else {
+        return Ok(None);
+    };
+    let domain = std::env::var("CONVEX_FUNRUN_TLS_DOMAIN").unwrap_or_else(|_| "funrun".to_string());
+    let config = ClientTlsConfig::new()
+        .domain_name(domain)
+        .ca_certificate(Certificate::from_pem(ca_pem))
+        .identity(TlsIdentity::from_pem(cert_pem, key_pem));
+    Ok(Some(config))
+}
+
+pub struct RemoteFunctionRunner<RT: Runtime> {
+    endpoint: Endpoint,
+    local: FunctionRunnerCore<RT, DeploymentStorage>,
+    deployment: DeploymentMetadata,
+    key_broker: KeyBroker,
+    convex_origin: ConvexOrigin,
+    rt: RT,
+    instance_secret: DeploymentSecret,
+}
+
+impl<RT: Runtime> RemoteFunctionRunner<RT> {
+    pub fn new(
+        funrun_addr: String,
+        deployment: DeploymentMetadata,
+        key_broker: KeyBroker,
+        instance_secret: DeploymentSecret,
+        convex_origin: ConvexOrigin,
+        rt: RT,
+        storage: DeploymentStorage,
+    ) -> anyhow::Result<Self> {
+        let mut endpoint = Endpoint::from_shared(funrun_addr.clone())
+            .map_err(|e| anyhow::anyhow!("Invalid CONVEX_FUNRUN_ADDR {funrun_addr}: {e}"))?
+            .tcp_nodelay(true);
+        if let Some(tls_config) = funrun_client_tls_config()? {
+            endpoint = endpoint
+                .tls_config(tls_config)
+                .map_err(|e| anyhow::anyhow!("invalid funrun client TLS configuration: {e}"))?;
+            tracing::info!("[funrun] connecting to fleet over mutual TLS");
+        } else {
+            tracing::warn!(
+                "[funrun] CONVEX_FUNRUN_TLS_* unset; connecting to fleet over PLAINTEXT gRPC -- \
+                 use only for local/dev"
+            );
+        }
+        let local = FunctionRunnerCore::new(rt.clone(), storage, 100)?;
+        Ok(Self {
+            endpoint,
+            local,
+            deployment,
+            key_broker,
+            convex_origin,
+            rt,
+            instance_secret,
+        })
+    }
+
+    fn funrun_auth_header(&self) -> String {
+        let unix_seconds = self.rt.unix_timestamp().as_secs();
+        funrun_auth_header(&self.instance_secret, &self.deployment.name, unix_seconds)
+    }
+
+    async fn run_function_remote(
+        &self,
+        udf_type: UdfType,
+        identity: Identity,
+        ts: RepeatableTimestamp,
+        existing_writes: FunctionWrites,
+        log_line_sender: Option<mpsc::UnboundedSender<LogLine>>,
+        function_metadata: Option<FunctionMetadata>,
+        default_system_env_vars: BTreeMap<EnvVarName, EnvVarValue>,
+        in_memory_index_last_modified: BTreeMap<IndexId, Timestamp>,
+        context: ExecutionContext,
+    ) -> anyhow::Result<(
+        Option<FunctionFinalTransaction>,
+        FunctionOutcome,
+        FunctionUsageStats,
+    )> {
+        let inert_identity: InertIdentity = identity.clone().into();
+        let path_and_args = function_metadata.as_ref().map(|m| m.path_and_args.clone());
+        let component = path_and_args
+            .as_ref()
+            .map(|p| p.path().component)
+            .unwrap_or(common::components::ComponentId::Root);
+        let auth_header = token_to_authorization_header(identity.clone().into())?;
+        let callback_token = self.key_broker.issue_action_token(component);
+        let existing_writes = existing_writes
+            .updates
+            .into_iter()
+            .map(pb::common::DocumentUpdateWithPrevTs::try_from)
+            .collect::<anyhow::Result<Vec<_>>>()?;
+        let (path_and_args_proto, journal_proto) = match function_metadata {
+            Some(FunctionMetadata {
+                path_and_args,
+                journal,
+            }) => (
+                Some(pb::common::ValidatedPathAndArgs::try_from(path_and_args)?),
+                Some(journal.into()),
+            ),
+            None => (None, None),
+        };
+        let request = pb::funrun::RunFunctionRequest {
+            instance_name: self.deployment.name.clone(),
+            udf_type: pb::common::UdfType::from(udf_type) as i32,
+            identity: Some(identity.try_into()?),
+            ts: Some(ts.into()),
+            existing_writes,
+            path_and_args: path_and_args_proto,
+            journal: journal_proto,
+            default_system_env_vars: default_system_env_vars
+                .into_iter()
+                .map(|(name, value)| pb::funrun::EnvVar {
+                    name: name.to_string(),
+                    value: String::from(value),
+                })
+                .collect(),
+            in_memory_index_last_modified: in_memory_index_last_modified
+                .into_iter()
+                .map(|(index_id, ts)| pb::funrun::IndexLastModified {
+                    index_id: String::from(index_id),
+                    last_modified_ts: ts.into(),
+                })
+                .collect(),
+            context: Some(context.into()),
+            backend_callback_url: Some(self.convex_origin.to_string()),
+            callback_token: Some(callback_token),
+            auth_header,
+        };
+        let mut request = tonic::Request::new(request);
+        request.metadata_mut().insert(
+            FUNRUN_AUTH_METADATA_KEY,
+            self.funrun_auth_header()
+                .parse()
+                .map_err(|e| anyhow::anyhow!("invalid funrun auth header: {e}"))?,
+        );
+        let channel = self.endpoint.connect().await.map_err(|e| {
+            anyhow::anyhow!(
+                "Failed to connect to funrun fleet at {:?}: {e}",
+                self.endpoint.uri()
+            )
+        })?;
+        let mut client = pb::funrun::funrun_client::FunrunClient::new(channel)
+            .max_decoding_message_size(MAX_GRPC_MESSAGE_BYTES)
+            .max_encoding_message_size(MAX_GRPC_MESSAGE_BYTES);
+        let mut stream = client
+            .run_function(request)
+            .await
+            .map_err(|status| status.into_anyhow())
+            .context("funrun RunFunction failed")?
+            .into_inner();
+        let mut result: Option<pb::funrun::RunFunctionResult> = None;
+        while let Some(part) = stream
+            .message()
+            .await
+            .map_err(|status| status.into_anyhow())
+            .context("funrun RunFunction stream error")?
+        {
+            match part.part {
+                Some(pb::funrun::run_function_response_part::Part::LogLine(log_line)) => {
+                    let log_line = LogLine::try_from(log_line)?;
+                    if let Some(sender) = &log_line_sender {
+                        let _ = sender.send(log_line);
+                    }
+                },
+                Some(pb::funrun::run_function_response_part::Part::Result(r)) => {
+                    anyhow::ensure!(
+                        result.is_none(),
+                        "funrun sent more than one terminal result"
+                    );
+                    result = Some(r);
+                },
+                None => anyhow::bail!("funrun sent an empty RunFunctionResponsePart"),
+            }
+        }
+        let pb::funrun::RunFunctionResult {
+            outcome,
+            final_transaction,
+            usage_stats,
+        } = result.context("funrun stream ended without a terminal result")?;
+        let outcome = FunctionOutcome::from_proto(
+            outcome.ok_or_else(|| anyhow::anyhow!("funrun response missing outcome"))?,
+            path_and_args,
+            None,
+            inert_identity,
+        )?;
+        let final_transaction = final_transaction
+            .map(FunctionFinalTransaction::try_from)
+            .transpose()?;
+        let usage_stats = usage_stats
+            .map(FunctionUsageStats::try_from)
+            .transpose()?
+            .unwrap_or_default();
+        Ok((final_transaction, outcome, usage_stats))
+    }
+
+    async fn run_http_action_remote(
+        &self,
+        identity: Identity,
+        ts: RepeatableTimestamp,
+        existing_writes: FunctionWrites,
+        log_line_sender: Option<mpsc::UnboundedSender<LogLine>>,
+        http_action_metadata: HttpActionMetadata,
+        default_system_env_vars: BTreeMap<EnvVarName, EnvVarValue>,
+        in_memory_index_last_modified: BTreeMap<IndexId, Timestamp>,
+        context: ExecutionContext,
+    ) -> anyhow::Result<(
+        Option<FunctionFinalTransaction>,
+        FunctionOutcome,
+        FunctionUsageStats,
+    )> {
+        let HttpActionMetadata {
+            mut http_response_streamer,
+            http_module_path,
+            routed_path,
+            http_request,
+        } = http_action_metadata;
+        let inert_identity: InertIdentity = identity.clone().into();
+        let request_head = http_request.head.clone();
+        let http_path_for_outcome = http_module_path.clone();
+        let component = http_module_path.path().component;
+        let auth_header = token_to_authorization_header(identity.clone().into())?;
+        let callback_token = self.key_broker.issue_action_token(component);
+        let http_request_body = match http_request.body {
+            Some(mut body) => {
+                let mut buf = Vec::new();
+                while let Some(chunk) = body.next().await {
+                    buf.extend_from_slice(&chunk?);
+                }
+                Some(buf)
+            },
+            None => None,
+        };
+        let existing_writes = existing_writes
+            .updates
+            .into_iter()
+            .map(pb::common::DocumentUpdateWithPrevTs::try_from)
+            .collect::<anyhow::Result<Vec<_>>>()?;
+        let request = pb::funrun::RunHttpActionRequest {
+            instance_name: self.deployment.name.clone(),
+            identity: Some(identity.try_into()?),
+            ts: Some(ts.into()),
+            existing_writes,
+            default_system_env_vars: default_system_env_vars
+                .into_iter()
+                .map(|(name, value)| pb::funrun::EnvVar {
+                    name: name.to_string(),
+                    value: String::from(value),
+                })
+                .collect(),
+            in_memory_index_last_modified: in_memory_index_last_modified
+                .into_iter()
+                .map(|(index_id, ts)| pb::funrun::IndexLastModified {
+                    index_id: String::from(index_id),
+                    last_modified_ts: ts.into(),
+                })
+                .collect(),
+            context: Some(context.into()),
+            backend_callback_url: Some(self.convex_origin.to_string()),
+            callback_token: Some(callback_token),
+            auth_header,
+            http_module_path: Some(http_module_path.try_into()?),
+            routed_path: routed_path.0,
+            http_request_head: Some(request_head.clone().into()),
+            http_request_body,
+        };
+        let mut request = tonic::Request::new(request);
+        request.metadata_mut().insert(
+            FUNRUN_AUTH_METADATA_KEY,
+            self.funrun_auth_header()
+                .parse()
+                .map_err(|e| anyhow::anyhow!("invalid funrun auth header: {e}"))?,
+        );
+        let channel = self.endpoint.connect().await.map_err(|e| {
+            anyhow::anyhow!(
+                "Failed to connect to funrun fleet at {:?}: {e}",
+                self.endpoint.uri()
+            )
+        })?;
+        let mut client = pb::funrun::funrun_client::FunrunClient::new(channel)
+            .max_decoding_message_size(MAX_GRPC_MESSAGE_BYTES)
+            .max_encoding_message_size(MAX_GRPC_MESSAGE_BYTES);
+        let mut stream = client
+            .run_http_action(request)
+            .await
+            .map_err(|status| status.into_anyhow())
+            .context("funrun RunHttpAction failed")?
+            .into_inner();
+        let mut result: Option<pb::funrun::RunFunctionResult> = None;
+        while let Some(part) = stream
+            .message()
+            .await
+            .map_err(|status| status.into_anyhow())
+            .context("funrun RunHttpAction stream error")?
+        {
+            match part.part {
+                Some(pb::funrun::http_action_response_part::Part::LogLine(log_line)) => {
+                    let log_line = LogLine::try_from(log_line)?;
+                    if let Some(sender) = &log_line_sender {
+                        let _ = sender.send(log_line);
+                    }
+                },
+                Some(pb::funrun::http_action_response_part::Part::Response(response)) => {
+                    let part = http_action_response_part_from_proto(response)?;
+                    let _ = http_response_streamer.send_part(part)?;
+                },
+                Some(pb::funrun::http_action_response_part::Part::Result(r)) => {
+                    anyhow::ensure!(
+                        result.is_none(),
+                        "funrun sent more than one terminal result"
+                    );
+                    result = Some(r);
+                },
+                None => anyhow::bail!("funrun sent an empty HttpActionResponsePart"),
+            }
+        }
+        let pb::funrun::RunFunctionResult {
+            outcome,
+            final_transaction: _,
+            usage_stats,
+        } = result.context("funrun HttpAction stream ended without a terminal result")?;
+        let outcome = FunctionOutcome::from_proto(
+            outcome.ok_or_else(|| anyhow::anyhow!("funrun response missing outcome"))?,
+            None,
+            Some((http_path_for_outcome, request_head)),
+            inert_identity,
+        )?;
+        let usage_stats = usage_stats
+            .map(FunctionUsageStats::try_from)
+            .transpose()?
+            .unwrap_or_default();
+        Ok((None, outcome, usage_stats))
+    }
+}
+
+fn http_action_response_part_from_proto(
+    response: pb::common::HttpActionResponse,
+) -> anyhow::Result<udf::HttpActionResponsePart> {
+    use pb::common::http_action_response::MessageType;
+    let message_type = response
+        .message_type
+        .context("HttpActionResponse missing message_type")?;
+    Ok(match message_type {
+        MessageType::Head(head) => {
+            udf::HttpActionResponsePart::Head(udf::HttpActionResponseHead::try_from(head)?)
+        },
+        MessageType::Body(bytes) => udf::HttpActionResponsePart::BodyChunk(bytes.into()),
+    })
+}
