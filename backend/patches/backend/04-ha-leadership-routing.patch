+#[cfg(test)]
+mod role_state_tests {
+    use common::types::BackendRole;
+
+    use super::{
+        DemotionAttempt,
+        PromotionAttempt,
+        RoleState,
+    };
+
+    #[test]
+    fn follower_starts_not_leader() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(!rs.is_leader());
+        assert_eq!(rs.current(), BackendRole::Follower);
+    }
+
+    #[test]
+    fn leader_starts_leader() {
+        let rs = RoleState::new(BackendRole::Leader);
+        assert!(rs.is_leader());
+        assert_eq!(rs.current(), BackendRole::Leader);
+    }
+
+    #[test]
+    fn promote_then_demote_round_trips() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+        assert!(!rs.is_leader());
+        rs.finish_promotion_success();
+        assert!(rs.is_leader());
+        assert!(matches!(rs.begin_demotion(), DemotionAttempt::Started));
+        assert!(!rs.is_leader());
+        assert_eq!(rs.current(), BackendRole::Follower);
+        rs.finish_demotion_success();
+        assert!(!rs.is_leader());
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+        rs.finish_promotion_success();
+        assert!(rs.is_leader());
+    }
+
+    #[test]
+    fn demote_is_idempotent_and_fenced() {
+        let rs = RoleState::new(BackendRole::Leader);
+        assert!(matches!(rs.begin_demotion(), DemotionAttempt::Started));
+        assert!(matches!(
+            rs.begin_demotion(),
+            DemotionAttempt::AlreadyInProgress
+        ));
+        rs.finish_demotion_success();
+        assert!(matches!(
+            rs.begin_demotion(),
+            DemotionAttempt::AlreadyFollower
+        ));
+    }
+
+    #[test]
+    fn cannot_demote_a_plain_follower() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(matches!(
+            rs.begin_demotion(),
+            DemotionAttempt::AlreadyFollower
+        ));
+        assert!(!rs.is_leader());
+    }
+
+    #[test]
+    fn promote_is_idempotent() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+        assert!(matches!(
+            rs.begin_promotion(),
+            PromotionAttempt::AlreadyInProgress
+        ));
+        rs.finish_promotion_success();
+        assert!(matches!(
+            rs.begin_promotion(),
+            PromotionAttempt::AlreadyLeader
+        ));
+    }
+
+    #[test]
+    fn aborted_promotion_returns_to_follower() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+        rs.abort_promotion();
+        assert!(!rs.is_leader());
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+    }
+
+    #[test]
+    fn aborted_demotion_returns_to_leader() {
+        let rs = RoleState::new(BackendRole::Leader);
+        assert!(matches!(rs.begin_demotion(), DemotionAttempt::Started));
+        assert!(!rs.is_leader());
+        rs.abort_demotion();
+        assert!(rs.is_leader());
+    }
+}
+
+#[cfg(test)]
+mod control_plane_token_tests {
+    use super::control_plane_token_eq;
+
+    #[test]
+    fn matches_only_exact_token() {
+        assert!(control_plane_token_eq(b"secret", b"secret"));
+        assert!(!control_plane_token_eq(b"secret", b"Secret"));
+        assert!(!control_plane_token_eq(b"secret", b"secre"));
+        assert!(!control_plane_token_eq(b"secret", b"secrett"));
+        assert!(!control_plane_token_eq(b"", b"secret"));
+        assert!(!control_plane_token_eq(b"secret", b""));
+        assert!(control_plane_token_eq(b"", b""));
+    }
+}
