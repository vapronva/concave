+
+    fn gated_router(role: Arc<RoleState>) -> Router {
+        Router::new()
+            .route("/api/query", post(|| async { "ok" }))
+            .route("/instance_name", get(|| async { "name" }))
+            .route("/instance_version", get(|| async { "version" }))
+            .route("/instance/leadership", get(|| async { "leadership" }))
+            .route("/instance/promote", post(|| async { "promote" }))
+            .route("/instance/demote", post(|| async { "demote" }))
+            .route("/", get(|| async { "health" }))
+            .layer(axum::middleware::from_fn_with_state(role, role_gate))
+    }
+
+    async fn status_of(router: Router, method: &str, path: &str) -> StatusCode {
+        let req = http::Request::builder()
+            .method(method)
+            .uri(path)
+            .body(axum::body::Body::empty())
+            .unwrap();
+        router.oneshot(req).await.unwrap().status()
+    }
+
+    #[tokio::test]
+    async fn leader_runtime_role_serves_clients_and_control_plane() {
+        let role = Arc::new(RoleState::new(BackendRole::Leader));
+        assert!(role.is_leader());
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/api/query").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "GET", "/instance/leadership").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/instance/promote").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role), "POST", "/instance/demote").await,
+            StatusCode::OK,
+        );
+    }
+
+    #[tokio::test]
+    async fn follower_runtime_role_is_gated_but_promotable() {
+        let role = Arc::new(RoleState::new(BackendRole::Follower));
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/api/query").await,
+            StatusCode::MISDIRECTED_REQUEST,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "GET", "/instance_name").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "GET", "/instance_version").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "GET", "/instance/leadership").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/instance/promote").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role), "POST", "/instance/demote").await,
+            StatusCode::OK,
+        );
+    }
+
+    #[tokio::test]
+    async fn demoted_leader_is_gated_then_repromotable_via_one_router() {
+        let role = Arc::new(RoleState::new(BackendRole::Leader));
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/api/query").await,
+            StatusCode::OK,
+        );
+        assert!(matches!(
+            role.begin_demotion(),
+            super::DemotionAttempt::Started
+        ));
+        role.finish_demotion_success();
+        assert!(!role.is_leader());
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/api/query").await,
+            StatusCode::MISDIRECTED_REQUEST,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/instance/promote").await,
+            StatusCode::OK,
+        );
+        assert!(matches!(
+            role.begin_promotion(),
+            super::PromotionAttempt::Started
+        ));
+        role.finish_promotion_success();
+        assert!(role.is_leader());
+        assert_eq!(
+            status_of(gated_router(role), "POST", "/api/query").await,
+            StatusCode::OK,
+        );
+    }
+}
+
+#[cfg(test)]
+mod role_state_tests {
+    use common::types::BackendRole;
+
+    use super::{
+        DemotionAttempt,
+        PromotionAttempt,
+        RoleState,
+    };
+
+    #[test]
+    fn follower_starts_not_leader() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(!rs.is_leader());
+        assert_eq!(rs.current(), BackendRole::Follower);
+    }
+
+    #[test]
+    fn leader_starts_leader() {
+        let rs = RoleState::new(BackendRole::Leader);
+        assert!(rs.is_leader());
+        assert_eq!(rs.current(), BackendRole::Leader);
+    }
+
+    #[test]
+    fn promote_then_demote_round_trips() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+        assert!(!rs.is_leader());
+        rs.finish_promotion_success();
+        assert!(rs.is_leader());
+        assert!(matches!(rs.begin_demotion(), DemotionAttempt::Started));
+        assert!(!rs.is_leader());
+        assert_eq!(rs.current(), BackendRole::Follower);
+        rs.finish_demotion_success();
+        assert!(!rs.is_leader());
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+        rs.finish_promotion_success();
+        assert!(rs.is_leader());
+    }
+
+    #[test]
+    fn demote_is_idempotent_and_fenced() {
+        let rs = RoleState::new(BackendRole::Leader);
+        assert!(matches!(rs.begin_demotion(), DemotionAttempt::Started));
+        assert!(matches!(
+            rs.begin_demotion(),
+            DemotionAttempt::AlreadyInProgress
+        ));
+        rs.finish_demotion_success();
+        assert!(matches!(
+            rs.begin_demotion(),
+            DemotionAttempt::AlreadyFollower
+        ));
+    }
+
+    #[test]
+    fn cannot_demote_a_plain_follower() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(matches!(
+            rs.begin_demotion(),
+            DemotionAttempt::AlreadyFollower
+        ));
+        assert!(!rs.is_leader());
+    }
+
+    #[test]
+    fn promote_is_idempotent() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+        assert!(matches!(
+            rs.begin_promotion(),
+            PromotionAttempt::AlreadyInProgress
+        ));
+        rs.finish_promotion_success();
+        assert!(matches!(
+            rs.begin_promotion(),
+            PromotionAttempt::AlreadyLeader
+        ));
+    }
+
+    #[test]
+    fn aborted_promotion_returns_to_follower() {
+        let rs = RoleState::new(BackendRole::Follower);
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+        rs.abort_promotion();
+        assert!(!rs.is_leader());
+        assert!(matches!(rs.begin_promotion(), PromotionAttempt::Started));
+    }
+}
