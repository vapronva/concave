+#[derive(Serialize)]
+pub struct PromoteResponse {
+    pub role: String,
+    pub is_leader: bool,
+    pub message: String,
+}
+
+pub async fn promote(headers: http::HeaderMap, MtState(st): MtState<LocalAppState>) -> Response {
+    if let Some(rejection) = reject_unauthorized_control_plane(&st, &headers) {
+        return rejection;
+    }
+    let Some(promote_ctx) = st.promote_ctx.clone() else {
+        return (
+            StatusCode::OK,
+            axum::Json(PromoteResponse {
+                role: st.role.as_str().to_string(),
+                is_leader: st.role.is_leader(),
+                message: "already leader; nothing to promote".to_string(),
+            }),
+        )
+            .into_response();
+    };
+    match st.role.begin_promotion() {
+        PromotionAttempt::AlreadyLeader => {
+            return (
+                StatusCode::OK,
+                axum::Json(PromoteResponse {
+                    role: "leader".to_string(),
+                    is_leader: true,
+                    message: "already leader".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        PromotionAttempt::AlreadyInProgress => {
+            return (
+                StatusCode::ACCEPTED,
+                axum::Json(PromoteResponse {
+                    role: "follower".to_string(),
+                    is_leader: false,
+                    message: "promotion already in progress".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        PromotionAttempt::Started => {},
+    }
+    tracing::info!("[promote] received POST /instance/promote; acquiring read-write lease");
+    let rw_persistence = match (promote_ctx.persistence_factory)().await {
+        Ok(p) => p,
+        Err(e) => {
+            tracing::warn!("[promote] lease acquire FAILED; staying follower (no steal): {e:#}");
+            st.role.abort_promotion();
+            return (
+                StatusCode::SERVICE_UNAVAILABLE,
+                axum::Json(PromoteResponse {
+                    role: "follower".to_string(),
+                    is_leader: false,
+                    message: format!("could not acquire lease (leader still alive?): {e:#}"),
+                }),
+            )
+                .into_response();
+        },
+    };
+    tracing::info!("[promote] lease acquired; promoting in-process (point of no return)");
+    match st
+        .application
+        .become_leader(
+            rw_persistence.clone(),
+            promote_ctx.retention_rate_limiter.clone(),
+            promote_ctx.preempt_signal.clone(),
+        )
+        .await
+    {
+        Ok(()) => {
+            st.leader_handle.set_rw_persistence(rw_persistence.clone());
+            install_lease_lost_handler(&st, rw_persistence);
+            st.role.finish_promotion_success();
+            tracing::info!("[promote] promotion SUCCESS; now serving as leader");
+            (
+                StatusCode::OK,
+                axum::Json(PromoteResponse {
+                    role: "leader".to_string(),
+                    is_leader: true,
+                    message: "promoted to leader".to_string(),
+                }),
+            )
+                .into_response()
+        },
+        Err(e) => {
+            tracing::error!("[promote] promotion FAILED after lease acquire (fatal): {e:#}");
+            (
+                StatusCode::INTERNAL_SERVER_ERROR,
+                axum::Json(PromoteResponse {
+                    role: "follower".to_string(),
+                    is_leader: false,
+                    message: format!("promotion failed after lease acquire (restarting): {e:#}"),
+                }),
+            )
+                .into_response()
+        },
+    }
+}
+
+#[derive(Serialize)]
+pub struct DemoteResponse {
+    pub role: String,
+    pub is_leader: bool,
+    pub message: String,
+}
+
+pub async fn demote<S>(headers: http::HeaderMap, MtState(st): MtState<LocalAppState>) -> Response
+where
+    LocalAppState: FromMtState<S>,
+{
+    if let Some(rejection) = reject_unauthorized_control_plane(&st, &headers) {
+        return rejection;
+    }
+    match st.role.begin_demotion() {
+        DemotionAttempt::AlreadyFollower => {
+            return (
+                StatusCode::CONFLICT,
+                axum::Json(DemoteResponse {
+                    role: "follower".to_string(),
+                    is_leader: false,
+                    message: "already a follower; nothing to demote".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        DemotionAttempt::AlreadyInProgress => {
+            return (
+                StatusCode::CONFLICT,
+                axum::Json(DemoteResponse {
+                    role: "follower".to_string(),
+                    is_leader: false,
+                    message: "demotion already in progress".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        DemotionAttempt::Started => {},
+    }
+    let Some(rw_persistence) = st.leader_handle.rw_persistence() else {
+        tracing::error!(
+            "[demote] role was Leader but no RW persistence handle present; firing preempt"
+        );
+        st.leader_handle.preempt_signal.signal(anyhow::anyhow!(
+            "demote requested but leader had no RW persistence handle"
+        ));
+        return (
+            StatusCode::INTERNAL_SERVER_ERROR,
+            axum::Json(DemoteResponse {
+                role: "follower".to_string(),
+                is_leader: false,
+                message: "no RW persistence handle (restarting)".to_string(),
+            }),
+        )
+            .into_response();
+    };
+    tracing::info!("[demote] received POST /instance/demote; stepping down in-process");
+    match st.application.become_follower(rw_persistence).await {
+        Ok(()) => {
+            st.leader_handle.clear_rw_persistence();
+            st.role.finish_demotion_success();
+            tracing::info!("[demote] demotion SUCCESS; now a warm follower");
+            (
+                StatusCode::OK,
+                axum::Json(DemoteResponse {
+                    role: "follower".to_string(),
+                    is_leader: false,
+                    message: "demoted to follower".to_string(),
+                }),
+            )
+                .into_response()
+        },
+        Err(e) => {
+            tracing::error!(
+                "[demote] demotion FAILED (firing preempt, restart-as-follower): {e:#}"
+            );
+            st.leader_handle
+                .preempt_signal
+                .signal(anyhow::anyhow!("in-process demotion failed: {e:#}"));
+            (
+                StatusCode::INTERNAL_SERVER_ERROR,
+                axum::Json(DemoteResponse {
+                    role: "follower".to_string(),
+                    is_leader: false,
+                    message: format!("demotion failed (restarting): {e:#}"),
+                }),
+            )
+                .into_response()
+        },
+    }
+}
+
+pub(crate) fn install_lease_lost_handler(st: &LocalAppState, rw_persistence: Arc<dyn Persistence>) {
+    let role = st.role.clone();
+    let application = st.application.clone();
+    let leader_handle = st.leader_handle.clone();
+    let handler: database::LeaseLostHandler = Arc::new(move || {
+        let role = role.clone();
+        let application = application.clone();
+        let leader_handle = leader_handle.clone();
+        let rw_persistence = rw_persistence.clone();
+        Box::pin(async move {
+            match role.begin_demotion() {
+                DemotionAttempt::Started => {},
+                _ => return true,
+            }
+            match application.become_follower(rw_persistence).await {
+                Ok(()) => {
+                    leader_handle.clear_rw_persistence();
+                    role.finish_demotion_success();
+                    tracing::info!(
+                        "[lease-watch] in-process self-demote SUCCESS; now a warm follower"
+                    );
+                    true
+                },
+                Err(e) => {
+                    tracing::error!("[lease-watch] in-process self-demote failed: {e:#}");
+                    false
+                },
+            }
+        })
+    });
+    st.application.database().set_lease_lost_handler(handler);
+}
+
+pub fn leadership_routes<S>() -> Router<S>
+where
+    LocalAppState: FromMtState<S>,
+    S: Clone + Send + Sync + 'static,
+{
+    Router::new()
+        .route("/instance/leadership", get(leadership::<S>))
+        .route("/instance/demote", post(demote::<S>))
+}
+
+pub fn follower_router(st: LocalAppState) -> Router {
+    let role = st.role.clone();
+    let promote_route = Router::new()
+        .route("/instance/promote", post(promote))
+        .with_state(st.clone());
+    crate::router::router(st)
+        .merge(promote_route)
+        .layer(axum::middleware::from_fn_with_state(role, role_gate))
+}
+
+fn is_gate_exempt(path: &str) -> bool {
+    matches!(
+        path,
+        "/" | "/echo"
+            | "/instance_name"
+            | "/instance_version"
+            | "/instance/leadership"
+            | "/instance/promote"
+            | "/instance/demote"
+    )
+}
+
+async fn role_gate(
+    axum::extract::State(role): axum::extract::State<Arc<RoleState>>,
+    req: Request<Body>,
+    next: Next,
+) -> Response {
+    if role.is_leader() || is_gate_exempt(req.uri().path()) {
+        next.run(req).await
+    } else {
+        (
+            StatusCode::MISDIRECTED_REQUEST,
+            "This backend is a follower (warm standby) and does not serve client traffic. Route \
+             to the leader (or POST /instance/promote to promote it).",
+        )
+            .into_response()
+    }
+}
