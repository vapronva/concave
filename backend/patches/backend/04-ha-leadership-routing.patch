+const CONTROL_PLANE_TOKEN_HEADER: &str = "X-Convex-Control-Plane-Token";
+
+pub struct RoleState {
+    role: AtomicU8,
+}
+
+const ROLE_FOLLOWER: u8 = 0;
+const ROLE_PROMOTING: u8 = 1;
+const ROLE_LEADER: u8 = 2;
+const ROLE_DEMOTING: u8 = 3;
+
+fn reject_unauthorized_control_plane(
+    control_plane_token: &Option<Arc<String>>,
+    headers: &http::HeaderMap,
+) -> Option<Response> {
+    let Some(expected) = control_plane_token.as_ref() else {
+        return Some(
+            (
+                StatusCode::FORBIDDEN,
+                "Control plane is disabled because CONVEX_CONTROL_PLANE_TOKEN is unset.",
+            )
+                .into_response(),
+        );
+    };
+    let presented = headers
+        .get(CONTROL_PLANE_TOKEN_HEADER)
+        .map(|v| v.as_bytes())
+        .unwrap_or_default();
+    if keybroker::constant_time_eq_sha256(presented, expected.as_bytes()) {
+        None
+    } else {
+        Some(
+            (
+                StatusCode::FORBIDDEN,
+                "Missing or invalid X-Convex-Control-Plane-Token.",
+            )
+                .into_response(),
+        )
+    }
+}
+
+impl RoleState {
+    pub fn new(role: BackendRole) -> Self {
+        let v = match role {
+            BackendRole::Leader => ROLE_LEADER,
+            BackendRole::Follower => ROLE_FOLLOWER,
+        };
+        Self {
+            role: AtomicU8::new(v),
+        }
+    }
+
+    pub fn current(&self) -> BackendRole {
+        match self.role.load(Ordering::SeqCst) {
+            ROLE_LEADER => BackendRole::Leader,
+            _ => BackendRole::Follower,
+        }
+    }
+
+    pub fn is_leader(&self) -> bool {
+        self.role.load(Ordering::SeqCst) == ROLE_LEADER
+    }
+
+    fn begin_promotion(&self) -> PromotionAttempt {
+        match self.role.compare_exchange(
+            ROLE_FOLLOWER,
+            ROLE_PROMOTING,
+            Ordering::SeqCst,
+            Ordering::SeqCst,
+        ) {
+            Ok(_) => PromotionAttempt::Started,
+            Err(ROLE_PROMOTING) => PromotionAttempt::AlreadyInProgress,
+            Err(ROLE_LEADER) => PromotionAttempt::AlreadyLeader,
+            Err(ROLE_DEMOTING) => PromotionAttempt::DemotionInProgress,
+            Err(_) => PromotionAttempt::AlreadyInProgress,
+        }
+    }
+
+    fn finish_promotion_success(&self) -> bool {
+        self.role
+            .compare_exchange(
+                ROLE_PROMOTING,
+                ROLE_LEADER,
+                Ordering::SeqCst,
+                Ordering::SeqCst,
+            )
+            .is_ok()
+    }
+
+    fn abort_promotion(&self) {
+        let _ = self.role.compare_exchange(
+            ROLE_PROMOTING,
+            ROLE_FOLLOWER,
+            Ordering::SeqCst,
+            Ordering::SeqCst,
+        );
+    }
+
+    pub(crate) fn begin_demotion(&self) -> DemotionAttempt {
+        match self.role.compare_exchange(
+            ROLE_LEADER,
+            ROLE_DEMOTING,
+            Ordering::SeqCst,
+            Ordering::SeqCst,
+        ) {
+            Ok(_) => DemotionAttempt::Started,
+            Err(ROLE_DEMOTING) => DemotionAttempt::AlreadyInProgress,
+            Err(ROLE_PROMOTING) => DemotionAttempt::PromotionInProgress,
+            Err(ROLE_FOLLOWER) => DemotionAttempt::AlreadyFollower,
+            Err(_) => DemotionAttempt::AlreadyFollower,
+        }
+    }
+
+    pub(crate) fn finish_demotion_success(&self) {
+        self.role.store(ROLE_FOLLOWER, Ordering::SeqCst);
+    }
+}
+
+enum PromotionAttempt {
+    Started,
+    AlreadyInProgress,
+    AlreadyLeader,
+    DemotionInProgress,
+}
+
+pub(crate) enum DemotionAttempt {
+    Started,
+    AlreadyInProgress,
+    AlreadyFollower,
+    PromotionInProgress,
+}
+
+pub type PersistenceFactory =
+    Arc<dyn Fn() -> BoxFuture<'static, anyhow::Result<Arc<dyn Persistence>>> + Send + Sync>;
+
+pub struct PromoteContext {
+    pub persistence_factory: PersistenceFactory,
+    pub preempt_signal: ShutdownSignal,
+    pub retention_rate_limiter: Arc<RateLimiter<ProdRuntime>>,
+}
+
+#[derive(Clone)]
+pub struct LeaderHandle {
+    rw_persistence: Arc<parking_lot::Mutex<Option<Arc<dyn Persistence>>>>,
+    pub preempt_signal: ShutdownSignal,
+}
+
+impl LeaderHandle {
+    pub fn for_leader(
+        rw_persistence: Arc<dyn Persistence>,
+        preempt_signal: ShutdownSignal,
+    ) -> Self {
+        Self {
+            rw_persistence: Arc::new(parking_lot::Mutex::new(Some(rw_persistence))),
+            preempt_signal,
+        }
+    }
+
+    pub fn for_follower(preempt_signal: ShutdownSignal) -> Self {
+        Self {
+            rw_persistence: Arc::new(parking_lot::Mutex::new(None)),
+            preempt_signal,
+        }
+    }
+
+    pub fn lease_ts(&self) -> Option<u64> {
+        self.rw_persistence
+            .lock()
+            .as_ref()
+            .and_then(|p| p.lease_ts())
+    }
+
+    pub fn rw_persistence(&self) -> Option<Arc<dyn Persistence>> {
+        self.rw_persistence.lock().clone()
+    }
+
+    pub fn set_rw_persistence(&self, persistence: Arc<dyn Persistence>) {
+        *self.rw_persistence.lock() = Some(persistence);
+    }
+
+    pub fn clear_rw_persistence(&self) {
+        *self.rw_persistence.lock() = None;
+    }
+}
+
+#[derive(Serialize)]
+pub struct LeadershipResponse {
+    pub role: String,
+    pub is_leader: bool,
+    pub lease_ts: Option<u64>,
+    pub latest_ts: u64,
+}
+
+pub async fn leadership<S>(MtState(st): MtState<LocalAppState>) -> Response
+where
+    LocalAppState: FromMtState<S>,
+{
+    let latest_ts: Timestamp = *st.application.now_ts_for_reads();
+    let lease_ts = st.leader_handle.lease_ts();
+    axum::Json(LeadershipResponse {
+        role: st.role.current().as_str().to_string(),
+        is_leader: st.role.is_leader(),
+        lease_ts,
+        latest_ts: u64::from(latest_ts),
+    })
+    .into_response()
+}
+
+pub async fn readyz<S>(MtState(st): MtState<LocalAppState>) -> Response
+where
+    LocalAppState: FromMtState<S>,
+{
+    let healthy = match st.configured_role {
+        BackendRole::Leader => st.role.is_leader(),
+        BackendRole::Follower => !st.role.is_leader(),
+    };
+    if healthy {
+        (StatusCode::OK, "ready").into_response()
+    } else {
+        (
+            StatusCode::SERVICE_UNAVAILABLE,
+            "not ready for configured role",
+        )
+            .into_response()
+    }
+}
+
+#[derive(Serialize)]
+pub struct PromoteResponse {
+    pub role: String,
+    pub is_leader: bool,
+    pub message: String,
+}
+
+pub async fn promote<S>(MtState(st): MtState<LocalAppState>) -> Response
+where
+    LocalAppState: FromMtState<S>,
+{
+    let promote_ctx = st.promote_ctx.clone();
+    match st.role.begin_promotion() {
+        PromotionAttempt::AlreadyLeader => {
+            return (
+                StatusCode::OK,
+                axum::Json(PromoteResponse {
+                    role: BackendRole::Leader.as_str().to_string(),
+                    is_leader: true,
+                    message: "already leader".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        PromotionAttempt::AlreadyInProgress => {
+            return (
+                StatusCode::ACCEPTED,
+                axum::Json(PromoteResponse {
+                    role: BackendRole::Follower.as_str().to_string(),
+                    is_leader: false,
+                    message: "promotion already in progress".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        PromotionAttempt::DemotionInProgress => {
+            return (
+                StatusCode::CONFLICT,
+                axum::Json(PromoteResponse {
+                    role: BackendRole::Follower.as_str().to_string(),
+                    is_leader: false,
+                    message: "a demotion is in progress; retry after it completes".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        PromotionAttempt::Started => {},
+    }
+    let runtime = st.application.runtime();
+    runtime.spawn_background("in_process_promotion", async move {
+        perform_promotion(st, promote_ctx).await;
+    });
+    (
+        StatusCode::ACCEPTED,
+        axum::Json(PromoteResponse {
+            role: BackendRole::Follower.as_str().to_string(),
+            is_leader: false,
+            message: "promotion started".to_string(),
+        }),
+    )
+        .into_response()
+}
+
+async fn perform_promotion(st: LocalAppState, promote_ctx: Arc<PromoteContext>) {
+    tracing::info!("[concave] promotion started; acquiring read-write lease");
+    let rw_persistence = match (promote_ctx.persistence_factory)().await {
+        Ok(p) => p,
+        Err(e) => {
+            tracing::warn!("[concave] promotion lease acquisition failed; staying follower: {e:#}");
+            st.role.abort_promotion();
+            return;
+        },
+    };
+    tracing::info!("[concave] promotion lease acquired; promoting in-process");
+    install_lease_lost_handler(&st, rw_persistence.clone());
+    match st
+        .application
+        .become_leader(
+            rw_persistence.clone(),
+            promote_ctx.retention_rate_limiter.clone(),
+            promote_ctx.preempt_signal.clone(),
+        )
+        .await
+    {
+        Ok(()) => {
+            st.leader_handle.set_rw_persistence(rw_persistence);
+            if st.role.finish_promotion_success() {
+                tracing::info!("[concave] promotion succeeded; now serving as leader");
+            } else {
+                tracing::error!(
+                    "[concave] promotion preempted (lease lost mid-promote); restarting"
+                );
+                st.leader_handle.preempt_signal.signal(anyhow::anyhow!(
+                    "promotion preempted: lease lost mid-promote"
+                ));
+            }
+        },
+        Err(e) => {
+            tracing::error!("[concave] promotion failed after lease acquisition: {e:#}");
+            if let Err(release_err) = rw_persistence.release_lease().await {
+                tracing::warn!(
+                    "[concave] failed to release the lease after a failed promotion (the next \
+                     acquirer steals it anyway): {release_err:#}"
+                );
+            }
+            st.leader_handle.preempt_signal.signal(anyhow::anyhow!(
+                "in-process promotion failed after acquiring the lease: {e:#}"
+            ));
+        },
+    }
+}
+
+#[derive(Serialize)]
+pub struct DemoteResponse {
+    pub role: String,
+    pub is_leader: bool,
+    pub message: String,
+}
+
+pub async fn demote<S>(MtState(st): MtState<LocalAppState>) -> Response
+where
+    LocalAppState: FromMtState<S>,
+{
+    match st.role.begin_demotion() {
+        DemotionAttempt::AlreadyFollower => {
+            return (
+                StatusCode::CONFLICT,
+                axum::Json(DemoteResponse {
+                    role: BackendRole::Follower.as_str().to_string(),
+                    is_leader: false,
+                    message: "already a follower; nothing to demote".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        DemotionAttempt::AlreadyInProgress => {
+            return (
+                StatusCode::CONFLICT,
+                axum::Json(DemoteResponse {
+                    role: BackendRole::Follower.as_str().to_string(),
+                    is_leader: false,
+                    message: "demotion already in progress".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        DemotionAttempt::PromotionInProgress => {
+            return (
+                StatusCode::CONFLICT,
+                axum::Json(DemoteResponse {
+                    role: BackendRole::Follower.as_str().to_string(),
+                    is_leader: false,
+                    message: "a promotion is in progress; retry after it completes".to_string(),
+                }),
+            )
+                .into_response();
+        },
+        DemotionAttempt::Started => {},
+    }
+    let Some(rw_persistence) = st.leader_handle.rw_persistence() else {
+        tracing::error!(
+            "[concave] role was Leader but no RW persistence handle present; firing preempt"
+        );
+        st.leader_handle.preempt_signal.signal(anyhow::anyhow!(
+            "demote requested but leader had no RW persistence handle"
+        ));
+        return (
+            StatusCode::INTERNAL_SERVER_ERROR,
+            axum::Json(DemoteResponse {
+                role: BackendRole::Follower.as_str().to_string(),
+                is_leader: false,
+                message: "no RW persistence handle (restarting)".to_string(),
+            }),
+        )
+            .into_response();
+    };
+    let runtime = st.application.runtime();
+    st.application.database().stop_lease_watch();
+    runtime.spawn_background("in_process_demotion", async move {
+        perform_demotion(st, rw_persistence).await;
+    });
+    (
+        StatusCode::ACCEPTED,
+        axum::Json(DemoteResponse {
+            role: BackendRole::Follower.as_str().to_string(),
+            is_leader: false,
+            message: "demotion started".to_string(),
+        }),
+    )
+        .into_response()
+}
+
+async fn perform_demotion(st: LocalAppState, rw_persistence: Arc<dyn Persistence>) {
+    tracing::info!("[concave] demotion started; stepping down in-process");
+    match st.application.become_follower(rw_persistence).await {
+        Ok(()) => {
+            st.leader_handle.clear_rw_persistence();
+            st.role.finish_demotion_success();
+            tracing::info!("[concave] demotion succeeded; now a warm follower");
+        },
+        Err(e) => {
+            tracing::error!(
+                "[concave] demotion FAILED (firing preempt, restart-as-follower): {e:#}"
+            );
+            st.leader_handle
+                .preempt_signal
+                .signal(anyhow::anyhow!("in-process demotion failed: {e:#}"));
+        },
+    }
+}
+
+pub(crate) fn install_lease_lost_handler(st: &LocalAppState, rw_persistence: Arc<dyn Persistence>) {
+    let role = st.role.clone();
+    let application = st.application.clone();
+    let leader_handle = st.leader_handle.clone();
+    let handler: database::LeaseLostHandler = Arc::new(move || {
+        let role = role.clone();
+        let application = application.clone();
+        let leader_handle = leader_handle.clone();
+        let rw_persistence = rw_persistence.clone();
+        Box::pin(async move {
+            match role.begin_demotion() {
+                DemotionAttempt::Started => {},
+                DemotionAttempt::AlreadyFollower => return true,
+                DemotionAttempt::AlreadyInProgress => return true,
+                DemotionAttempt::PromotionInProgress => return false,
+            }
+            match application.become_follower(rw_persistence).await {
+                Ok(()) => {
+                    leader_handle.clear_rw_persistence();
+                    role.finish_demotion_success();
+                    tracing::info!("[concave] in-process self-demote SUCCESS; now a warm follower");
+                    true
+                },
+                Err(e) => {
+                    tracing::error!("[concave] in-process self-demote failed: {e:#}");
+                    false
+                },
+            }
+        })
+    });
+    st.application.database().set_lease_lost_handler(handler);
+}
+
+async fn control_plane_gate(
+    axum::extract::State(control_plane_token): axum::extract::State<Option<Arc<String>>>,
+    headers: http::HeaderMap,
+    req: Request<Body>,
+    next: Next,
+) -> Response {
+    if let Some(rejection) = reject_unauthorized_control_plane(&control_plane_token, &headers) {
+        return rejection;
+    }
+    next.run(req).await
+}
+
+pub fn leadership_routes<S>(control_plane_token: Option<Arc<String>>) -> Router<S>
+where
+    LocalAppState: FromMtState<S>,
+    S: Clone + Send + Sync + 'static,
+{
+    let control = Router::new()
+        .route("/instance/promote", post(promote::<S>))
+        .route("/instance/demote", post(demote::<S>))
+        .layer(axum::middleware::from_fn_with_state(
+            control_plane_token,
+            control_plane_gate,
+        ));
+    Router::new()
+        .route("/instance/leadership", get(leadership::<S>))
+        .merge(control)
+}
+
+pub fn follower_router(st: LocalAppState) -> Router {
+    let role = st.role.clone();
+    crate::router::router(st).layer(axum::middleware::from_fn_with_state(role, role_gate))
+}
+
+fn is_gate_exempt(path: &str) -> bool {
+    matches!(
+        path,
+        "/" | "/readyz"
+            | "/instance/leadership"
+            | "/instance/promote"
+            | "/instance/demote"
+            | "/instance_name"
+            | "/instance_version"
+    )
+}
+
+async fn role_gate(
+    axum::extract::State(role): axum::extract::State<Arc<RoleState>>,
+    req: Request<Body>,
+    next: Next,
+) -> Response {
+    if role.is_leader() || is_gate_exempt(req.uri().path()) {
+        next.run(req).await
+    } else {
+        (
+            StatusCode::MISDIRECTED_REQUEST,
+            "This backend is a follower (warm standby) and does not serve client traffic. Route \
+             to the leader (or POST /instance/promote to promote it).",
+        )
+            .into_response()
+    }
+}
