+    #[tokio::test]
+    async fn follower_runtime_role_is_gated_but_promotable() {
+        let role = Arc::new(RoleState::new(BackendRole::Follower));
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/api/query").await,
+            StatusCode::MISDIRECTED_REQUEST,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "GET", "/instance/leadership").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/instance/promote").await,
+            StatusCode::OK,
+        );
+        assert_eq!(
+            status_of(gated_router(role), "POST", "/instance/demote").await,
+            StatusCode::OK,
+        );
+    }
+
+    #[tokio::test]
+    async fn demoted_leader_is_gated_then_repromotable_via_one_router() {
+        let role = Arc::new(RoleState::new(BackendRole::Leader));
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/api/query").await,
+            StatusCode::OK,
+        );
+        assert!(matches!(
+            role.begin_demotion(),
+            super::DemotionAttempt::Started
+        ));
+        role.finish_demotion_success();
+        assert!(!role.is_leader());
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/api/query").await,
+            StatusCode::MISDIRECTED_REQUEST,
+        );
+        assert_eq!(
+            status_of(gated_router(role.clone()), "POST", "/instance/promote").await,
+            StatusCode::OK,
+        );
+        assert!(matches!(
+            role.begin_promotion(),
+            super::PromotionAttempt::Started
+        ));
+        role.finish_promotion_success();
+        assert!(role.is_leader());
+        assert_eq!(
+            status_of(gated_router(role), "POST", "/api/query").await,
+            StatusCode::OK,
+        );
+    }
+}
