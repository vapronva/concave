+pub const fn lease_release(multitenant: bool) -> &'static str {
+    tableify!(
+        multitenant,
+        formatcp!(
+            "UPDATE @db_name.leases SET ts=$1 WHERE {column}={value} AND ts=$2",
+            column = if multitenant { "instance_name" } else { "id" },
+            value = if multitenant { "$3" } else { "1" }
+        )
+    )
+}
