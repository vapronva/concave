+    tableify!(
+        multitenant,
+        formatcp!(
+            "SELECT 1 FROM @db_name.leases WHERE {column}={value} LIMIT 1",
+            column = if multitenant { "instance_name" } else { "id" },
+            value = if multitenant { "$1" } else { "1" }
+        )
+    )
