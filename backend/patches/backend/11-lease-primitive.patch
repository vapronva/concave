-// Acquire the lease unless acquire by someone with a higher timestamp.
+// Acquire the lease, bumping ts to GREATEST(now, current+1) so it stays
+// strictly monotonic and a future-dated predecessor (clock skew) can't stall
+// promotion; safety is the commit-time fence (lease_release/transact pin ts),
+// not this.
 pub const fn lease_acquire(multitenant: bool) -> &'static str {
     tableify!(
         multitenant,
         formatcp!(
-            "UPDATE @db_name.leases SET ts=$1 WHERE {column}={value} AND ts<$1",
+            "UPDATE @db_name.leases SET ts=GREATEST($1, ts+1) WHERE {column}={value} RETURNING ts",
+            column = if multitenant { "instance_name" } else { "id" },
+            value = if multitenant { "$2" } else { "1" }
+        )
+    )
+}
