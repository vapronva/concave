+#[cfg(test)]
+mod lease_sql_tests {
+    use super::{
+        advisory_lease_check,
+        lease_acquire,
+        lease_release,
+    };
+
+    #[test]
+    fn lease_release_is_a_guarded_lower_of_ts_single_tenant() {
+        assert_eq!(
+            lease_release(false),
+            "UPDATE @db_name.leases SET ts=$1 WHERE id=1 AND ts=$2",
+        );
+    }
+
+    #[test]
+    fn lease_release_is_instance_scoped_multitenant() {
+        assert_eq!(
+            lease_release(true),
+            "UPDATE @db_name.leases SET ts=$1 WHERE instance_name=$3 AND ts=$2",
+        );
+    }
+
+    #[test]
+    fn advisory_check_is_non_locking_and_release_does_not_widen_acquire() {
+        assert_eq!(
+            advisory_lease_check(false),
+            "SELECT 1 FROM @db_name.leases WHERE id=1 AND ts=$1",
+        );
+        assert!(!advisory_lease_check(false).contains("FOR SHARE"));
+        assert!(!advisory_lease_check(false).contains("FOR UPDATE"));
+        assert_eq!(
+            lease_acquire(false),
+            "UPDATE @db_name.leases SET ts=$1 WHERE id=1 AND ts<$1",
+        );
+    }
+}
