+
+    use super::SqlitePersistence;
+
+    #[tokio::test]
+    async fn non_lease_persistence_uses_safe_defaults() {
+        let tmp = TempDir::new().unwrap();
+        let path = tmp.path().join("lease_defaults.sqlite3");
+        let p = SqlitePersistence::new(path.to_str().unwrap()).unwrap();
+        assert_eq!(p.lease_ts(), None);
