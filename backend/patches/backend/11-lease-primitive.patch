+
+    async fn lease_held(&self) -> anyhow::Result<bool> {
+        let lease_ts = self.lease_ts;
+        let mut client = self
+            .pool
+            .get_connection("lease_held", &self.schema, &self.instance_name)
+            .await?;
+        let multitenant = self.multitenant;
+        let instance_name = self.instance_name.clone();
+        let row = client
+            .with_retry(async move |client| {
+                let mut params = vec![&lease_ts as &(dyn ToSql + Sync)];
+                if multitenant {
+                    params.push(&instance_name.raw as &(dyn ToSql + Sync));
+                }
+                client
+                    .query_opt(sql::advisory_lease_check(multitenant), params.as_slice())
+                    .await
+            })
+            .await?;
+        Ok(row.is_some())
+    }
+
+    async fn release(&self) -> anyhow::Result<bool> {
+        let held_ts = self.lease_ts;
+        let release_ts = held_ts.saturating_sub(1);
+        let mut client = self
+            .pool
+            .get_connection("lease_release", &self.schema, &self.instance_name)
+            .await?;
+        let multitenant = self.multitenant;
+        let instance_name = self.instance_name.clone();
+        let rows_modified = client
+            .with_retry(async move |client| {
+                let stmt = client
+                    .prepare_cached(sql::lease_release(multitenant))
+                    .await?;
+                let mut params = vec![
+                    &release_ts as &(dyn ToSql + Sync),
+                    &held_ts as &(dyn ToSql + Sync),
+                ];
+                if multitenant {
+                    params.push(&instance_name.raw as &(dyn ToSql + Sync));
+                }
+                client.execute(&stmt, params.as_slice()).await
+            })
+            .await?;
+        if rows_modified == 1 {
+            tracing::info!("lease released (ts {held_ts} -> {release_ts}); peer may take over");
+            Ok(true)
+        } else {
+            tracing::info!("lease release no-op: already lost (held ts {held_ts})");
+            Ok(false)
+        }
+    }
