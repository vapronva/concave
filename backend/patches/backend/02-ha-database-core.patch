+    pub fn spawn_lease_watch(
+        &self,
+        rw_persistence: Arc<dyn Persistence>,
+        preempt_signal: ShutdownSignal,
+    ) {
+        let runtime = self.runtime.clone();
+        let handler = self.lease_lost_handler.clone();
+        let worker = async move {
+            const MAX_NON_TRANSIENT_PROBE_FAILURES: usize = 3;
+            const TRANSIENT_HEARTBEAT_EVERY: usize = 20;
+            let mut non_transient_failures = 0;
+            let mut transient_failures: usize = 0;
+            let mut first_probe = true;
+            loop {
+                if !first_probe {
+                    runtime.wait(*LEASE_WATCH_POLL_INTERVAL).await;
+                }
+                first_probe = false;
+                let held = match rw_persistence.lease_held().await {
+                    Ok(held) => {
+                        non_transient_failures = 0;
+                        transient_failures = 0;
+                        held
+                    },
+                    Err(e) => {
+                        if common::errors::is_transient_db_error(&e) {
+                            non_transient_failures = 0;
+                            transient_failures += 1;
+                            if transient_failures % TRANSIENT_HEARTBEAT_EVERY == 0 {
+                                tracing::warn!(
+                                    "[lease-watch] {transient_failures} consecutive transient \
+                                     probe errors; lease ownership unverified: {e:#}"
+                                );
+                            }
+                        } else {
+                            transient_failures = 0;
+                            non_transient_failures += 1;
+                            if non_transient_failures >= MAX_NON_TRANSIENT_PROBE_FAILURES {
+                                tracing::error!(
+                                    "[lease-watch] probe failed {non_transient_failures} times \
+                                     with non-transient errors; firing preempt: {e:#}"
+                                );
