@@ -0,0 +1,436 @@
+use std::{
+    ops::Bound,
+    sync::Arc,
+    time::Duration,
+};
+
+use common::{
+    document::DocumentUpdate,
+    errors::{
+        is_transient_db_error,
+        report_error,
+    },
+    knobs::MAX_REPEATABLE_TIMESTAMP_COMMIT_DELAY,
+    persistence::{
+        new_static_repeatable_recent,
+        PersistenceReader,
+        RepeatablePersistence,
+        RetentionValidator,
+        TimestampRange,
+    },
+    query::Order,
+    runtime::{
+        Runtime,
+        SpawnHandle,
+    },
+    sync::split_rw_lock::Writer,
+    types::RepeatableTimestamp,
+    value::TableNamespace,
+    virtual_system_mapping::VirtualSystemMapping,
+};
+use errors::ErrorMetadataAnyhowExt;
+use futures::{
+    select_biased,
+    FutureExt,
+    TryStreamExt,
+};
+use sync_types::backoff::Backoff;
+use tokio::sync::oneshot;
+
+use crate::{
+    bootstrap_model::defaults::BootstrapTableIds,
+    persistence_helpers::stream_transactions,
+    search_index_bootstrap::bootstrap_search_indexes,
+    snapshot_manager::SnapshotManager,
+    DatabaseSnapshot,
+};
+
+const INITIAL_BACKOFF: Duration = Duration::from_secs(1);
+const MAX_BACKOFF: Duration = Duration::from_secs(60);
+
+pub struct PromotedTailerState {
+    pub writer: Writer<SnapshotManager>,
+    pub tailed_ts: RepeatableTimestamp,
+}
+
+type PromoteRequest = oneshot::Sender<anyhow::Result<PromotedTailerState>>;
+
+pub struct FollowerTailerHandle {
+    promote_tx: Option<oneshot::Sender<PromoteRequest>>,
+    join: Box<dyn SpawnHandle>,
+}
+
+impl FollowerTailerHandle {
+    pub async fn promote(mut self) -> anyhow::Result<PromotedTailerState> {
+        let promote_tx = self
+            .promote_tx
+            .take()
+            .ok_or_else(|| anyhow::anyhow!("follower tailer already asked to promote"))?;
+        let (reply_tx, reply_rx) = oneshot::channel();
+        promote_tx
+            .send(reply_tx)
+            .map_err(|_| anyhow::anyhow!("follower tailer exited before promotion handshake"))?;
+        let state = reply_rx
+            .await
+            .map_err(|_| anyhow::anyhow!("follower tailer dropped during promotion handshake"))??;
+        self.join.shutdown_and_join().await?;
+        Ok(state)
+    }
+
+    pub async fn shutdown(mut self) -> anyhow::Result<()> {
+        drop(self.promote_tx.take());
+        self.join.shutdown_and_join().await
+    }
+}
+
+pub struct FollowerLogTailer<RT: Runtime> {
+    runtime: RT,
+    snapshot_writer: Writer<SnapshotManager>,
+    reader: Arc<dyn PersistenceReader>,
+    retention_validator: Arc<dyn RetentionValidator>,
+    virtual_system_mapping: VirtualSystemMapping,
+    poll_interval: Duration,
+}
+
+impl<RT: Runtime> FollowerLogTailer<RT> {
+    pub fn start(
+        runtime: RT,
+        snapshot_writer: Writer<SnapshotManager>,
+        reader: Arc<dyn PersistenceReader>,
+        retention_validator: Arc<dyn RetentionValidator>,
+        virtual_system_mapping: VirtualSystemMapping,
+        tailed_ts: RepeatableTimestamp,
+        already_warm: bool,
+    ) -> FollowerTailerHandle {
+        let poll_interval = *MAX_REPEATABLE_TIMESTAMP_COMMIT_DELAY / 2;
+        let worker = Self {
+            runtime: runtime.clone(),
+            snapshot_writer,
+            reader,
+            retention_validator,
+            virtual_system_mapping,
+            poll_interval,
+        };
+        let (promote_tx, promote_rx) = oneshot::channel();
+        let join = runtime.spawn(
+            "follower_log_tailer",
+            worker.go(tailed_ts, already_warm, promote_rx),
+        );
+        FollowerTailerHandle {
+            promote_tx: Some(promote_tx),
+            join,
+        }
+    }
+
+    async fn go(
+        mut self,
+        mut tailed_ts: RepeatableTimestamp,
+        already_warm: bool,
+        promote_rx: oneshot::Receiver<PromoteRequest>,
+    ) {
+        let mut backoff = Backoff::new(INITIAL_BACKOFF, MAX_BACKOFF);
+        let mut promote_rx = promote_rx.fuse();
+        while !already_warm {
+            match self.bootstrap_search_into_snapshot(tailed_ts).await {
+                Ok(()) => break,
+                Err(e) if e.is_out_of_retention() => {
+                    tracing::warn!(
+                        "[follower-tailer] bootstrap ts {tailed_ts} out of retention; \
+                         cold-reloading"
+                    );
+                    match self.cold_reload().await {
+                        Ok(new_ts) => {
+                            tailed_ts = new_ts;
+                            backoff.reset();
+                        },
+                        Err(e) => {
+                            let delay = backoff.fail(&mut self.runtime.rng());
+                            report_error(
+                                &mut e.context("FollowerLogTailer bootstrap cold reload failed"),
+                            )
+                            .await;
+                            select_biased! {
+                                reply = promote_rx => {
+                                    self.handle_promote(reply, tailed_ts).await;
+                                    return;
+                                },
+                                _ = self.runtime.wait(delay) => {},
+                            }
+                        },
+                    }
+                },
+                Err(e) => {
+                    let delay = backoff.fail(&mut self.runtime.rng());
+                    report_error(&mut e.context("FollowerLogTailer search bootstrap failed")).await;
+                    tracing::error!(
+                        "[follower-tailer] search bootstrap failed (attempt {}); retrying in \
+                         {:.1}s",
+                        backoff.failures(),
+                        delay.as_secs_f32(),
+                    );
+                    select_biased! {
+                        reply = promote_rx => {
+                            self.handle_promote(reply, tailed_ts).await;
+                            return;
+                        },
+                        _ = self.runtime.wait(delay) => {},
+                    }
+                },
+            }
+        }
+        backoff.reset();
+        tracing::info!(
+            "[follower-tailer] search/vector warm at {tailed_ts}; entering tail loop (poll {:?})",
+            self.poll_interval,
+        );
+        loop {
+            let wait = match self.tail_once(&mut tailed_ts).await {
+                Ok(()) => {
+                    backoff.reset();
+                    self.poll_interval
+                },
+                Err(e) if e.is_out_of_retention() => {
+                    tracing::warn!(
+                        "[follower-tailer] tailed_ts {tailed_ts} out of retention; \
+                         cold-reloading: {e:#}"
+                    );
+                    match self.cold_reload().await {
+                        Ok(new_ts) => {
+                            tailed_ts = new_ts;
+                            backoff.reset();
+                            tracing::info!(
+                                "[follower-tailer] cold reload complete; resuming tail at \
+                                 {tailed_ts}"
+                            );
+                            Duration::ZERO
+                        },
+                        Err(e) => {
+                            let delay = backoff.fail(&mut self.runtime.rng());
+                            report_error(&mut e.context("FollowerLogTailer cold reload failed"))
+                                .await;
+                            tracing::error!(
+                                "[follower-tailer] cold reload failed (attempt {}); retrying in \
+                                 {:.1}s",
+                                backoff.failures(),
+                                delay.as_secs_f32(),
+                            );
+                            delay
+                        },
+                    }
+                },
+                Err(e) => {
+                    let delay = backoff.fail(&mut self.runtime.rng());
+                    let transient = is_transient_db_error(&e);
+                    if !transient {
+                        report_error(&mut e.context("FollowerLogTailer tail failed")).await;
+                    }
+                    tracing::error!(
+                        "[follower-tailer] tail step failed (attempt {}, transient={transient}); \
+                         retrying in {:.1}s",
+                        backoff.failures(),
+                        delay.as_secs_f32(),
+                    );
+                    delay
+                },
+            };
+            select_biased! {
+                reply = promote_rx => {
+                    self.handle_promote(reply, tailed_ts).await;
+                    return;
+                },
+                _ = self.runtime.wait(wait) => {},
+            }
+        }
+    }
+
+    async fn handle_promote(
+        mut self,
+        reply: Result<PromoteRequest, oneshot::error::RecvError>,
+        mut tailed_ts: RepeatableTimestamp,
+    ) {
+        let Ok(reply_tx) = reply else {
+            tracing::info!("[follower-tailer] promote channel closed without request; exiting");
+            return;
+        };
+        tracing::info!(
+            "[follower-tailer] promotion requested at tailed_ts {tailed_ts}; doing FINAL \
+             fast-forward to high-water"
+        );
+        let result: anyhow::Result<RepeatableTimestamp> = async {
+            let max_ts = DatabaseSnapshot::<RT>::max_ts(self.reader.as_ref()).await?;
+            if max_ts > *tailed_ts {
+                let target = RepeatableTimestamp::new_validated(
+                    max_ts,
+                    common::types::RepeatableReason::IdleMaxTs,
+                );
+                self.fast_forward_to(&mut tailed_ts, target).await?;
+            }
+            Ok(tailed_ts)
+        }
+        .await;
+        let response = match result {
+            Ok(tailed_ts) => {
+                tracing::info!(
+                    "[follower-tailer] FINAL fast-forward complete; tailed_ts {tailed_ts}"
+                );
+                Ok(PromotedTailerState {
+                    writer: self.snapshot_writer,
+                    tailed_ts,
+                })
+            },
+            Err(e) => Err(e),
+        };
+        let _ = reply_tx.send(response);
+    }
+
+    async fn fast_forward_to(
+        &mut self,
+        tailed_ts: &mut RepeatableTimestamp,
+        target: RepeatableTimestamp,
+    ) -> anyhow::Result<()> {
+        if *target <= **tailed_ts {
+            return Ok(());
+        }
+        let repeatable_persistence = RepeatablePersistence::new(
+            self.reader.clone(),
+            target,
+            self.retention_validator.clone(),
+        );
+        let bootstrap_tables = {
+            let snapshot = self.snapshot_writer.read().latest_snapshot();
+            BootstrapTableIds::new(snapshot.table_mapping())
+        };
+        let range = TimestampRange::new((Bound::Excluded(**tailed_ts), Bound::Included(*target)));
+        let transactions =
+            stream_transactions(bootstrap_tables, &repeatable_persistence, range, Order::Asc);
+        futures::pin_mut!(transactions);
+        while let Some(txn) = transactions.try_next().await? {
+            self.apply_transaction(txn)?;
+        }
+        {
+            let mut snapshot_manager = self.snapshot_writer.write();
+            snapshot_manager.bump_persisted_max_repeatable_ts(*target)?;
+        }
+        *tailed_ts = target;
+        Ok(())
+    }
+
+    async fn bootstrap_search_into_snapshot(
+        &mut self,
+        at: RepeatableTimestamp,
+    ) -> anyhow::Result<()> {
+        let (index_registry, table_mapping) = {
+            let snapshot = self.snapshot_writer.read().latest_snapshot();
+            (
+                snapshot.index_registry.clone(),
+                snapshot.table_mapping().clone(),
+            )
+        };
+        let repeatable_persistence =
+            RepeatablePersistence::new(self.reader.clone(), at, self.retention_validator.clone());
+        let bootstrapped = bootstrap_search_indexes(
+            index_registry,
+            &repeatable_persistence,
+            table_mapping.namespace(TableNamespace::Global),
+        )
+        .await?;
+        let mut snapshot_manager = self.snapshot_writer.write();
+        let mut pending_writes = crate::write_log::PendingWrites::new();
+        snapshot_manager.overwrite_last_snapshot_text_and_vector_indexes(
+            bootstrapped.text_index_manager,
+            bootstrapped.vector_index_manager,
+            &mut pending_writes,
+        );
+        Ok(())
+    }
+
+    async fn tail_once(&mut self, tailed_ts: &mut RepeatableTimestamp) -> anyhow::Result<()> {
+        let target = new_static_repeatable_recent(self.reader.as_ref()).await?;
+        if *target <= **tailed_ts {
+            return Ok(());
+        }
+        let repeatable_persistence = RepeatablePersistence::new(
+            self.reader.clone(),
+            target,
+            self.retention_validator.clone(),
+        );
+        let bootstrap_tables = {
+            let snapshot = self.snapshot_writer.read().latest_snapshot();
+            BootstrapTableIds::new(snapshot.table_mapping())
+        };
+        let range = TimestampRange::new((Bound::Excluded(**tailed_ts), Bound::Included(*target)));
+        let transactions =
+            stream_transactions(bootstrap_tables, &repeatable_persistence, range, Order::Asc);
+        futures::pin_mut!(transactions);
+        let mut applied_ts = **tailed_ts;
+        let mut num_txns: u64 = 0;
+        let mut num_revisions: u64 = 0;
+        while let Some(txn) = transactions.try_next().await? {
+            let ts = txn.ts;
+            num_txns += 1;
+            num_revisions += txn.revision_pairs.len() as u64;
+            self.apply_transaction(txn)?;
+            applied_ts = ts;
+        }
+        {
+            let mut snapshot_manager = self.snapshot_writer.write();
+            snapshot_manager.bump_persisted_max_repeatable_ts(*target)?;
+        }
+        *tailed_ts = target;
+        if num_txns > 0 {
+            tracing::debug!(
+                "[follower-tailer] applied {num_txns} txn(s) / {num_revisions} revision(s) up to \
+                 {applied_ts}; repeatable at {target}"
+            );
+        }
+        Ok(())
+    }
+
+    fn apply_transaction(
+        &mut self,
+        txn: crate::persistence_helpers::TransactionRevisions,
+    ) -> anyhow::Result<()> {
+        let ts = txn.ts;
+        let (latest_ts, mut new_snapshot) = self.snapshot_writer.read().latest();
+        if ts <= *latest_ts {
+            return Ok(());
+        }
+        let mut write_bytes: u64 = 0;
+        for rp in txn.revision_pairs {
+            let tablet_id = rp.id.table();
+            let table_number = new_snapshot.table_mapping().tablet_number(tablet_id)?;
+            let id = rp.id.to_resolved(table_number);
+            write_bytes += rp.document().map(|d| d.size() as u64).unwrap_or(0);
+            let update = DocumentUpdate {
+                id,
+                old_document: rp.prev_document().cloned(),
+                new_document: rp.document().cloned(),
+            };
+            new_snapshot.update(&update, ts)?;
+        }
+        let mut snapshot_manager = self.snapshot_writer.write();
+        snapshot_manager.push(ts, new_snapshot, write_bytes);
+        Ok(())
+    }
+
+    async fn cold_reload(&mut self) -> anyhow::Result<RepeatableTimestamp> {
+        let snapshot_ts = new_static_repeatable_recent(self.reader.as_ref()).await?;
+        let mut db_snapshot = DatabaseSnapshot::<RT>::load(
+            self.runtime.clone(),
+            self.reader.clone(),
+            snapshot_ts,
+            self.retention_validator.clone(),
+            self.virtual_system_mapping.clone(),
+        )
+        .await?;
+        db_snapshot.load_table_summaries().await?;
+        let new_ts = db_snapshot.timestamp();
+        let snapshot = db_snapshot.snapshot;
+        {
+            let mut snapshot_manager = self.snapshot_writer.write();
+            *snapshot_manager = SnapshotManager::new(*new_ts, snapshot);
+        }
+        self.bootstrap_search_into_snapshot(new_ts).await?;
+        Ok(new_ts)
+    }
+}
