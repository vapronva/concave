+                .await
+                .take()
+                .ok_or_else(|| {
+                    anyhow::anyhow!(
+                        "become_leader called but there is no follower tailer to stop (already \
+                         promoted or not a follower?)"
+                    )
+                })?;
+            handle.promote().await?
+        };
+        let mut snapshot_writer = promoted.writer;
+        let tailed_ts = promoted.tailed_ts;
+        tracing::info!(
+            "[promote] tailer stopped; recovered Writer at tailed_ts {tailed_ts}; \
+             snapshot.latest_ts {}",
+            self.snapshot_manager.lock().latest_ts(),
+        );
+        let idle_ts = new_idle_repeatable_ts(rw_persistence.as_ref(), &self.runtime).await?;
+        anyhow::ensure!(
+            *idle_ts >= *tailed_ts,
+            "promotion invariant violated: idle_ts {idle_ts} < tailed_ts {tailed_ts} (a write \
+             landed after the FINAL fast-forward — impossible while we hold the lease)"
+        );
+        if *idle_ts > *self.snapshot_manager.lock().latest_ts() {
+            snapshot_writer
+                .write()
+                .bump_persisted_max_repeatable_ts(*idle_ts)?;
+        }
+        let latest_ts = self.snapshot_manager.lock().latest_ts();
+        anyhow::ensure!(
+            *latest_ts == *idle_ts,
+            "promotion invariant violated: after bump, snapshot latest_ts {latest_ts} != idle_ts \
+             {idle_ts}"
+        );
+        let (retention_manager, retention_worker_seed) =
+            LeaderRetentionManager::new(self.runtime.clone(), rw_persistence.clone(), idle_ts)
+                .await?;
+        let (deleted_tablet_sender, deleted_tablet_receiver) = mpsc::channel(100);
+        let retention_workers = retention_worker_seed
+            .start_retention(
+                self.bootstrap_metadata.clone(),
+                self.snapshot_manager.clone(),
+                preempt_signal.clone(),
+                retention_rate_limiter,
+                deleted_tablet_sender,
