+        let mut index_cache_handle = self
+            .index_cache_handle()
+            .ok_or_else(|| anyhow::anyhow!("become_leader requires an index cache handle"))?;
+        index_cache_handle.set_write_log_reader(Arc::new(log_reader.clone()));
