+    pub async fn become_follower(
+        &self,
+        rw_persistence: Arc<dyn Persistence>,
+    ) -> anyhow::Result<()> {
+        let committer = {
+            let mut leader_state = self.leader_state.write();
+            leader_state.committer.take()
+        }
+        .ok_or_else(|| {
+            anyhow::anyhow!(
+                "become_follower called but there is no committer to stop (already a follower?)"
+            )
+        })?;
+        tracing::info!("[demote] stopping committer; recovering writer before lease release");
+        let recover_budget = 2 * *DEMOTION_DRAIN_TIMEOUT;
+        let recover = committer.shutdown_and_recover_writer().fuse();
+        pin_mut!(recover);
+        let recover_timeout = self.runtime.wait(recover_budget).fuse();
+        pin_mut!(recover_timeout);
+        let snapshot_writer = futures::select_biased! {
+            writer = recover => writer?,
+            _ = recover_timeout => anyhow::bail!(
+                "committer writer-recovery did not finish within {recover_budget:?}; demote \
+                 aborted with the committer wedged"
+            ),
+        };
+        let tailed_ts = self.snapshot_manager.lock().latest_ts();
+        tracing::info!(
+            "[demote] committer stopped; recovered Writer; snapshot.latest_ts {tailed_ts}"
+        );
+        let (old_subscriptions, retention_workers) = {
+            let leader_state = self.leader_state.read();
+            (
+                leader_state.subscriptions.clone(),
+                leader_state.retention_workers.clone(),
+            )
+        };
+        if let Some(retention_workers) = &retention_workers {
+            retention_workers.shutdown().await?;
+        }
+        match rw_persistence.release_lease().await {
+            Ok(true) => tracing::info!("[demote] lease released; peer may take over"),
+            Ok(false) => {
+                tracing::info!("[demote] lease was already lost before release (peer took over)")
+            },
+            Err(e) => {
+                tracing::error!(
+                    "[demote] lease release FAILED after stopping committer (will preempt): {e:#}"
+                );
+                return Err(e.context("lease release failed during demotion"));
+            },
+        }
+        let retention_manager: Arc<dyn RetentionValidator> = Arc::new(
+            FollowerRetentionManager::new(self.runtime.clone(), self.reader.clone()).await?,
+        );
+        let follower_tailer = FollowerLogTailer::start(
+            self.runtime.clone(),
+            snapshot_writer,
+            self.reader.clone(),
+            retention_manager.clone(),
+            self.virtual_system_mapping.clone(),
+            tailed_ts,
+            true,
+        );
+        let (log_owner, log_reader, _log_writer) = new_write_log(*tailed_ts);
+        let mut index_cache_handle = self
+            .index_cache_handle()
+            .ok_or_else(|| anyhow::anyhow!("become_follower requires an index cache handle"))?;
+        index_cache_handle.remove_deployment();
+        index_cache_handle.set_write_log_reader(Arc::new(log_reader.clone()));
+        let subscriptions = SubscriptionsWorker::start(
+            log_owner,
+            self.runtime.clone(),
+            self.invalidation_callback.clone(),
+        );
+        *self.follower_tailer_handle.lock().await = Some(follower_tailer);
+        {
+            let mut leader_state = self.leader_state.write();
+            debug_assert!(leader_state.committer.is_none());
+            leader_state.subscriptions = subscriptions;
+            leader_state.log = log_reader;
+            leader_state.retention_manager = retention_manager;
+            leader_state.retention_workers = None;
+            leader_state.index_cache_handle = Some(index_cache_handle);
+        }
+        old_subscriptions.shutdown();
+        if let Some(handle) = self.lease_watch_handle.lock().take() {
+            handle.detach();
+        }
+        tracing::info!(
+            "[demote] Database demoted to follower at ts {tailed_ts}; tailer resumed, no committer"
+        );
+        Ok(())
+    }
