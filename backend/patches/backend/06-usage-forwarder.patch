diff --git a/crates/local_backend/src/usage_forwarder.rs b/crates/local_backend/src/usage_forwarder.rs
new file mode 100644
index 000000000..5711183a9
--- /dev/null
+++ b/crates/local_backend/src/usage_forwarder.rs
@@ -0,0 +1,342 @@
+use async_trait::async_trait;
+use axum::{
+    extract::RawQuery,
+    response::{
+        IntoResponse,
+        Response,
+    },
+};
+use common::http::extract::MtState;
+use events::usage::{
+    UsageEvent,
+    UsageEventLogger,
+};
+use http::StatusCode;
+use metrics::{
+    log_counter,
+    register_convex_counter,
+};
+use reqwest::Client;
+use tokio::{
+    sync::{
+        mpsc,
+        oneshot,
+        Mutex,
+    },
+    time::{
+        timeout,
+        Duration,
+    },
+};
+
+use crate::{
+    authentication::ExtractIdentity,
+    LocalAppState,
+};
+
+const USAGE_FORWARDER_CHANNEL_CAPACITY: usize = 2048;
+const USAGE_FORWARDER_MAX_BATCHES_PER_POST: usize = 32;
+const SELF_HOSTED_USAGE_QUERY_PATH: &str = "/api/dashboard/teams/0/usage/query";
+
+register_convex_counter!(
+    USAGE_FORWARDER_DROPPED_BATCHES_TOTAL,
+    "Usage-event batches dropped because the forwarder channel was full or closed"
+);
+
+fn usage_sink_token() -> Option<String> {
+    std::env::var("CONVEX_USAGE_SINK_TOKEN")
+        .ok()
+        .filter(|t| !t.is_empty())
+}
+
+#[derive(Debug)]
+pub struct HttpUsageForwarder {
+    tx: mpsc::Sender<Vec<UsageEvent>>,
+    shutdown_tx: Mutex<Option<oneshot::Sender<()>>>,
+    worker: Mutex<Option<tokio::task::JoinHandle<()>>>,
+}
+
+fn coalesce_batches(
+    rx: &mut mpsc::Receiver<Vec<UsageEvent>>,
+    mut events: Vec<UsageEvent>,
+) -> (Vec<UsageEvent>, u64) {
+    let mut batches: u64 = 1;
+    while batches < USAGE_FORWARDER_MAX_BATCHES_PER_POST as u64 {
+        match rx.try_recv() {
+            Ok(more) => {
+                events.extend(more);
+                batches += 1;
+            },
+            Err(_) => break,
+        }
+    }
+    (events, batches)
+}
+
+async fn post_events(
+    client: &Client,
+    sink_url: &str,
+    token: Option<&str>,
+    deployment: &str,
+    events: Vec<UsageEvent>,
+    batches: u64,
+) {
+    if events.is_empty() {
+        return;
+    }
+    let body = serde_json::json!({
+        "deployment": deployment,
+        "events": events,
+    });
+    let mut req = client.post(sink_url).json(&body);
+    if let Some(token) = token {
+        req = req.bearer_auth(token);
+    }
+    for attempt in 1..=3 {
+        let Some(attempt_req) = req.try_clone() else {
+            tracing::error!("usage sink request is not clonable; dropping batch");
+            log_counter(&USAGE_FORWARDER_DROPPED_BATCHES_TOTAL, batches);
+            return;
+        };
+        match attempt_req.send().await {
+            Ok(resp) if resp.status().is_success() => return,
+            Ok(resp) => tracing::warn!(
+                "usage sink {} returned {} (attempt {attempt}/3)",
+                sink_url,
+                resp.status()
+            ),
+            Err(e) => tracing::warn!("usage sink post failed (attempt {attempt}/3): {e}"),
+        }
+        if attempt < 3 {
+            tokio::time::sleep(Duration::from_millis(100 * attempt)).await;
+        }
+    }
+    tracing::error!("usage sink batch permanently failed after 3 attempts");
+    log_counter(&USAGE_FORWARDER_DROPPED_BATCHES_TOTAL, batches);
+}
+
+impl HttpUsageForwarder {
+    pub fn new(sink_url: String, deployment: String) -> anyhow::Result<Self> {
+        let token = usage_sink_token();
+        let (tx, mut rx) = mpsc::channel::<Vec<UsageEvent>>(USAGE_FORWARDER_CHANNEL_CAPACITY);
+        let (shutdown_tx, mut shutdown_rx) = oneshot::channel::<()>();
+        let client = Client::builder()
+            .timeout(Duration::from_secs(30))
+            .connect_timeout(Duration::from_secs(10))
+            .build()?;
+        let worker = tokio::spawn(async move {
+            loop {
+                tokio::select! {
+                    Some(events) = rx.recv() => {
+                        let (events, batches) = coalesce_batches(&mut rx, events);
+                        post_events(
+                            &client,
+                            &sink_url,
+                            token.as_deref(),
+                            &deployment,
+                            events,
+                            batches,
+                        )
+                        .await
+                    },
+                    _ = &mut shutdown_rx => {
+                        rx.close();
+                        while let Ok(events) = rx.try_recv() {
+                            let (events, batches) = coalesce_batches(&mut rx, events);
+                            post_events(
+                                &client,
+                                &sink_url,
+                                token.as_deref(),
+                                &deployment,
+                                events,
+                                batches,
+                            )
+                            .await;
+                        }
+                        break;
+                    },
+                    else => break,
+                }
+            }
+        });
+        Ok(Self {
+            tx,
+            shutdown_tx: Mutex::new(Some(shutdown_tx)),
+            worker: Mutex::new(Some(worker)),
+        })
+    }
+}
+
+#[async_trait]
+impl UsageEventLogger for HttpUsageForwarder {
+    async fn record_async(&self, events: Vec<UsageEvent>) {
+        let n = events.len();
+        match self.tx.try_send(events) {
+            Ok(()) => {},
+            Err(mpsc::error::TrySendError::Full(_)) => {
+                log_counter(&USAGE_FORWARDER_DROPPED_BATCHES_TOTAL, 1);
+                tracing::error!(
+                    "usage forwarder full; dropping {} events (billing under-count)",
+                    n
+                )
+            },
+            Err(mpsc::error::TrySendError::Closed(_)) => {
+                log_counter(&USAGE_FORWARDER_DROPPED_BATCHES_TOTAL, 1);
+                tracing::error!(
+                    "usage forwarder closed; dropping {} events (billing under-count)",
+                    n
+                )
+            },
+        }
+    }
+
+    async fn shutdown(&self) -> anyhow::Result<()> {
+        if let Some(tx) = self.shutdown_tx.lock().await.take() {
+            let _ = tx.send(());
+        }
+        if let Some(mut handle) = self.worker.lock().await.take() {
+            if timeout(Duration::from_secs(5), &mut handle).await.is_err() {
+                handle.abort();
+                let queued = USAGE_FORWARDER_CHANNEL_CAPACITY.saturating_sub(self.tx.capacity());
+                if queued > 0 {
+                    log_counter(&USAGE_FORWARDER_DROPPED_BATCHES_TOTAL, queued as u64);
+                }
+                tracing::error!(
+                    "usage forwarder shutdown timed out; {queued} queued batches abandoned \
+                     (billing under-count)"
+                );
+            }
+        }
+        Ok(())
+    }
+}
+
+#[derive(Clone, Debug)]
+pub struct InsightsProxy {
+    base_url: reqwest::Url,
+    token: Option<String>,
+    client: Client,
+}
+
+impl InsightsProxy {
+    pub fn from_env() -> anyhow::Result<Option<Self>> {
+        let Some(base_url) = std::env::var("CONVEX_INSIGHTS_QUERY_URL")
+            .ok()
+            .filter(|u| !u.is_empty())
+        else {
+            return Ok(None);
+        };
+        Ok(Some(Self {
+            base_url: reqwest::Url::parse(&base_url)?,
+            token: std::env::var("CONVEX_INSIGHTS_QUERY_TOKEN")
+                .ok()
+                .filter(|t| !t.is_empty())
+                .or_else(usage_sink_token),
+            client: Client::builder()
+                .timeout(Duration::from_secs(15))
+                .connect_timeout(Duration::from_secs(10))
+                .build()?,
+        }))
+    }
+}
+
+pub async fn insights_query(
+    MtState(st): MtState<LocalAppState>,
+    ExtractIdentity(identity): ExtractIdentity,
+    RawQuery(query): RawQuery,
+) -> Response {
+    if identity
+        .require_operation(keybroker::DeploymentOp::ViewData)
+        .is_err()
+    {
+        return (StatusCode::FORBIDDEN, "insights requires deployment admin").into_response();
+    }
+    let Some(proxy) = &st.insights_proxy else {
+        return (
+            StatusCode::NOT_FOUND,
+            "insights query endpoint not configured",
+        )
+            .into_response();
+    };
+    let upstream = build_insights_url(&proxy.base_url, &st.instance_name, query.as_deref());
+    let mut req = proxy.client.get(upstream);
+    if let Some(token) = &proxy.token {
+        req = req.bearer_auth(token);
+    }
+    match req.send().await {
+        Ok(resp) => {
+            let status =
+                StatusCode::from_u16(resp.status().as_u16()).unwrap_or(StatusCode::BAD_GATEWAY);
+            let content_type = resp.headers().get(http::header::CONTENT_TYPE).cloned();
+            let body = match resp.bytes().await {
+                Ok(body) => body,
+                Err(e) => {
+                    tracing::warn!("[concave] insights upstream body read failed: {e}");
+                    return (
+                        StatusCode::BAD_GATEWAY,
+                        "insights upstream body read failed",
+                    )
+                        .into_response();
+                },
+            };
+            let mut response = (status, body).into_response();
+            if let Some(content_type) = content_type {
+                response
+                    .headers_mut()
+                    .insert(http::header::CONTENT_TYPE, content_type);
+            }
+            response
+        },
+        Err(e) => {
+            tracing::warn!("[concave] insights query proxy failed: {e}");
+            (StatusCode::BAD_GATEWAY, "insights upstream error").into_response()
+        },
+    }
+}
+
+fn build_insights_url(
+    base: &reqwest::Url,
+    deployment: &str,
+    raw_query: Option<&str>,
+) -> reqwest::Url {
+    let mut url = base.clone();
+    url.set_path(SELF_HOSTED_USAGE_QUERY_PATH);
+    url.set_query(None);
+    {
+        let mut pairs = url.query_pairs_mut();
+        if let Some(raw_query) = raw_query {
+            for (key, value) in url::form_urlencoded::parse(raw_query.as_bytes()) {
+                if key == "from" || key == "to" {
+                    pairs.append_pair(&key, &value);
+                }
+            }
+        }
+        pairs.append_pair("deploymentName", deployment);
+    }
+    url
+}
+
+#[cfg(test)]
+mod tests {
+    use super::build_insights_url;
+
+    #[test]
+    fn insights_url_pins_deployment_name() {
+        let url = build_insights_url(
+            &reqwest::Url::parse("http://bigbrain:8081/ignored").unwrap(),
+            "real deployment",
+            Some("from=2026-01-01&deploymentName=evil&to=2026-01-02"),
+        );
+        let pairs = url.query_pairs().collect::<Vec<_>>();
+        assert_eq!(
+            pairs
+                .iter()
+                .filter(|(key, _)| key == "deploymentName")
+                .count(),
+            1
+        );
+        assert!(pairs
+            .iter()
+            .any(|(key, value)| key == "deploymentName" && value == "real deployment"));
+    }
+}
